# Local reference source checkouts (PostgreSQL, SQLite, DuckDB, etc.).
# Provisioned on demand with `rake references:setup`; never committed.
# See CLAUDE.md §12. The canonical mirrors live on the persist volume,
# not here — these are git worktrees of those mirrors.
/references/

# Rust build artifacts (Cargo.lock IS committed — jed is an app, not a library).
/impl/rust/target/
/cli/target/
# Ruby gem's native-extension (cdylib) build artifacts; ext/Cargo.lock IS committed.
/impl/ruby/ext/target/
# WASM (wasm32-wasip1) wrap's build artifacts; impl/wasm/Cargo.lock IS committed.
/impl/wasm/target/
# Built gem packages.
/impl/ruby/*.gem

# Go build artifacts. NOTE: do not ignore "*.test" — the conformance corpus files
# use that extension (spec/conformance/suites/**/*.test).
/impl/go/bin/
# `go build ./cmd/mutate` (the mutation-testing harness) drops a binary here.
/impl/go/mutate

# TS core: installed dev-dependencies (typescript + @types/node for the engine; vite +
# @playwright/test for the browser/OPFS host's demo + e2e — dev-only, spec/design/hosts.md §5).
# package-lock.json IS committed for reproducibility; the engine/tests/harness run on
# bare Node with no install.
/impl/ts/node_modules/
# Browser/OPFS host build + e2e artifacts (Vite bundle, Playwright run output).
/impl/ts/dist-browser/
/impl/ts/test-results/
/impl/ts/playwright-report/

# Benchmark subsystem (spec/design/benchmarks.md): generated databases + results are
# local state; harness build artifacts mirror the per-core ignores above.
/bench/data/
/bench/results/
/bench/go/bin/
/bench/rust/target/
/bench/ts/node_modules/

# Personal, machine-local mise overrides (mise.toml IS committed/shared). Git has
# no knowledge of mise's conventions, so this must be ignored explicitly.
/mise.local.toml
/spec/conformance/suites/_reduce_tmp/
