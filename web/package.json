{
  "name": "web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "The jed website — static SvelteKit docs + live in-browser database playground (a non-core tooling module; CLAUDE.md §6/§14). Consumes the TS core (impl/ts) via a Vite alias.",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && pagefind --site build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:browser": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^24.13.2",
    "mdsvex": "^0.12.0",
    "prettier": "3.8.4",
    "prettier-plugin-svelte": "4.1.1",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-sql": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "codemirror": "^6.0.0",
    "pagefind": "^1.0.0",
    "shiki": "^1.0.0"
  }
}
