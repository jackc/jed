/* ===========================================================================
 * Jed SQL grammar — CANONICAL (CLAUDE.md §5, §6).
 *
 * One language-neutral EBNF. The hand-written parsers (impl/rust, impl/go,
 * impl/ts) are *downstream consumers* of this grammar, never the source of it;
 * the parser is explicitly NOT codegen'd (CLAUDE.md §5). This file is
 * DESCRIPTIVE of the currently-implemented surface, not aspirational — it grows
 * one production at a time as features land (see ../../TODO.md). The reasoning
 * lives in ../design/grammar.md; read it before editing.
 *
 * Notation (W3C-style EBNF, as in the XML / XQuery specs):
 *   rule ::= expr          a production
 *   A B                    concatenation (A then B)
 *   A | B                  alternation
 *   A?                     optional (zero or one)
 *   A*                     zero or more
 *   A+                     one or more
 *   ( ... )                grouping
 *   "..."                  a literal terminal (see case rule below)
 *   [a-z]                  a character class (one character)
 *   comment                a slash-star ... star-slash block, as used here
 *
 * Conventions specific to this grammar:
 *   - Keywords ("SELECT", "FROM", ...) are written as quoted terminals but are
 *     NOT reserved words: the lexer emits one `identifier` token for every bare
 *     word and the parser distinguishes keywords by position, case-insensitively.
 *     So a keyword spelling is a legal identifier where the grammar expects one.
 *   - Keyword terminals match case-insensitively (SELECT = select = SeLeCt).
 *     Punctuation terminals match literally.
 *   - Whitespace (space, tab, CR, LF) separates tokens and is otherwise
 *     insignificant. SQL comments are whitespace (../design/grammar.md §33):
 *     two hyphens start a line comment running to the end of the line, and a
 *     slash-star ... star-slash block comment NESTS (PostgreSQL / the SQL
 *     standard). Two hyphens ALWAYS start a comment outside a string literal,
 *     even abutting a token (`1--2` lexes as `1`). Comment openers inside a
 *     string literal are ordinary text. An unterminated block comment is a
 *     42601 syntax error.
 *   - Exactly one statement is parsed per input; there is no statement
 *     terminator (no ';').
 * ===========================================================================
 */

/* --- entry point --------------------------------------------------------- */

sql_statement  ::= create_table
                 | drop_table
                 | create_index
                 | drop_index
                 | insert
                 | query_expr
                 | update
                 | delete
                 | begin
                 | commit
                 | rollback

/* --- DDL ----------------------------------------------------------------- */

create_table   ::= "CREATE" "TABLE" identifier
                   "(" table_element ("," table_element)* ")"

/* A table element is a column definition or a table-level constraint: the
 * composite-capable PRIMARY KEY list, an (optionally named) CHECK constraint, or an
 * (optionally named) UNIQUE column list. Any may appear anywhere among the column
 * definitions (PostgreSQL's shape). An element starting with the two keywords
 * "PRIMARY" "KEY", with "CHECK" "(", with "UNIQUE" "(", or with "CONSTRAINT" parses as a
 * table constraint — the constraint keywords are not reserved (§3), but a column named
 * "primary" cannot have a type named "key" (no such type exists) and a column named
 * "check"/"constraint"/"unique" is followed by a type name, never "(" — so the
 * disambiguation loses nothing (../design/grammar.md §13/§29/§31). */
table_element  ::= column_def | table_constraint

/* "PRIMARY KEY (a, b, ...)" declares the table's key over one or more named columns; the
 * LIST order is the KEY order — it may differ from the column-declaration order (the
 * original 0A000 narrowing was lifted by the secondary-index catalog reshape, which
 * persists the key order explicitly — ../design/constraints.md §3). Each named column
 * must exist (42703) and appear once (42701); a table has at most one primary key across
 * both forms (42P16). Every member is implicitly NOT NULL and must be of a key-encodable
 * type (the column-level rule). The key bytes are the concatenation of the members'
 * encodings in LIST order (../design/encoding.md §2.3).
 *
 * "CHECK ( expr )" declares a row predicate over this table's columns, optionally named
 * via the "CONSTRAINT name" prefix (auto-named otherwise — ../design/constraints.md §4).
 * The expression is a general boolean expression (42804 otherwise) over the table's
 * columns; a subquery (0A000), an aggregate (42803), and a bind parameter (42P02) are
 * rejected at CREATE TABLE. The table-level and column-level CHECK forms are
 * semantically IDENTICAL — a column-level CHECK may reference any column (PostgreSQL's
 * model); the position only feeds the textual definition order. The "CONSTRAINT name"
 * prefix is accepted before CHECK and UNIQUE this slice (a jed narrowing; PG allows it
 * before any constraint).
 *
 * "UNIQUE (a, b, ...)" declares a uniqueness constraint over one or more named columns,
 * realized as a UNIQUE secondary index (../design/constraints.md §5, indexes.md §8). Each
 * named column must exist (42703, "named in key") and appear once (42701); each must be of
 * a key-encodable type (0A000). An identical column LIST (same columns, same order) as the
 * primary key, or as an earlier UNIQUE constraint, is folded away (PostgreSQL); the
 * backing index is auto-named lowercased "<table>_<cols>_key" with the smallest free
 * suffix, or takes the explicit CONSTRAINT name (collisions: 42P07 against the relation
 * namespace, 42710 against the table's constraint names). The column-level "UNIQUE" is the
 * one-member form. */
table_constraint ::= "PRIMARY" "KEY" "(" identifier ("," identifier)* ")"
                 | ["CONSTRAINT" identifier] "CHECK" "(" expr ")"
                 | ["CONSTRAINT" identifier] "UNIQUE" "(" identifier ("," identifier)* ")"

/* A column definition is a name, a type, and zero or more column constraints. The
 * constraints are order-free (the parsers accept them in any order, deduplicating —
 * "x int NOT NULL PRIMARY KEY" = "x int PRIMARY KEY NOT NULL"). "PRIMARY KEY" makes the
 * column the table's single-column key and implies NOT NULL. "NOT NULL" forbids a NULL
 * value in the column: storing one — directly, or via an applied/omitted default — traps
 * 23502 (../design/constraints.md). "DEFAULT" gives the column a default expression
 * (../design/constraints.md §2): a constant literal is pre-evaluated + coerced once at
 * CREATE TABLE; any other expression (a function call like "uuidv7()", arithmetic like
 * "1 + 1") is validated at CREATE TABLE and evaluated per row at INSERT. A column
 * reference, subquery, aggregate, or parameter in the expression is rejected.
 * "CHECK" declares a row predicate, identical in semantics to the table-level form
 * (../design/constraints.md §4) — its position only feeds the textual definition order.
 * The constraint keywords are NOT reserved (§3). */
column_def     ::= identifier type_name column_constraint*

column_constraint ::= "PRIMARY" "KEY"
                 | "NOT" "NULL"
                 | "DEFAULT" expr
                 | ["CONSTRAINT" identifier] "CHECK" "(" expr ")"
                 | ["CONSTRAINT" identifier] "UNIQUE"

/* DROP TABLE removes a table — its definition and all its rows — from the
 * catalog. The surface is deliberately minimal (../design/grammar.md §13): ONE
 * table (no "DROP TABLE a, b"), no "IF EXISTS" (dropping a table that does not
 * exist is a 42P01 undefined_table error, mirroring CREATE TABLE's 42P07 on a
 * duplicate), and no "CASCADE" / "RESTRICT" (there are no dependent objects yet).
 * Each omission is relaxable later (../../TODO.md). */
drop_table     ::= "DROP" "TABLE" identifier

/* CREATE INDEX declares a secondary index over one or more named columns of one table
 * (../design/indexes.md). "CREATE UNIQUE INDEX" makes it a UNIQUE index: building it over
 * existing duplicate values is 23505, and thereafter it enforces uniqueness at every write
 * (NULLS DISTINCT — indexes.md §8). The index name is optional: omitted, the engine
 * derives PostgreSQL's choice — lowercased "<table>_<col>_..._idx" with the smallest free
 * positive-integer suffix on collision (the "_idx" suffix even for a unique index;
 * "_key" is the UNIQUE-constraint spelling — table_constraint above). Because no word is
 * reserved (§3), the optional name needs one disambiguation: the word after INDEX is the
 * index name UNLESS it is "ON" followed by a word and then "(" — a fixed three-token
 * lookahead, byte-identical across the parsers (../design/grammar.md §30). Each named
 * column must exist (42703) and be of a key-encodable type (else 0A000); a column may be
 * listed more than once (PostgreSQL allows it). Index names share the TABLE namespace (a
 * duplicate in either is 42P07, "relation"). Narrowings this slice (each 0A000-free —
 * simply not in the grammar): no expression/ordered/partial keys (a key is a bare column
 * name), no IF NOT EXISTS, no USING, no NULLS NOT DISTINCT.
 *
 * DROP INDEX removes one index by name: 42704 if it does not exist, 42809 if the name is
 * a table ("is not an index"); symmetrically DROP TABLE of an index name is 42809 ("is
 * not a table"). DROP TABLE drops the table's indexes with it. DROP INDEX of a
 * constraint-backed unique index drops the UNIQUE constraint with it (a documented PG
 * divergence — jed has no ALTER TABLE ... DROP CONSTRAINT, so the index name is the
 * constraint's only handle; indexes.md §8). */
create_index   ::= "CREATE" "UNIQUE"? "INDEX" identifier? "ON" identifier
                   "(" identifier ("," identifier)* ")"
drop_index     ::= "DROP" "INDEX" identifier

/* type_name is an identifier, optionally followed by a parenthesized type modifier
 * (precision, optional scale) — `decimal` is the FIRST parameterized type. The name is
 * resolved by the catalog (case-insensitively); accepted names:
 *   int16 | smallint | int32 | int | integer | int64 | bigint
 *   text | varchar | "character varying" | string
 *   boolean | bool
 *   decimal | numeric | dec
 *   bytea
 *   uuid
 * An unknown name is rejected at execution time (42704), not by the grammar. The typmod
 * is accepted ONLY for decimal/numeric: numeric(p) (= numeric(p,0)) and numeric(p,s),
 * with 1 <= p <= 1000 and 0 <= s <= p (a bad typmod traps 22023; ../design/grammar.md).
 * A typmod on a non-decimal type, or empty parens `numeric()`, is a 42601 syntax error.
 * type_name appears in a column_def and in CAST(expr AS type_name). */
type_name      ::= identifier ("(" integer ("," integer)? ")")?

/* --- DML ----------------------------------------------------------------- */

/* INSERT's source is EITHER a "VALUES" list of one or more parenthesized rows OR a `select`
 * (INSERT ... SELECT — ../design/grammar.md §24). An optional column list names the target
 * columns (`INSERT INTO t (a, c) VALUES ...` / `... SELECT ...`); with no list the values map
 * positionally to every column in declaration order. Each VALUES row's arity — or the SELECT's
 * output column count — must match the list (or the column count); a mismatch is 42601 (for the
 * SELECT source this is checked even when it produces zero rows). Each VALUES value is a
 * `literal` or the "DEFAULT" keyword, which substitutes the target column's declared default.
 * A column not named in the list — or a "DEFAULT" slot — takes that column's default, else NULL,
 * else 23502 if it is NOT NULL (../design/constraints.md §2). An unknown column in the list is
 * 42703, a duplicate is 42701.
 *   A multi-row INSERT is two-phase / all-or-nothing, exactly like UPDATE (../design/grammar.md
 * §12): every row is fully validated — arity, type/range (22003), NOT NULL (23502) — and every
 * storage key checked for a duplicate (23505), both against existing rows AND earlier rows in
 * the same statement, BEFORE any row is inserted. If any check fails, no row is inserted. An
 * INSERT ... SELECT additionally validates each projected column's TYPE is assignable to its
 * target up front (42804, even over an empty source — §24), and its cost is the embedded
 * SELECT's accrued cost (not zero).
 *   "DEFAULT" is NOT reserved (§3): a column may be named "default", disambiguated positionally
 * (it is a keyword only in a VALUES slot). */
insert         ::= "INSERT" "INTO" identifier ("(" identifier ("," identifier)* ")")?
                   ( "VALUES" row ("," row)* | select )
                   returning_clause?

row            ::= "(" insert_value ("," insert_value)* ")"

insert_value   ::= "DEFAULT" | parameter | literal

update         ::= "UPDATE" identifier "SET"
                   assignment ("," assignment)*
                   where_clause?
                   returning_clause?

assignment     ::= identifier "=" expr

delete         ::= "DELETE" "FROM" identifier where_clause? returning_clause?

/* The terminal clause of the three DML statements (../design/grammar.md §32): the statement
 * becomes a query result projecting each affected row — INSERT the stored row, UPDATE the new
 * row, DELETE the old row. The item list is the ordinary select_items production (general
 * expressions, "AS" output labels, the standalone "*" glob), resolved against the target table
 * only; subqueries are allowed (they observe the pre-statement snapshot), aggregates are 42803.
 * The qualifiers "old" and "new" name the row's two versions (old.col = pre-statement, new.col
 * = post-statement; the absent side is the all-NULL row) — no new production: they are ordinary
 * qualified column references resolved as qualifier-only pseudo-relations, valid only here, and
 * shadowed by a target table actually named old/new (../design/grammar.md §32; PG 18 semantics).
 * "RETURNING" is NOT reserved (§3): it is recognized positionally as the trailing clause, and it
 * joins the table_ref implicit-alias stop-keyword set so an INSERT ... SELECT source never
 * swallows it as an alias (../design/grammar.md §15). Row order is unspecified (no ORDER BY
 * exists here — one after the clause is 42601). */
returning_clause ::= "RETURNING" select_items

/* --- transaction control (../design/transactions.md §4, ../design/grammar.md §27) --------- */

/* An explicit transaction block. "BEGIN" (optionally "BEGIN TRANSACTION" / "BEGIN WORK") and
 * "START TRANSACTION" are equivalent openers; the access mode defaults to READ WRITE. A nested
 * BEGIN — one issued while a block is already open — is 25001 (no SAVEPOINT/nesting this slice).
 * READ ONLY takes no write lock and pins a snapshot; a write statement inside it is 25006. */
begin          ::= ("BEGIN" ("TRANSACTION" | "WORK")? | "START" "TRANSACTION") access_mode?

access_mode    ::= "READ" "ONLY" | "READ" "WRITE"

/* COMMIT publishes the block's changes (durably, per the `synchronous` setting); "END" and
 * "COMMIT WORK"/"COMMIT TRANSACTION" are aliases. COMMIT of a *failed* block performs a ROLLBACK
 * (PostgreSQL). ROLLBACK discards the block's working set and clears a failed block. A
 * COMMIT/ROLLBACK with no open block is a lenient no-op success (no 25P01 — §4.2). The keywords
 * BEGIN/START/COMMIT/END/ROLLBACK/WORK/READ/ONLY/WRITE are NOT reserved (§3). */
commit         ::= ("COMMIT" | "END") ("TRANSACTION" | "WORK")?

rollback       ::= "ROLLBACK" ("TRANSACTION" | "WORK")?

/* --- queries ------------------------------------------------------------- */

/* A query expression is the top-level query form (../design/grammar.md §25): one or more SELECT
 * cores combined by the set operators UNION / INTERSECT / EXCEPT, with an optional trailing
 * ORDER BY / LIMIT / OFFSET that applies to the WHOLE combined result. With no set operator it is
 * a single SELECT — exactly the form the rest of the engine already supported, the trailing
 * clauses folding back onto the lone core.
 *   PRECEDENCE (PostgreSQL): INTERSECT binds TIGHTER than UNION and EXCEPT, so it is its own inner
 * level (intersect_expr); UNION and EXCEPT share one outer level and are LEFT-ASSOCIATIVE. Thus
 * "a UNION b INTERSECT c" = "a UNION (b INTERSECT c)" and "a UNION b EXCEPT c" =
 * "(a UNION b) EXCEPT c".
 *   Each operator's bare form deduplicates (UNION = UNION DISTINCT); an "ALL" suffix keeps
 * multiplicities (multiset union / intersection / difference); a "DISTINCT" suffix is the explicit
 * spelling of the default. Output columns take the LEFT operand's count and NAMES; the operands
 * must have the same column count (else 42601) and per-column unifiable types (else 42804 —
 * ../design/grammar.md §25, ../design/cost.md §3).
 *   Two deferred narrowings (../design/grammar.md §25): an operand may NOT carry its own
 * ORDER BY / LIMIT / OFFSET (one such operand clause surfaces as a leftover-token 42601), and
 * operands may NOT be parenthesized "(SELECT ...)". UNION / INTERSECT / EXCEPT / ALL / DISTINCT
 * are NOT reserved (§3), disambiguated positionally. */
query_expr     ::= set_expr order_by? limit_offset?

set_expr       ::= intersect_expr (("UNION" | "EXCEPT") ("ALL" | "DISTINCT")? intersect_expr)*

intersect_expr ::= select_core ("INTERSECT" ("ALL" | "DISTINCT")? select_core)*

/* A SELECT core is one SELECT WITHOUT a trailing ORDER BY / LIMIT / OFFSET — the operand form of
 * a set operation. A lone query_expr (no set operator) folds the trailing clauses back onto this
 * core, recovering the single-table / joined SELECT unchanged.
 *   The FROM clause is OPTIONAL (../design/grammar.md §34): with no FROM the select list
 * evaluates over ONE virtual zero-column row (PostgreSQL semantics) — no table is read, so no
 * scan cost accrues (../design/cost.md §3). WHERE / GROUP BY / HAVING (and a lone query's
 * ORDER BY / LIMIT / OFFSET) still compose; "SELECT *" with no FROM is 42601. Because keywords
 * are not reserved (§3), a word after the select items that is not "FROM" is NOT a FROM clause:
 * "SELECT distinct" at end of input is a column reference (the DISTINCT lookahead is unchanged)
 * and "SELECT from" reads "from" as a column — both resolve to 42703, a documented divergence
 * from PG's empty-target-list form (../design/grammar.md §34). */
select_core    ::= "SELECT" "DISTINCT"? select_items ("FROM" from_clause)?
                   where_clause?
                   group_by?
                   having_clause?

/* A SELECT with its own optional trailing ORDER BY / LIMIT / OFFSET — behaviorally identical to
 * the pre-set-operations `select`. This is the form an INSERT ... SELECT source takes; a set
 * operation is NOT allowed in an INSERT source this slice (a deferred narrowing,
 * ../design/grammar.md §25). */
select         ::= select_core order_by? limit_offset?

/* HAVING filters GROUPED rows: a general expression that must resolve to boolean (42804
 * otherwise), evaluated AFTER grouping/aggregation and BEFORE ORDER BY. Unlike WHERE (which
 * filters input rows and may NOT contain an aggregate — 42803), HAVING MAY reference
 * aggregates (HAVING COUNT(*) > 1, HAVING SUM(x) > 10 — even ones not in the SELECT list) and
 * the grouping keys; a non-aggregated column that is not a grouping key is 42803, the same
 * grouping-error rule the SELECT list takes. HAVING with no GROUP BY filters the single
 * whole-table aggregate row (../design/aggregates.md §8). HAVING makes a query an aggregate
 * query even with no GROUP BY and no select-list aggregate. */
having_clause  ::= "HAVING" expr

/* GROUP BY partitions the post-WHERE rows into groups that share a value on every grouping
 * key, producing one result row per group (../design/aggregates.md §5). A grouping key is a
 * bare or qualified table column (column_ref) — NOT a general expression (GROUP BY a + 1), an
 * output alias, or an ordinal (GROUP BY 1); those stay deferred, exactly the ORDER BY
 * narrowing (§10, ../design/grammar.md §5). With GROUP BY present, every column referenced in
 * the SELECT list (and HAVING/ORDER BY) that is NOT inside an aggregate MUST be a grouping
 * key, else 42803 grouping_error. NULL is its own single group (NULL groups with NULL, not
 * three-valued); decimal keys bucket by VALUE-canonical form so 1.5 and 1.50 share one group
 * (../design/decimal.md §5). Output group order with no ORDER BY is first-occurrence over the
 * source scan (the DISTINCT mechanism — grammar.md §11). */
group_by       ::= "GROUP" "BY" column_ref ("," column_ref)*

/* The FROM clause is a left-deep chain: a first table_ref followed by zero or more
 * join_clauses. With no join_clause it is the single-table SELECT the rest of the
 * engine already supported (../design/grammar.md §5/§15). A table_ref is a base table
 * name OR a set-returning function call (table_function — generate_series(1,5), the
 * computed row source of ../design/grammar.md §35), each with an optional alias — "AS"
 * optional ("orders o" = "orders AS o"). The alias (or, with none, the table name /
 * function name) is the relation's LABEL, used to qualify columns (t.col); two relations
 * with the same label (a self-join with no aliases, "t JOIN t") is a 42712 duplicate_alias.
 * A "(" immediately after the leading identifier marks the function form (a one-token
 * lookahead — a §8 determinism surface); the column-alias-list form "AS g(cols)" is a
 * deferred 0A000 narrowing. */
from_clause    ::= table_ref join_clause*

table_ref      ::= (table_function | identifier) ("AS"? identifier)?

table_function ::= identifier "(" expr ("," expr)* ")"

/* A join_clause is INNER JOIN ... ON <expr> (the "INNER" keyword is optional — a bare
 * "JOIN" is INNER) or CROSS JOIN (a Cartesian product, no "ON"). The "ON" predicate is a
 * general expression that must resolve to boolean (42804 otherwise), exactly like WHERE,
 * evaluated at the join (../design/grammar.md §15). An "INNER"/"JOIN" with no "ON" is a
 * 42601 syntax error; "CROSS JOIN ... ON ..." is likewise 42601.
 *   join_type is parsed for the OUTER family too (LEFT/RIGHT/FULL [OUTER]) so the grammar
 * carries the full shape, but executing an outer join is a documented 0A000 narrowing this
 * slice (only INNER and CROSS run — ../design/grammar.md §15, the text-PK/deferred-cast
 * deferral pattern). The join keywords are NOT reserved (§3): a column or table may be
 * named "join"/"inner"/"cross"/"on"/"left"/..., disambiguated positionally by the parser. */
join_clause    ::= "CROSS" "JOIN" table_ref
                 | join_type? "JOIN" table_ref "ON" expr

join_type      ::= "INNER"
                 | ("LEFT" | "RIGHT" | "FULL") "OUTER"?

/* "DISTINCT" removes duplicate PROJECTED output rows (dedup on the select-list
 * values, NULL-safe so two all-NULL rows collapse — ../design/grammar.md §11). It
 * is NOT reserved (a column may be named "distinct", §3), and it is the only
 * modifier that precedes the select list, so the parsers disambiguate it with a
 * TWO-token lookahead: the leading "DISTINCT" is the modifier iff the token after it
 * is NOT "FROM" and not end-of-input. So "SELECT distinct FROM t" selects a column
 * named distinct, "SELECT DISTINCT a FROM t" is the modifier, and "SELECT DISTINCT
 * distinct FROM t" is the modifier applied over a column named distinct. The rule is
 * a CLAUDE.md §8 determinism surface — it must be byte-identical across cores. */

/* A select item is a general expression with an optional output-name alias. The
 * "*" glob is a STANDALONE alternative — it is the whole select list, never mixed
 * with other items ("SELECT *, a" is not accepted; "SELECT t.*" has no qualified
 * form). Aliasing requires the explicit "AS" keyword; there is no implicit alias
 * ("SELECT a b"). The alias is an OUTPUT LABEL only: it names the result column and
 * is invisible to WHERE and ORDER BY resolution (those still resolve against table
 * columns). "AS" is not reserved (a column may be named "as"); the parser takes it
 * as an alias marker only after a complete expr, exactly as CAST consumes its own
 * inner "AS". The output name of an item with no alias is the column's canonical
 * name for a bare column reference, and the fixed literal "?column?" for any other
 * expression (see ../design/grammar.md §8). */
select_items   ::= "*"
                 | select_item ("," select_item)*

select_item    ::= expr ("AS" identifier)?

/* ORDER BY is one or more sort keys, applied left to right (the first key is
 * primary, ties broken by the next, and a full tie keeps the primary-key scan
 * order via a stable sort). A sort_key is a bare table column — NOT a general
 * expression, an output alias, or an ordinal position (those stay deferred,
 * ../design/grammar.md §5) — with an optional direction and an optional explicit
 * NULL placement. Default NULL placement follows direction: ASC => NULLS LAST,
 * DESC => NULLS FIRST, because the physical key order ratifies NULL as the LARGEST
 * value (the PostgreSQL model; ../design/types.md §4, ../types/compare.toml
 * null_ordering). An explicit NULLS FIRST | LAST overrides that default regardless
 * of direction. "NULLS" not followed by FIRST | LAST is a syntax error (42601). */
order_by       ::= "ORDER" "BY" sort_key ("," sort_key)*

sort_key       ::= column_ref ("ASC" | "DESC")? ("NULLS" ("FIRST" | "LAST"))?

/* LIMIT and OFFSET cap and skip output rows. They may appear in EITHER order, and
 * each clause AT MOST ONCE — a repeat (e.g. "LIMIT 1 LIMIT 2") is a syntax error
 * (42601). The slice is applied AFTER order_by and before projection, so a windowed
 * row count is what the SELECT result and the row_produced cost both reflect
 * (../design/grammar.md §9, ../design/cost.md §3). */
limit_offset   ::= limit_clause offset_clause?
                 | offset_clause limit_clause?

limit_clause   ::= "LIMIT" count

offset_clause  ::= "OFFSET" count

/* A non-negative integer literal — NOT a general expression (the same literal-only
 * narrowing INSERT makes). A leading "-" is well-formed grammar but the negative
 * VALUE is rejected deterministically at parse time — 2201W for LIMIT, 2201X for
 * OFFSET — analogous to the bare-2^63 -> 22003 case for `integer` (the value -0
 * folds to 0 and is accepted). The magnitude bound (42601) and the i64-range trap
 * (22003, a positive magnitude of 2^63) still apply via the shared integer lexer. */
count          ::= "-"? integer

/* A WHERE clause is a general expression that must resolve to `boolean`; a row
 * is kept iff it evaluates to TRUE (FALSE and NULL/unknown both exclude). */
where_clause   ::= "WHERE" expr

/* --- expressions --------------------------------------------------------- */

/* One expression grammar, shared by the SELECT list, WHERE, and UPDATE ... SET.
 * The productions are layered by precedence, loosest first; each level binds
 * tighter than the one above. The precedence is mirrored as authored data in
 * ../functions/catalog.toml (the `precedence` field) — the hand-written parsers
 * and that table must agree (see ../design/functions.md). Levels:
 *   OR  <  AND  <  NOT  <  comparison/IS NULL  <  additive  <  multiplicative
 *       <  unary minus  <  postfix (`::` cast, `.field`/`.*` field selection)  <  primary
 */
expr           ::= or_expr

or_expr        ::= and_expr ("OR" and_expr)*

and_expr       ::= not_expr ("AND" not_expr)*

not_expr       ::= "NOT" not_expr
                 | comparison

/* Comparison, IS [NOT] NULL, IS [NOT] DISTINCT FROM, and the predicate forms
 * [NOT] IN are all NON-associative: at most one of them applies to a pair/operand of
 * additive expressions, so "a = b = c" and "a IS DISTINCT FROM b IS DISTINCT FROM c"
 * are syntax errors (42601). IS [NOT] NULL is a postfix test binding at the comparison
 * level, so "a + 1 IS NULL" parses as "(a + 1) IS NULL". IS [NOT] DISTINCT FROM is
 * NULL-safe equality (a comparison with total NULL handling — functions.md §3); both its
 * operands are additive, so "a IS DISTINCT FROM b + 1" parses as
 * "a IS DISTINCT FROM (b + 1)". The leading "IS" is shared: after "IS" "NOT"? the
 * parser dispatches on "NULL" vs "DISTINCT".
 *   "NOT"? "IN" "(" ... ")" is the membership predicate (../design/grammar.md §20),
 * "NOT"? "BETWEEN" lo "AND" hi is the range predicate (§21), and "NOT"? "LIKE" pattern is the
 * text pattern match (§22) — all at the comparison level. A "NOT" before "IN"/"BETWEEN"/"LIKE"
 * is the predicate negation; the parsers take it with a two-token lookahead (the prefix "NOT"
 * was already consumed by not_expr) and only when the predicate keyword follows. The IN operand
 * is EITHER a parenthesized query_expr (the uncorrelated IN-subquery, §26 — disambiguated by a
 * leading "SELECT" after "(") OR a value list of one or more additive expressions; an empty
 * "IN ()" value list is a 42601 syntax error (an empty subquery RESULT is valid → FALSE). BETWEEN's two
 * bounds are additive expressions: parsing them at the additive level (which never consumes
 * "AND", a looser level) is what lets the structural "AND" be matched here, so
 * "x BETWEEN a AND b AND c" is "(x BETWEEN a AND b) AND c". LIKE's pattern is one additive
 * expression. PostgreSQL binds IN/BETWEEN/LIKE slightly tighter than the comparison operators;
 * collapsing them into this one non-associative level is a documented narrowing (unobservable,
 * since chaining comparisons is already a syntax error here). */
comparison     ::= additive ( compare_op additive
                            | "IS" "NOT"? "NULL"
                            | "IS" "NOT"? "DISTINCT" "FROM" additive
                            | "NOT"? "IN" "(" ( query_expr | additive ("," additive)* ) ")"
                            | "NOT"? "BETWEEN" additive "AND" additive
                            | "NOT"? "LIKE" additive )?

compare_op     ::= "=" | "<" | ">" | "<=" | ">="   /* no "<>" and no "!=" */

additive       ::= multiplicative ( ("+" | "-") multiplicative )*

multiplicative ::= unary ( ("*" | "/" | "%") unary )*

unary          ::= "-" unary
                 | postfix

/* The PostgreSQL `::` typecast operator — `expr :: type_name` is exactly
 * `CAST(expr AS type_name)` (../design/grammar.md §37, types.md §5), reusing the whole cast
 * machinery: the same cast matrix (../types/casts.toml), the same string-literal coercion for a
 * string-literal operand (`'42' :: int` = `CAST('42' AS int)` = `integer '42'`), the same deferred
 * narrowings (casting to/from text/boolean/bytea/uuid/timestamp/interval is 0A000), and the same
 * `42704`/`22003`/`22P02` resolve codes. Casts CHAIN left-associatively — `x :: int8 :: int2` is
 * `(x :: int8) :: int2` — and a typmod rides on the type name exactly as in CAST (`x :: numeric(10,2)`).
 *   PRECEDENCE: `::` binds TIGHTER than unary minus (PostgreSQL), so `-5 :: int` is `-(5 :: int)`,
 * NOT `(-5) :: int`. This is observable at the type bound: `-32768 :: int16` traps `22003` (the inner
 * `32768` overflows int16 before the negation), while `(-32768) :: int16` is the in-range value. The
 * leading-`-`-of-a-numeric-literal fold (../design/grammar.md §4) is therefore suppressed when a `::`
 * immediately follows the literal, so the cast applies to the unsigned magnitude first.
 *   A bind parameter operand takes the cast TARGET as its inferred type — `$1 :: int` declares `$1`
 * as int (../design/api.md §5), the parameter-typing case the `CAST(... AS ...)` spelling shares.
 *   COMPOSITE FIELD SELECTION (../design/composite.md §1, §S4): ".field" selects one field of a
 * composite base and ".*" expands all its fields (projection list only); both are postfix operators
 * at this level. Field selection is PARENS-REQUIRED (PostgreSQL): ".field"/".*" applies only to a
 * PARENTHESIZED base — "(home).zip", "(t.home).zip", "(ROW(1,2)).f1" — and chains on a prior field
 * access ("(c).a.b"). The unparenthesized "a.b"/"a.b.c" is consumed by column_ref as a (multi-part)
 * column reference, NEVER field access: its first identifier must name a relation, else 42P01
 * (there is no bare "col.field" fallback — PG rejects every unparenthesized field reference). Field
 * lookup is case-insensitive; an unknown field is 42703, a non-composite base 42809, ".*" in a
 * scalar position 0A000. NB: the grammar below writes the postfix uniformly, but the parens-required
 * rule is a hand-written-parser SEMANTIC gate (a "field_accessible" flag set true only for a
 * parenthesized primary and after each ".field"), not expressible as pure EBNF. */
postfix        ::= primary ( "::" type_name | "." identifier | "." "*" )*

/* A "(" begins either a parenthesized expression "(" expr ")" or a SCALAR SUBQUERY
 * "(" query_expr ")" (../design/grammar.md §26) — disambiguated by a leading "SELECT" after the
 * "(". "EXISTS" "(" query_expr ")" is the existence predicate. Both subquery forms (and the
 * IN-subquery above) are UNCORRELATED this slice: a reference to an outer-query column, or a bind
 * parameter "$N", inside the subquery is a 0A000 (../design/grammar.md §26). */
primary        ::= number
                 | string
                 | "TRUE" | "FALSE"
                 | "NULL"
                 | "CURRENT_TIMESTAMP"
                 | parameter
                 | typed_literal
                 | "CAST" "(" expr "AS" type_name ")"
                 | case_expr
                 | function_call
                 | "EXISTS" "(" query_expr ")"
                 | "(" ( query_expr | expr ) ")"
                 | column_ref

/* CURRENT_TIMESTAMP is the SQL-standard BARE keyword (no parens) for the transaction/statement
 * timestamp (../design/functions.md §12). It is pure sugar: the parser desugars it to a now() call,
 * so it shares now()'s resolution / execution / cost / STABLE volatility / default `now` column
 * label. Reserved as a primary like TRUE/FALSE/NULL (recognized only when NOT followed by "(" — the
 * precision-typmod form current_timestamp(p) is deferred, so a "(" falls through to ordinary
 * resolution, 42883). now() and clock_timestamp() are ordinary function_calls, not keywords. */

/* A typed string literal (../design/grammar.md §36): ANY type name IMMEDIATELY followed by a
 * single-quoted string, naming the literal's type so it is CONTEXT-FREE (carries that type in
 * any expression position) — e.g. `INTERVAL '1 day'`, `TIMESTAMP '2024-01-01'`, `INTEGER '42'`,
 * `NUMERIC '1.5'`, `BOOLEAN 'true'`, `BYTEA '\xDE'`, `UUID '…'`, `TEXT 'hi'`. This is PostgreSQL's
 * `type 'string'` form, equal to `CAST('string' AS type)` restricted to a string-literal operand
 * (../design/types.md §5). The string is coerced to the type at resolve time (22P02 malformed /
 * 22003 out of range / the type's own parse codes; 42704 if the type name is unknown), before any
 * scan. The leading word stays non-reserved (§3): the form is recognized ONLY when the next token
 * is a string — a ONE-token lookahead, a §8 determinism surface — so "timestamp"/"interval"/etc.
 * remain usable as column / function names otherwise. The type name is a bare identifier (NO
 * typmod here: a "(" after the name breaks the lookahead, so `NUMERIC(10,2) '…'` is not a typed
 * literal — typmod rides only on CAST). For the native-syntax types (integer/decimal/boolean) the
 * coercion matches jed's OWN literal grammar, not PG's extras (no hex/underscore/scientific/NaN —
 * documented §36 divergences). */
typed_literal  ::= identifier string

/* A bind parameter — "$" followed by a 1-based decimal index ($1, $2, …). NOT part of
 * the conformance corpus (which is literal-only, ../design/conformance.md §1.2): a
 * parameter is bound by the host API (../design/api.md), and its type is inferred from
 * context (sibling operand, target column, or CAST target; 42P18 if indeterminate). The
 * lexer rejects "$0", a leading zero ("$01"), and "$" with no following digit (42601).
 * Allowed anywhere `primary` is and as an `insert_value`; NOT in LIMIT/OFFSET, GROUP BY,
 * or a type modifier this slice (../design/grammar.md §5). */
parameter      ::= "$" digit+

/* A CASE expression (../design/grammar.md §23), a primary like CAST. Two forms: the SEARCHED
 * form has no operand before the first WHEN and each WHEN takes a boolean predicate; the SIMPLE
 * form has an operand and each WHEN takes a value compared for equality to it (`CASE x WHEN v
 * ...` is `x = v`). At least one WHEN is required (zero is a 42601 syntax error). With no
 * matching branch and no ELSE the result is NULL. The result-arm types (the THENs and ELSE)
 * unify to one common type (42804 if incompatible); an all-NULL CASE is text. CASE is the one
 * deliberately LAZY expression: the first TRUE branch wins and later arms are not evaluated
 * (../design/cost.md §3). CASE/WHEN/THEN/ELSE/END are not reserved (§3), disambiguated
 * positionally. */
case_expr      ::= "CASE" expr? ( "WHEN" expr "THEN" expr )+ ( "ELSE" expr )? "END"

/* The shared function-call syntax. A name resolves to an AGGREGATE function
 * (../functions/catalog.toml, kind = "aggregate" — COUNT/SUM/MIN/MAX/AVG) or a SCALAR
 * function (kind = "function" — abs/round, ../design/functions.md §9); any other name is
 * 42883 (undefined_function). The argument is either the "*" glob (accepted ONLY by
 * COUNT — COUNT(*) counts rows; "*" to any other function is a resolve error) or a
 * COMMA-SEPARATED list of general expressions: aggregates take exactly one (a second
 * argument is no such aggregate, 42883), abs takes one, round takes one or two. DISTINCT
 * inside the parens (COUNT(DISTINCT x)) is DEFERRED and rejected (42601). An AGGREGATE is
 * not allowed in WHERE / a JOIN ON / a GROUP BY key, nor nested in another aggregate
 * (42803); a SCALAR function is legal anywhere an expression is — see ../design/functions.md
 * §9 and ../design/aggregates.md.
 *   Function names are NOT reserved (§3): a column may be named "count" or "abs",
 * disambiguated by a ONE-token lookahead — a bare identifier IMMEDIATELY followed by "(" is
 * a call, otherwise it is a column_ref. So "SELECT count FROM t" selects a column named
 * count and "SELECT count(*) FROM t" is the aggregate. The "*" here (the COUNT(*) row-count
 * form) is distinct from the SELECT-list "*" glob. This lookahead is a CLAUDE.md §8
 * determinism surface — byte-identical across the three hand-written parsers
 * (../design/grammar.md §17). */
/* An argument is positional (`expr`) or NAMED (`name => expr`, PostgreSQL named notation —
 * the only spelling; legacy ":=" is rejected, ../design/grammar.md §17). A positional argument
 * may NOT follow a named one (parser-enforced, 42601). The argument list may be EMPTY (a
 * function whose parameters all DEFAULT — e.g. make_interval()). Named notation is valid only
 * for a function that declares parameter names (make_interval); elsewhere it is 42883. */
function_call  ::= identifier "(" ( "*" | function_arg ( "," function_arg )* )? ")"
function_arg   ::= ( identifier "=>" )? expr

/* A column reference is a bare column ("col") or a qualified column ("rel.col") where
 * `rel` is a relation's LABEL in the FROM clause (its alias, else its table name). A bare
 * name is resolved against every relation in scope: no match is 42703 undefined_column, a
 * match in two or more relations is 42702 ambiguous_column, exactly one match resolves. A
 * qualified name names exactly one relation (an unknown label is 42P01, a label with no
 * such column is 42703) and is never ambiguous (../design/grammar.md §15). The "." is the
 * `Dot` token (see the lexical layer); there is no "rel.*" qualified-star this slice. */
column_ref     ::= identifier ("." identifier)?

/* INSERT takes literals only (no expressions, no columns). A leading "-" before
 * a number here is the unary-minus operator applied to the literal, folded at
 * parse time. A `number` is an integer or a decimal (with a "." fractional part);
 * a decimal literal lands in a decimal column (rounded to its scale) and is a 42804
 * type error against an integer column. TRUE/FALSE/NULL are the non-numeric literal
 * forms; a TRUE/FALSE literal stores into a boolean column (boolean is storable —
 * ../design/types.md §9) but into a non-boolean column is a 42804 type error. */
literal        ::= "-"? number
                 | string
                 | "TRUE" | "FALSE"
                 | "NULL"

/* --- lexical (token) layer ----------------------------------------------- */

/* A `number` is an UNSIGNED numeric literal: either an integer or a decimal. The
 * sign, if any, is the unary-minus operator (so "- 5" with a space is legal, and
 * "-5" is the operator applied to "5", folded at parse time). The lexer scans one
 * run of digits with an optional fractional point and an optional scientific exponent,
 * emitting an INTEGER token only when there is NEITHER a "." NOR an exponent and a DECIMAL
 * token otherwise — so the integer paths (LIMIT/OFFSET `count`, the typmod, array arity)
 * are unaffected (a bare digit run is still an integer). */
number         ::= decimal | integer

/* An integer is an UNSIGNED magnitude of digits; its magnitude must be <= 2^63
 * (9223372036854775808); a larger magnitude is a syntax error (42601, cannot be
 * represented). The single value 2^63 is in range only as the operand of unary
 * minus, where it folds to int64's minimum (-9223372036854775808); a bare 2^63
 * fits no signed integer type and traps 22003 at resolve time. */
integer        ::= digit+

/* A decimal literal is either a "."-bearing significand (digits on at least one side —
 * `1.5`, `1.`, `.5`, `0.00`) or ANY significand followed by a scientific `e`-notation
 * exponent (`5e2`, `1.5e3`, `.5e-2`, `1e3`). A plain digit run with neither a "." nor an
 * exponent is an INTEGER, not a decimal. The written form fixes the value AND the scale
 * (number of fractional digits): `1.50` is coefficient 150, scale 2 — distinct in display
 * from `1.5` (scale 1) though equal in value. With an exponent the scale is
 * max(0, frac_digits − exponent) and the value shifts by 10^exponent (PostgreSQL numeric;
 * ../design/grammar.md §14): `1.5e3` is `1500` (scale 0), `1.5e-3` is `0.0015` (scale 4),
 * `5e2` is `500`. The coefficient's integer-part digits must be <= max_int_digits and the
 * scale <= max_scale (../types/scalars.toml; else 22003 at resolve). A decimal literal is an
 * untyped decimal constant that adapts to its context (../design/types.md §6, extended to
 * decimal). */
decimal        ::= significand exponent
                 | digit+ "." digit*
                 | "." digit+
significand    ::= digit+ "." digit*
                 | "." digit+
                 | digit+
exponent       ::= ( "e" | "E" ) ( "+" | "-" )? digit+

/* The "." token has two roles, resolved by the lexer on the FOLLOWING byte alone (no
 * preceding-token context, so the rule is trivially identical across cores — §4):
 *   - a "." with a DIGIT immediately after starts/continues a numeric literal (`.5`, and
 *     `123.` / `123.45` from the digit run above);
 *   - any other "." is the standalone `Dot` token, consumed only by `column_ref` (`t.col`).
 * The single overlap — an identifier immediately followed by `.<digit>` (`t.5`) — is
 * invalid SQL either way (a column name is never numeric), so it is left to lex as
 * `<word> <decimal>` and rejected at parse (42601); no qualified form needs it. A bare "."
 * with no digit after and no identifier before/after is still a 42601. */
dot            ::= "."

/* The `::` PostgreSQL typecast operator token — exactly two colons, scanned greedily. A LONE
 * `:` is not part of jed's surface (no host-parameter `:name`, no array slice, no `psql`
 * meta-syntax), so a single colon is a 42601 syntax error, reported by the lexer. Consumed only
 * by `postfix` above. */
double_colon   ::= ":" ":"

/* A single-quoted string literal (the `text` type). An embedded single quote is written
 * by doubling it (`''`) — standard_conforming_strings; there are NO backslash escapes. The
 * content is UTF-8 and compares by the `C` collation (../design/types.md §11). `char` is any
 * character other than a single quote. */
string         ::= "'" ( char | "''" )* "'"

/* Identifiers are ASCII only; there is no quoted-identifier syntax. */
identifier     ::= (letter | "_") (letter | digit | "_")*

letter         ::= [A-Za-z]
digit          ::= [0-9]
char           ::= /* any character except "'" */
