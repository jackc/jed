# NULL storage and three-valued logic (CLAUDE.md §4).
# Format + the `requires` directive: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.where_eq, query.is_null, query.order_by, types.int16, types.int32, null.three_valued, expr.arithmetic, expr.unary_minus

statement ok
CREATE TABLE t (id int32 PRIMARY KEY, v int16)

statement ok
INSERT INTO t VALUES (1, 10)

statement ok
INSERT INTO t VALUES (2, NULL)

# IS NULL selects the null row
query I nosort
SELECT id FROM t WHERE v IS NULL
----
2

# IS NOT NULL selects the rest
query I nosort
SELECT id FROM t WHERE v IS NOT NULL
----
1

# three-valued logic: `= NULL` is UNKNOWN, never TRUE -> no rows
query I nosort
SELECT id FROM t WHERE v = NULL
----

# a NULL value also never satisfies equality with a non-null
query I nosort
SELECT id FROM t WHERE v = 10 ORDER BY id
----
1

# NULL renders as the literal NULL in output
query II nosort
SELECT id, v FROM t ORDER BY id
----
1
10
2
NULL

# --- NULL propagates through arithmetic: any operator with a NULL operand yields NULL ---
# (CLAUDE.md §4 three-valued logic). The NULL row (id 2) returns NULL for every operator;
# a core that returned 0 or skipped the row would pass none of these.
query I nosort
SELECT v + 1 FROM t WHERE id = 2
----
NULL

query I nosort
SELECT v * 2 FROM t WHERE id = 2
----
NULL

query I nosort
SELECT -v FROM t WHERE id = 2
----
NULL

# NULL / 1 propagates (NULL, not a division result); modulo likewise. Neither is a
# division-by-zero trap — the NULL is the dividend, the divisor is non-zero.
query I nosort
SELECT v / 1 FROM t WHERE id = 2
----
NULL

query I nosort
SELECT v % 2 FROM t WHERE id = 2
----
NULL

# a NULL-bearing predicate is UNKNOWN, so the NULL row is filtered out: v + 1 = 11 holds
# for id 1 (10 + 1) but is UNKNOWN for id 2 (NULL + 1 = 11 -> UNKNOWN), which never selects.
query I nosort
SELECT id FROM t WHERE v + 1 = 11 ORDER BY id
----
1

# projecting an arithmetic expression over a mixed column: the non-null row computes, the
# NULL row propagates NULL (one query exercises both paths together)
query II nosort
SELECT id, v + 1 FROM t ORDER BY id
----
1
11
2
NULL
