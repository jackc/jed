# interval scalar type (spec/design/interval.md): a span of time held as three independent
# fields (months/days/micros). Storage, the "unit + time" input subset (single-quoted string
# adapting to an interval column, OR the INTERVAL '...' keyword literal in expression position),
# PG `IntervalStyle = postgres` rendering, and comparison/ordering/dedup by the canonical 128-bit
# SPAN (1 month = 30 days, 1 day = 24 h — so '1 mon' = '30 days' = '720:00:00'). NULL, the
# fractional-unit cascade, parse-error codes (22007 malformed / 22008 field overflow), and the
# interval PRIMARY KEY / UNIQUE / secondary index (the 16-byte interval-span-i128 span key,
# encoding.md §2.10 — span-equal values share a key). No field qualifiers, no precision typmod,
# no CAST.
# requires: ddl.create_table, ddl.primary_key, ddl.unique, ddl.secondary_index, dml.insert, dml.insert_multi_row, query.select, query.select_no_from, query.where_eq, query.comparison_order, query.is_null, query.order_by, query.distinct, query.group_by, query.aggregates, types.i32, types.interval

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, d interval)

statement ok
INSERT INTO t VALUES (1, '1 mon 2 days 03:04:05'), (2, '-1 day'), (3, '30 days'), (4, '1 mon'), (5, NULL), (6, '1.5 days')

# rendering (PG postgres style): a multi-field value, year/mon from the months field
query T nosort
SELECT d FROM t WHERE id = 1
----
1 mon 2 days 03:04:05

# the fractional-unit cascade: 1.5 days -> 1 day 12:00:00 (0.5 day = 12 h, exact)
query T nosort
SELECT d FROM t WHERE id = 6
----
1 day 12:00:00

# a negative field renders with its sign and the plural unit
query T nosort
SELECT d FROM t WHERE id = 2
----
-1 days

# the INTERVAL '...' keyword literal works in expression position (no column context needed)
query T nosort
SELECT INTERVAL '2 hours 30 minutes'
----
02:30:00

# year/mon split + bare time, signs across fields
query T nosort
SELECT INTERVAL '1 year 2 mons 3 days 4:5:6'
----
1 year 2 mons 3 days 04:05:06

# the zero interval renders as a bare 00:00:00
query T nosort
SELECT INTERVAL '0 seconds'
----
00:00:00

# span equality: '1 mon' (id 4) and '30 days' (id 3) compare EQUAL (1 month = 30 days)
query I nosort
SELECT id FROM t WHERE d = INTERVAL '30 days' ORDER BY id
----
3
4

# a bare string adapts to interval in a comparison context too
query I nosort
SELECT id FROM t WHERE d = '1 mon' ORDER BY id
----
3
4

# ordering is by the canonical span; ties broken by the PK
query I nosort
SELECT id FROM t WHERE d IS NOT NULL ORDER BY d, id
----
2
6
3
4
1

# DISTINCT collapses the span-equal '1 mon'/'30 days' to ONE row; the first-seen representation
# (PK scan order -> id 3 = '30 days') survives, then ORDER BY orders by span
query T nosort
SELECT DISTINCT d FROM t WHERE d IS NOT NULL ORDER BY d
----
-1 days
1 day 12:00:00
30 days
1 mon 2 days 03:04:05

# GROUP BY buckets by span: the '1 mon'/'30 days' rows form one group of 2
# names: d, count
query TI nosort
SELECT d, COUNT(*) FROM t WHERE d IS NOT NULL GROUP BY d ORDER BY d
----
-1 days
1
1 day 12:00:00
1
30 days
2
1 mon 2 days 03:04:05
1

# IS NULL / IS NOT NULL
query I nosort
SELECT id FROM t WHERE d IS NULL
----
5

# NULL sorts last ascending (PG model)
query I nosort
SELECT id FROM t ORDER BY d, id
----
2
6
3
4
1
5

# trailing `ago` negates the whole interval
query T nosort
SELECT INTERVAL '1 day 2 hours ago'
----
-1 days -02:00:00

# a bare number defaults to seconds (PG)
query T nosort
SELECT INTERVAL '90'
----
00:01:30

# --- parse errors (PG agrees: bad interval input fails) ---

statement error 22007
SELECT INTERVAL '1 fortnight'

statement error 22007
SELECT INTERVAL 'not an interval'

# a bare ambiguous `m` is not accepted (months vs minutes)
statement error 22007
SELECT INTERVAL '1 m'

# --- G24: mixed-sign render + field overflow ---

# Mixed-sign output: when the independent fields carry OPPOSITE signs, PG `postgres` style renders
# each with its own sign (the positive ones gaining a leading `+`). `-1 mon 2 days` → `-1 mons +2 days`.
query T nosort
SELECT INTERVAL '-1 mon 2 days'
----
-1 mons +2 days

# A year+month input collapses into the single months field (1 year = 12 mons), so `-1 year 2 mons`
# is -10 months → `-10 mons` (one field, one sign — NOT mixed).
query T nosort
SELECT INTERVAL '-1 year 2 mons'
----
-10 mons

# A field whose magnitude overflows the canonical representation traps 22008. PostgreSQL raises its
# dedicated interval_field_overflow code 22015 instead — a documented code divergence (jed reuses
# its datetime field-overflow code, oracle_overrides ledger).
statement error 22008
SELECT INTERVAL '100000000000 years'

# --- interval as a PRIMARY KEY (encoding.md §2.10: interval-span-i128) --------------------------
# interval IS a valid PRIMARY KEY — its order-preserving 16-byte SPAN key is exercised here (the
# third fixed-width non-integer key, and the first whose key body differs from its stored value body:
# the key is the derived canonical span, the value keeps the three raw fields).
statement ok
CREATE TABLE ik (k interval PRIMARY KEY, n i32)

# insert deliberately NOT in key order; the spread crosses the sign boundary, the zero interval, and
# the month/day/time fields.
statement ok
INSERT INTO ik VALUES ('1 day', 2), ('-1 mon', 6), ('100 years', 7), ('0', 4), ('1 sec', 1), ('-1 day', 5), ('1 mon', 3)

# point lookup on the interval PK (span-keyed equality) resolves the matching row
query I nosort
SELECT n FROM ik WHERE k = '1 day'
----
2

# the key encodes the canonical SPAN, not the field triple: '30 days' (span-equal to the stored
# '1 mon') finds that row — the "equal but not identical" case (1 mon = 30 days)
query I nosort
SELECT n FROM ik WHERE k = '30 days'
----
3

# a full scan iterates in key (= span) order: -1 mon < -1 day < 0 < 1 sec < 1 day < 1 mon < 100 years;
# each value renders its OWN fields (PG returns heap order — oracle_overrides ledger)
query TI nosort
SELECT k, n FROM ik
----
-1 mons
6
-1 days
5
00:00:00
4
00:00:01
1
1 day
2
1 mon
3
100 years
7

# a duplicate interval PK is a unique violation (23505)
statement error 23505
INSERT INTO ik VALUES ('1 day', 9)

# span-canonicality: '30 days' equals the stored '1 mon', so it conflicts too (23505) — they index as one
statement error 23505
INSERT INTO ik VALUES ('30 days', 9)

# a NULL interval PK is rejected NOT NULL (23502)
statement error 23502
INSERT INTO ik VALUES (NULL, 9)

# interval is also a valid UNIQUE column and an ordered secondary-index key (the same lifted gate)
statement ok
CREATE TABLE iu (id i32 PRIMARY KEY, span interval UNIQUE)

statement ok
INSERT INTO iu VALUES (1, '1 mon'), (2, '2 days')

# the UNIQUE interval index treats '30 days' as equal to the stored '1 mon' (span-equal, field-distinct) — 23505
statement error 23505
INSERT INTO iu VALUES (3, '30 days')

statement ok
CREATE INDEX iu_span ON iu (span)
