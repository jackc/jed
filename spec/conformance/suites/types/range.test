# Range values (spec/design/ranges.md): the six built-in PostgreSQL range types as a structural type
# over a scalar element. This slice (R0–R3): the '[1,5)' text literal coerced by a named type
# ('[1,5)'::int4range / a bare string adapting to a range column), inclusive/exclusive + unbounded
# endpoints + the distinguished empty value, the compact value codec (type_code 17, format_version
# 16), range_out rendering ([lo,hi) with PG bound quoting), canonicalization of discrete subtypes
# (i32/i64/date stored canonical [); continuous subtypes kept verbatim), empty normalization, the
# whole-value IS NULL rule, and (R3) the range_cmp total order driving =/</ORDER BY/DISTINCT. The
# constructor/operator surface lands in follow-ons (RF1–RF4). Since the range-PK slice a range IS a
# valid PRIMARY KEY / ordered index / UNIQUE key / FK target — the first CONTAINER key (range-bounds,
# encoding.md §2.11; PG also indexes ranges via its range btree opclass), exercised below; a range
# DEFAULT stays 0A000 and a cross-element comparison (int4range × int8range) is 42804 (per-core tests —
# PG allows the former and reports 42883 for the latter). The names int4range/int8range are jed aliases
# of i32range/i64range, used here so the SQL is oracle-clean (the canonical i32range/i64range spelling
# is a per-core divergence test). range_out matches PostgreSQL byte-for-byte. Format:
# ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, ddl.unique, ddl.secondary_index, ddl.foreign_key, dml.insert, dml.insert_multi_row, dml.update, dml.update_container, query.select, query.where_eq, query.order_by, query.distinct, query.is_null, types.range, types.i32, types.decimal, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, r int4range, br int8range)

# A bare string literal adapts to the range column (range_in); a finite [) is stored verbatim.
statement ok
INSERT INTO t VALUES (1, '[1,5)', '[10,20)')

# A discrete range canonicalizes to [): an inclusive upper '[1,5]' becomes [1,6); a NULL range stores
# the lone NULL (distinct from the empty range).
statement ok
INSERT INTO t VALUES (2, '[1,5]', NULL)

# 'empty' is the distinguished empty value; an infinite-lower (,100) keeps the open lower bound.
statement ok
INSERT INTO t VALUES (3, 'empty', '(,100)')

# Both-infinite (,) ; an exclusive-lower '(5,)' canonicalizes to [6,) (the +1 step with an open upper).
statement ok
INSERT INTO t VALUES (4, '(,)', '(5,)')

# A NULL range; a singleton '[1,1]' canonicalizes to [1,2).
statement ok
INSERT INTO t VALUES (5, NULL, '[1,1]')

# range_out renders [lo,hi): empty for the empty range, an omitted bound for an infinite side, a NULL
# range as NULL. Ordering is by id (range comparison lands in R3).
query ITT nosort
SELECT id, r, br FROM t ORDER BY id
----
1
[1,5)
[10,20)
2
[1,6)
NULL
3
empty
(,100)
4
(,)
[6,)
5
NULL
[1,2)

# Whole-value IS NULL: only a SQL-NULL range is NULL — the empty range and (,) are NOT NULL.
query I nosort
SELECT id FROM t WHERE r IS NULL ORDER BY id
----
5

query I nosort
SELECT id FROM t WHERE r IS NOT NULL ORDER BY id
----
1
2
3
4

# --- the literal cast / typed-literal forms (oracle-pinned renders) ---

# Discrete canonicalization: an exclusive lower steps up, an inclusive upper steps up.
query T nosort
SELECT '(1,5)'::int4range
----
[2,5)

# A one-point discrete range that is not both-inclusive normalizes to empty.
query T nosort
SELECT '[5,5)'::int4range
----
empty

# A both-inclusive singleton is kept (then canonicalized [5,6)).
query T nosort
SELECT '[5,5]'::int4range
----
[5,6)

# int8range over i64.
query T nosort
SELECT '[100,200)'::int8range
----
[100,200)

# numrange is continuous — bounds + inclusivity kept verbatim (no canonicalization).
query T nosort
SELECT '[1.5,2.5]'::numrange
----
[1.5,2.5]

query T nosort
SELECT 'empty'::numrange
----
empty

# daterange is discrete — an inclusive upper steps up one day.
query T nosort
SELECT '[2024-01-01,2024-02-01]'::daterange
----
[2024-01-01,2024-02-02)

# A daterange bound has no special char, so it renders bare (no quoting).
query T nosort
SELECT '[2024-01-01,)'::daterange
----
[2024-01-01,)

# A tsrange bound contains a space, so range_out double-quotes both bounds (the §5 quoting path).
query T nosort
SELECT '["2020-01-01 09:00","2020-02-01 12:30")'::tsrange
----
["2020-01-01 09:00:00","2020-02-01 12:30:00")

# --- R3: comparison & ordering (range_cmp total order, spec/design/ranges.md §6) ---

# ORDER BY r: empty sorts below every non-empty range; then by lower bound (an infinite lower is the
# smallest), then upper bound; a NULL range sorts last (NULLS LAST default). Tie-break by id.
query IT nosort
SELECT id, r FROM t ORDER BY r, id
----
3
empty
4
(,)
1
[1,5)
2
[1,6)
5
NULL

# Equality is over the CANONICAL form: a discrete [1,5] and [1,6) coincide (both → [1,6)), and
# [1,5) equals [1,4] (→ [1,5)). empty is least; <= is reflexive; (,) is below any finite-lower range.
query B nosort
SELECT '[1,5]'::int4range = '[1,6)'::int4range
----
true

query B nosort
SELECT '[1,5)'::int4range = '[1,4]'::int4range
----
true

query B nosort
SELECT '[1,5)'::int4range = '[1,5]'::int4range
----
false

query B nosort
SELECT 'empty'::int4range < '[1,5)'::int4range
----
true

query B nosort
SELECT '[1,5)'::int4range <= '[1,5)'::int4range
----
true

query BBBB nosort
SELECT '[1,5)'::int4range < '[1,5)'::int4range,
       '[1,5)'::int4range <= '[1,5)'::int4range,
       '[1,5)'::int4range > '[1,5)'::int4range,
       '[1,5)'::int4range >= '[1,5)'::int4range
----
false
true
false
true

query B nosort
SELECT '(,)'::int4range < '[1,5)'::int4range
----
true

# Inclusivity tiebreaks on a continuous numrange (where [1 vs (1 and 5) vs 5] survive
# canonicalization): for an equal lower value an inclusive lower sorts before an exclusive one
# ([1 < (1); for an equal upper an exclusive upper sorts before an inclusive one (5) < 5]).
query B nosort
SELECT '[1,5)'::numrange < '[1,5]'::numrange
----
true

query B nosort
SELECT '[1,5]'::numrange < '(1,5)'::numrange
----
true

# ORDER BY over a numrange table exercises the inclusivity tiebreaks end to end.
statement ok
CREATE TABLE nr (id i32 PRIMARY KEY, r numrange)

statement ok
INSERT INTO nr VALUES (1, '[1,5)'), (2, '(1,5)'), (3, '[1,5]'), (4, '(1,5]'), (5, '[1,3]'), (6, 'empty')

query IT nosort
SELECT id, r FROM nr ORDER BY r, id
----
6
empty
5
[1,3]
1
[1,5)
3
[1,5]
2
(1,5)
4
(1,5]

# SELECT DISTINCT dedups on the canonical form: the two empties collapse, [1,5)/[1,4] collapse to
# [1,5), and the NULL ranges collapse to one (PG treats NULLs as not distinct).
statement ok
CREATE TABLE dr (id i32 PRIMARY KEY, r int4range)

statement ok
INSERT INTO dr VALUES (1,'[1,5)'), (2,'[1,4]'), (3,'[1,5]'), (4,'empty'), (5,'empty'), (6,NULL), (7,NULL)

query T rowsort
SELECT DISTINCT r FROM dr
----
NULL
[1,5)
[1,6)
empty

# --- error conditions (oracle-pinned) ---

# A range whose lower bound exceeds its upper bound is 22000.
statement error 22000
SELECT '[5,1)'::int4range

# A malformed range literal (missing comma / extra field) is 22P02.
statement error 22P02
SELECT '[1,2,3)'::int4range

statement error 22P02
SELECT 'not a range'::int4range

# Canonicalizing a discrete upper past the element domain overflows (22003).
statement error 22003
SELECT '[1,2147483647]'::int4range

# There is no range type over text — textrange is an undefined type (42704).
statement error 42704
CREATE TABLE bad (id i32 PRIMARY KEY, r textrange)

# --- range as a PRIMARY KEY (encoding.md §2.11: range-bounds, the first CONTAINER key) ----------
# A range IS a valid PRIMARY KEY — its recursive order-preserving range-bounds key is exercised here:
# a leading empty/non-empty discriminator, the lower bound (−∞ < finite < +∞), then the upper, each
# finite bound carrying the i32 element key + an inclusivity byte. PG also btree-indexes ranges.
statement ok
CREATE TABLE rk (k int4range PRIMARY KEY, n i32)

# insert deliberately NOT in key order; the spread covers empty, unbounded-lower, fully-unbounded, and
# finite-bound ranges
statement ok
INSERT INTO rk VALUES ('[1,5)', 3), ('empty', 0), ('(,)', 2), ('[2,)', 5), ('(,5)', 1), ('[2,4)', 4)

# point lookup on the range PK resolves the matching row (the operand is cast to the range type — a
# range `=` compares range-to-range, not range-to-text)
query I nosort
SELECT n FROM rk WHERE k = '[1,5)'::int4range
----
3

# the discrete range is stored canonical [): '[1,4]' equals the stored '[1,5)', so the non-canonical
# spelling finds that row (the "equal but not identical" container analogue of decimal scale / span)
query I nosort
SELECT n FROM rk WHERE k = '[1,4]'::int4range
----
3

# a full scan iterates in key (= range_total_cmp) order: empty < (,5) < (,) < [1,5) < [2,4) < [2,)
# (PG returns heap/insertion order — oracle_overrides ledger; the multiset is identical)
query TI nosort
SELECT k, n FROM rk
----
empty
0
(,5)
1
(,)
2
[1,5)
3
[2,4)
4
[2,)
5

# a duplicate range PK is a unique violation (23505)
statement error 23505
INSERT INTO rk VALUES ('[1,5)', 9)

# discrete canonicality: '[1,4]' canonicalizes to the stored '[1,5)', so it conflicts too (23505)
statement error 23505
INSERT INTO rk VALUES ('[1,4]', 9)

# a NULL range PK is rejected NOT NULL (23502)
statement error 23502
INSERT INTO rk VALUES (NULL, 9)

# range is also a valid UNIQUE column and an ordered secondary-index key (the same lifted gate). A
# numrange (continuous, decimal element) shows the bound's scale-independence carries through.
statement ok
CREATE TABLE ru (id i32 PRIMARY KEY, span numrange UNIQUE)

statement ok
INSERT INTO ru VALUES (1, '[1.0,2.0)'), (2, '[3,4)')

# the UNIQUE numrange index treats '[1.00,2.00)' as equal to the stored '[1.0,2.0)' (the decimal
# element 1.00 = 1.0, 2.00 = 2.0) — 23505
statement error 23505
INSERT INTO ru VALUES (3, '[1.00,2.00)')

statement ok
CREATE INDEX ru_span ON ru (span)

# range is also a valid FOREIGN KEY reference target (the lifted gate makes it a key)
statement ok
CREATE TABLE rchild (id i32 PRIMARY KEY, fr int4range REFERENCES rk (k))

# an FK value matching a parent range key inserts; a non-canonical spelling of a present key matches too
statement ok
INSERT INTO rchild VALUES (1, '[2,4)'), (2, '[1,4]')

# an FK value with no matching parent range key is a foreign-key violation (23503)
statement error 23503
INSERT INTO rchild VALUES (3, '[100,200)')

# ── Updating a range column (dml.update_container, ranges.md §4) ──────────────────────────────────
statement ok
CREATE TABLE rupd (id i32 PRIMARY KEY, during int4range)

statement ok
INSERT INTO rupd VALUES (1, '[10,20)'), (2, '[5,9)'), (3, '[100,200)')

# A bare string literal adapts to the range column (range_in), like INSERT.
statement ok
UPDATE rupd SET during = '[30,40)' WHERE id = 1

# An explicit cast and the type constructor are both valid RHS forms.
statement ok
UPDATE rupd SET during = '[1,5)'::int4range WHERE id = 2

statement ok
UPDATE rupd SET during = int4range(50, 60) WHERE id = 2

# The RHS is a general expression over the OLD row: a range set-op (union) reads `during` and stores
# the result. Discrete canonicalization applies to the stored value ([)).
statement ok
UPDATE rupd SET during = during + int4range(60, 70) WHERE id = 2

# NULL clears the range (the column is nullable).
statement ok
UPDATE rupd SET during = NULL WHERE id = 3

query IT nosort
SELECT id, during FROM rupd ORDER BY id
----
1
[30,40)
2
[50,70)
3
NULL

# A scalar RHS is not assignable to a range column (42804).
statement error 42804
UPDATE rupd SET during = 5 WHERE id = 1

# A range of a DIFFERENT element type is not assignable (int8range ⇏ int4range) — 42804.
statement error 42804
UPDATE rupd SET during = '[1,2)'::int8range WHERE id = 1

# Re-keying a range PRIMARY KEY: the row moves to its new key; an end-state collision is 23505.
statement ok
CREATE TABLE rkupd (during int4range PRIMARY KEY, note text)

statement ok
INSERT INTO rkupd VALUES ('[1,5)', 'a'), ('[10,20)', 'b')

statement ok
UPDATE rkupd SET during = '[100,200)' WHERE note = 'a'

query TT nosort
SELECT during, note FROM rkupd ORDER BY during
----
[10,20)
b
[100,200)
a

# Re-keying onto an existing key collides (end-state 23505).
statement error 23505
UPDATE rkupd SET during = '[10,20)' WHERE note = 'a'
