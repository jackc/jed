# date scalar type (spec/design/date.md): a calendar date — year/month/day, no time/zone,
# int32 days since 1970-01-01 (reusing timestamp's calendar core). Storage, strict ISO
# YYYY-MM-DD literals (a single-quoted string adapting like timestamp, or the DATE '...' keyword)
# with BC era and the infinity/-infinity sentinels, comparison/ordering by the day count, a date
# PRIMARY KEY (key encoding = int32, so PK is SUPPORTED — like timestamp), and the parse-error
# codes (22007 malformed / 22008 field-or-range overflow). A trailing time/offset in a date
# literal is VALIDATED then DROPPED (PG), and 24:00:00 does NOT roll into the day (unlike
# timestamp). date is a strict island — it does not compare to timestamp (42804).
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.where_eq, query.comparison_order, query.is_null, query.is_distinct_from, query.order_by, types.int32, types.text, types.date, types.timestamp, resource.cost_metering

statement ok
CREATE TABLE t (id int32 PRIMARY KEY, d date)

statement ok
INSERT INTO t VALUES (1, '2024-01-15'), (2, '1999-12-31'), (3, 'infinity'), (4, '-infinity'), (5, NULL), (6, '0044-03-15 BC'), (7, '2024-06-15 12:34:56')

# rendering: YYYY-MM-DD, no time
query T nosort
SELECT d FROM t WHERE id = 1
----
2024-01-15

# the infinity sentinels render as the bare words
query T nosort
SELECT d FROM t WHERE id = 3
----
infinity

query T nosort
SELECT d FROM t WHERE id = 4
----
-infinity

# a BC-era date: astronomical year -43 displays as 0044 with a BC suffix
query T nosort
SELECT d FROM t WHERE id = 6
----
0044-03-15 BC

# a date literal carrying a time keeps ONLY the date portion — the time 12:34:56 is dropped
query T nosort
SELECT d FROM t WHERE id = 7
----
2024-06-15

# equality is by the day count; the DATE '...' keyword literal names the type directly
query I nosort
SELECT id FROM t WHERE d = DATE '2024-01-15'
----
1

# infinity compares as the largest value
query I nosort
SELECT id FROM t WHERE d = 'infinity'
----
3

query I nosort
SELECT id FROM t WHERE d > '2024-06-15'
----
3

# ordering predicate: every finite date < a fixed date, plus -infinity and the BC value; infinity
# and NULL excluded. < '2024-03-01' matches ids 1 (2024-01-15), 2 (1999), 4 (-inf), 6 (BC).
query I nosort
SELECT id FROM t WHERE d < '2024-03-01' ORDER BY id
----
1
2
4
6

# total order over the day count: -infinity < BC < 1999 < 2024-01 < 2024-06 < infinity
query I nosort
SELECT id FROM t WHERE d IS NOT NULL ORDER BY d
----
4
6
2
1
7
3

# NULL sorts last (ascending), as for every type
query I nosort
SELECT id FROM t ORDER BY d
----
4
6
2
1
7
3
5

query I nosort
SELECT id FROM t WHERE d IS NULL
----
5

query I nosort
SELECT id FROM t WHERE d IS NOT NULL ORDER BY id
----
1
2
3
4
6
7

# = NULL is UNKNOWN, never a match (three-valued logic)
query I nosort
SELECT id FROM t WHERE d = NULL
----

# IS [NOT] DISTINCT FROM: NULL-safe equality; infinity is a present, non-null value
query I nosort
SELECT id FROM t WHERE d IS NOT DISTINCT FROM NULL
----
5

query I nosort
SELECT id FROM t WHERE d IS DISTINCT FROM 'infinity' ORDER BY id
----
1
2
4
5
6
7

# --- the date-vs-timestamp distinction: 24:00:00 does NOT advance a date ----------------------
statement ok
CREATE TABLE e (id int32 PRIMARY KEY, d date)

# Exactly 24:00:00 is accepted as a valid end-of-day time, but a date takes its day from the
# date fields directly — so this is 2024-03-01, NOT 2024-03-02 (a timestamp WOULD roll over).
statement ok
INSERT INTO e VALUES (1, '2024-03-01 24:00:00')

query T nosort
SELECT d FROM e WHERE id = 1
----
2024-03-01

# One second past it (24:00:01) is out of range → 22008.
statement error 22008
INSERT INTO e VALUES (2, '2024-03-01 24:00:01')

# --- type errors -------------------------------------------------------------
# an integer literal into a date column is a type error: 42804
statement error 42804
INSERT INTO t VALUES (8, 123)

# malformed date syntax traps 22007 (deterministically, before any scan for a predicate)
statement error 22007
INSERT INTO t VALUES (9, 'not a date')

# a clock-relative special (today/now/...) is deferred this slice: 22007
statement error 22007
INSERT INTO t VALUES (10, 'today')

# an out-of-range field traps 22008: month 13 ...
statement error 22008
INSERT INTO t VALUES (11, '2024-13-01')

# ... a non-existent calendar day (Feb 30) ...
statement error 22008
INSERT INTO t VALUES (12, '2024-02-30')

# ... and a leap second (:60 — jed has no leap seconds; the time IS validated even though dropped)
statement error 22008
INSERT INTO t VALUES (13, '2024-01-15 12:00:60')

# a malformed comparison literal traps the same way, pre-scan
statement error 22007
SELECT id FROM t WHERE d = 'garbage'

# a string literal with NO date context stays text and is never parsed as a date
statement ok
CREATE TABLE txt (id int32 PRIMARY KEY, s text)

statement ok
INSERT INTO txt VALUES (1, 'not a date')

query I nosort
SELECT id FROM txt WHERE s = 'not a date'
----
1

# --- date does not compare to timestamp (a strict island): 42804 -------------
statement ok
CREATE TABLE m (id int32 PRIMARY KEY, a date, b timestamp)

statement ok
INSERT INTO m VALUES (1, '2024-01-01', '2024-01-01 12:00:00')

statement error 42804
SELECT id FROM m WHERE a = b

# --- date PRIMARY KEY is supported (key encoding = int32) ---------------------
statement ok
CREATE TABLE k (d date PRIMARY KEY)

statement ok
INSERT INTO k VALUES ('2024-01-01'), ('-infinity'), ('infinity'), ('1999-06-15')

# iterating the key exercises the order-preserving date key bytes: -infinity first, infinity
# last, finite values chronological in between
query T nosort
SELECT d FROM k ORDER BY d
----
-infinity
1999-06-15
2024-01-01
infinity

# a duplicate date key violates primary-key uniqueness: 23505
statement error 23505
INSERT INTO k VALUES ('2024-01-01')

# --- deterministic, cross-core cost ------------------------------------------
statement ok
CREATE TABLE c (id int32 PRIMARY KEY, d date)

statement ok
INSERT INTO c VALUES (1, '2020-01-01'), (2, '2021-01-01'), (3, '2022-01-01'), (4, '2023-01-01'), (5, '2024-01-01'), (6, '2025-01-01')

# a date comparison is ONE operator_eval (weight 1), like an integer/timestamp comparison.
# 6 scanned + 6 filter (one `=` per row) + 1 produced + 0 projection (bare column) = 13, plus
# the page_read block.
# cost: 14
query I nosort
SELECT id FROM c WHERE d = '2023-01-01'
----
4
