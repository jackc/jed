# CROSS JOIN (spec/design/grammar.md §15): the Cartesian product of two tables, no ON. Output
# cardinality is |left| x |right|; an empty side yields the empty result. Cost (cost.md §3 JOIN):
# storage_row_read per materialized row (sum of cardinalities), NO ON operator_eval (every pair
# is kept), WHERE per surviving combined row, row_produced per emitted row.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.where_eq, query.order_by, query.order_by_keys, query.cross_join, query.qualified_column, types.int32, resource.cost_metering

statement ok
CREATE TABLE x (id int32 PRIMARY KEY, v int32)

statement ok
CREATE TABLE y (id int32 PRIMARY KEY, w int32)

statement ok
CREATE TABLE z (id int32 PRIMARY KEY)

statement ok
INSERT INTO x VALUES (1, 100), (2, 200), (3, 300)

statement ok
INSERT INTO y VALUES (1, 10), (2, 20)

# 3 x 2 = 6 pairs, every pair kept. 3 + 2 materialized (5 storage_row_read) + 6 produced = 11
# (the cost.md §3 worked example). No ON, so no operator_eval; projection is bare columns.
# names: id, id
# cost: 13
query II nosort
SELECT x.id, y.id FROM x CROSS JOIN y ORDER BY x.id, y.id
----
1
1
1
2
2
1
2
2
3
1
3
2

# An empty right table makes the product empty. 3 + 0 materialized + 0 produced = 3.
# names: id, id
# cost: 4
query II nosort
SELECT x.id, z.id FROM x CROSS JOIN z
----

# WHERE applies after the product. 6 combined rows, `x.v = 200` evaluated on each (6) keeps the
# two y-pairs of x row 2. 5 materialize + 0 ON + 6 WHERE + 2 produced = 13.
# names: v, w
# cost: 15
query II nosort
SELECT x.v, y.w FROM x CROSS JOIN y WHERE x.v = 200 ORDER BY y.w
----
200
10
200
20
