# WHERE-derived bound plus a residual reject.
# cost: 42
query II nosort
SELECT p.id, s.id
FROM room_probe p CROSS JOIN seat s
WHERE s.room = p.room AND s.id > 2
ORDER BY p.id, s.id
----
1
3
1
7
2
5

# cost: 18
query II nosort
SELECT p.id, s.id
FROM room_probe p JOIN seat s ON s.room = p.room
ORDER BY p.id
LIMIT 2
----
1
1
1
3

# Ordered B-tree precedence over GiST for the same sibling equality.
statement ok
CREATE INDEX seat_room_btree ON seat (room)

query ITTII nosort
EXPLAIN SELECT p.id, s.id FROM room_probe p JOIN seat s ON s.room = p.room
----
0
Nested Loop
inner; on:conjuncts=1
4
25
1
Scan room_probe
Full scan; touched=2
4
5
1
Scan seat
Index-nested-loop Index bound: using seat_room_btree; touched=2
4
12

# A primary-key sibling bound is cheaper still and wins over a GiST index on that same key.
statement ok
CREATE TABLE seat_pk (room i32 PRIMARY KEY, id i32)

statement ok
CREATE INDEX seat_pk_room_gist ON seat_pk USING gist (room)

statement ok
