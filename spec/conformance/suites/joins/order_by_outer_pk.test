# ORDER BY satisfied by the OUTER relation's primary-key scan order in a two-table join
# (spec/design/cost.md §3 "JOIN"). The physical join drives/probes the OUTER (first) relation in
# primary-key order, so a two-table INNER/CROSS join whose ORDER BY is a prefix of the outer
# relation's PK — and which has a LIMIT — needs no sort: the join output already arrives in
# `(outer PK, inner key)` order. The engine elides the sort and STOPS the probe loop once the
# LIMIT/OFFSET window is filled, so the ON/WHERE operator_evals and row_produced drop to the
# combinations actually examined. Both tables are still materialized in full; an eligible equality
# join also builds the complete right hash table before its left probes short-circuit.
#
# Every ORDER BY here is the outer `a.id` over a 1:1 join, so it is a TOTAL order (oracle-clean); the
# outer-PK tie-break beyond SQL (a strict prefix with inner-key ties) is left to the NoREC sweep. All
# units weigh 1, so for every record:
#   cost = materialization + hash build/probe/candidate verification (for equality joins) + ON/WHERE
#          evaluation + row production/projection over the rows reached before short-circuit.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.join_inner, query.cross_join, query.order_by, query.order_by_keys, query.qualified_column, query.table_alias, query.where_eq, query.comparison_order, query.limit, query.offset, query.order_by_join_scan, query.hash_join, types.i32, resource.cost_metering

statement ok
CREATE TABLE a (id i32 PRIMARY KEY, k i32)

statement ok
CREATE TABLE b (id i32 PRIMARY KEY, k i32)

# 1:1 on the join key `k`, so `ORDER BY a.id` is a TOTAL order over the joined rows.
statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50)

statement ok
INSERT INTO b VALUES (101, 10), (102, 20), (103, 30), (104, 40), (105, 50)

# ORDER BY the selected OUTER PK `a.id` with a LIMIT: the nested loop drives a in id order and stops
# once two matches are produced. Later a rows incur no ON/output work.
# cost: 21
query II nosort
SELECT a.id, b.id FROM a JOIN b ON a.k = b.k ORDER BY a.id LIMIT 2
----
1
101
2
102

# CONTRAST — `ORDER BY a.id, b.id` references the INNER PK too, so it is NOT satisfied by the outer
# scan order alone (the inner key is the tie-break, not part of `a`'s PK): the eager path completes
# every nested-loop pair, sorts, then windows. Same rows; higher cost proves short-circuit.
# cost: 39
query II nosort
SELECT a.id, b.id FROM a JOIN b ON a.k = b.k ORDER BY a.id, b.id LIMIT 2
----
1
101
2
102

# OFFSET composes: probe/match a.id=1 and skip it, then take matches for a.id=2 and 3 before stopping.
# cost: 27
query II nosort
SELECT a.id, b.id FROM a JOIN b ON a.k = b.k ORDER BY a.id LIMIT 2 OFFSET 1
----
2
102
3
103

# A WHERE on the INNER PK composes with both optimizations: `b.id >= 103` is a join-pushdown PK range
# bound (query.join_pushdown), so `b` materializes only rows 103,104,105 (3, not 5) — and the outer
# scan order still elides the sort and short-circuits. The inner contains only b=103..105; a=1,2
# miss, then a=3,4 match and fill the window. The residual WHERE runs on those pairs.
# cost: 25
query II nosort
SELECT a.id, b.id FROM a JOIN b ON a.k = b.k WHERE b.id >= 103 ORDER BY a.id LIMIT 2
----
3
103
4
104

# CROSS JOIN to a single-row inner: every a row pairs with the one b row, so `ORDER BY a.id` is a
# TOTAL order and the loop short-circuits with NO ON evals (a CROSS has no ON). LIMIT 2 → a.id 1,2.
# 2 page + 6 scanned (5 a + 1 b) + 0 ON + 2 produced = 10.
statement ok
CREATE TABLE one (id i32 PRIMARY KEY)

statement ok
INSERT INTO one VALUES (7)

# cost: 10
query II nosort
SELECT a.id, one.id FROM a CROSS JOIN one ORDER BY a.id LIMIT 2
----
1
7
2
7
