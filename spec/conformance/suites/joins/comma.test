# Comma-separated FROM (spec/design/grammar.md §15): `FROM a, b` is an implicit CROSS JOIN — the
# Cartesian product, byte-identical in result and cost to `a CROSS JOIN b`. The comma binds LOOSER
# than JOIN, so each comma-separated FROM item is its own join sub-chain AND its own ON-resolution
# segment: a later join's ON may reference only relations within its own comma item (so
# `FROM a, b JOIN c ON a.x = c.x` is a 42P01 on `a`, matching PostgreSQL). Composes with
# `FROM t, LATERAL (…)` (a lateral item still sees earlier comma items). Cost is the CROSS-JOIN
# contract of cost.md §3 (JOIN): storage_row_read per materialized row (sum of cardinalities), NO
# ON operator_eval for a comma cross, WHERE per surviving combined row, row_produced per emitted row.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.select_star, query.where_eq, query.order_by, query.order_by_keys, query.comma_from, query.cross_join, query.join_inner, query.index_nested_loop, query.qualified_column, query.derived_table, query.lateral, query.subquery_correlated, expr.arithmetic, types.i32, resource.cost_metering

statement ok
CREATE TABLE a (id i32 PRIMARY KEY, k i32)

statement ok
CREATE TABLE b (id i32 PRIMARY KEY, w i32)

statement ok
CREATE TABLE c (id i32 PRIMARY KEY, k i32)

statement ok
CREATE TABLE e (id i32 PRIMARY KEY)

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30)

statement ok
INSERT INTO b VALUES (1, 100), (2, 200)

statement ok
INSERT INTO c VALUES (1, 20), (2, 40)

# `FROM a, b` is the Cartesian product, identical to `a CROSS JOIN b`. 3 x 2 = 6 pairs, every pair
# kept (no ON). 3 + 2 materialized + 2 page + 6 produced.
# names: id, id
# cost: 13
query II nosort
SELECT a.id, b.id FROM a, b ORDER BY a.id, b.id
----
1
1
1
2
2
1
2
2
3
1
3
2

# An empty comma item makes the product empty. 3 + 0 materialized + 1 page (a) + 0 produced.
# names: id, id
# cost: 4
query II nosort
SELECT a.id, e.id FROM a, e
----

# WHERE applies after the product. 6 combined rows, `a.k = 20` evaluated on each (6) keeps the two
# b-pairs of a row 2. 3 + 2 materialize + 2 page + 6 WHERE + 2 produced.
# names: k, w
# cost: 15
query II nosort
SELECT a.k, b.w FROM a, b WHERE a.k = 20 ORDER BY b.w
----
20
100
20
200

# Three comma items chain left-deep: a x b x c = 3 x 2 x 2 = 12 rows.
# names: id, id, id
# cost: 22
query III nosort
SELECT a.id, b.id, c.id FROM a, b, c ORDER BY a.id, b.id, c.id
----
1
1
1
1
1
2
1
2
1
1
2
2
2
1
1
2
1
2
2
2
1
2
2
2
3
1
1
3
1
2
3
2
1
3
2
2

# The comma binds LOOSER than JOIN: `a, b JOIN c ON b.id = c.id` is `a x (b JOIN c)`. The join's ON
# references only its own comma item (b, c). b JOIN c on id → (b1,c1),(b2,c2); crossed with a's 3
# rows → 6. The ON `b.id = c.id` compares c's PK to the sibling b.id, so c is bound per outer row by
# index-nested-loop (query.index_nested_loop): a: 1 page + 3 rows; b: 1 page + 2 rows; c seeks once
# per (a,b) combined row — 6 point lookups, each `c.id = b.id` a HIT (b.id ∈ {1,2} = c's PKs), 1 page
# + 1 row each = 6 page + 6 rows; 6 ON evals over the 6 hits; 6 produced. 4 + 3 + 12 + 6 + 6 = 31.
# (The pre-INL full-inner-scan baseline was 28 — for a single-leaf inner the per-outer seeks cost a
# little more; the win shows when the inner is large, N·log M ≪ N·M.)
# names: id, id, id
# cost: 31
query III nosort
SELECT a.id, b.id, c.id FROM a, b JOIN c ON b.id = c.id ORDER BY a.id, b.id
----
1
1
1
1
2
2
2
1
1
2
2
2
3
1
1
3
2
2

# SELECT * expands across the comma items in FROM order, each in catalog order: a(id, k) then
# b(id, w). a row 1 crossed with both b rows.
# names: id, k, id, w
# cost: 9
query IIII nosort
SELECT * FROM a, b WHERE a.id = 1 ORDER BY b.id
----
1
10
1
100
1
10
2
200

# A bare column present in two comma items is ambiguous (42702) — the comma items share one scope.
statement error 42702
SELECT k FROM a, c

# A qualified column from either comma item resolves. a.id = 1 keeps a's one row crossed with c.
# names: k, k
# cost: 9
query II nosort
SELECT a.k, c.k FROM a, c WHERE a.id = 1 ORDER BY c.k
----
10
20
10
40

# Segment scoping: a join's ON may NOT reach across a comma to an earlier item — `a.k` is not in
# the `b JOIN c` segment, so this is a 42P01 (matching PostgreSQL's "invalid reference to
# FROM-clause entry for table a").
statement error 42P01
SELECT a.id FROM a, b JOIN c ON a.k = c.k

# Comma enables `FROM t, LATERAL (…)`: the lateral derived table still sees the earlier comma item
# (a). For each a row the body finds c where c.k = a.k * 2: a.k=10 -> c(20); a.k=20 -> c(40);
# a.k=30 -> none.
# names: id, k
# cost: 29
query II nosort
SELECT a.id, t.k FROM a, LATERAL (SELECT c.k FROM c WHERE c.k = a.k * 2) AS t(k) ORDER BY a.id
----
1
20
2
40
