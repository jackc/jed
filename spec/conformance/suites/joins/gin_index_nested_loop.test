# GIN sibling-bound index-nested-loop (gin.md §6.1; cost.md §3 "JOIN"). The inner array
# opclass query may be a bare column from an earlier sibling. It is evaluated once per outer row;
# posting candidates stay in storage-key order and the complete ON/WHERE remains residual.
# requires: ddl.create_table, ddl.primary_key, ddl.gin_index, dml.insert, dml.insert_multi_row, query.select, query.join_inner, query.join_left, query.cross_join, query.qualified_column, query.table_alias, query.where_eq, query.comparison_order, query.logical_connectives, query.order_by, query.limit, query.index_nested_loop, query.gin_scan, query.gin_any_eq, query.gin_array_eq, query.gin_index_nested_loop, query.order_by_join_scan, query.order_by_join_inl, types.i32, types.array, func.array_containment, func.array_quantified, null.three_valued, resource.cost_metering

statement ok
CREATE TABLE gin_probe (id i32 PRIMARY KEY, q i32[], term i32)

statement ok
CREATE TABLE gin_doc (id i32 PRIMARY KEY, tags i32[], alt i32[])

statement ok
CREATE INDEX gin_doc_tags ON gin_doc USING gin (tags)

statement ok
INSERT INTO gin_probe VALUES
  (1, ARRAY[10,20], 20),
  (2, ARRAY[40,40], 40),
  (3, '{}', NULL),
  (4, '{NULL}', 99),
  (5, NULL, 10)

statement ok
INSERT INTO gin_doc VALUES
  (10, ARRAY[10,20,30], ARRAY[20]),
  (11, ARRAY[20,40], ARRAY[40]),
  (12, ARRAY[40], '{}'),
  (13, '{}', ARRAY[10]),
  (14, '{NULL}', NULL),
  (15, NULL, ARRAY[10])

# @> uses posting-list intersection. Empty Q falls back per outer row; NULL-containing and whole
# NULL Q values are empty. Duplicate query terms remain a set.
# cost: 44
query II nosort
SELECT p.id, d.id
FROM gin_probe p JOIN gin_doc d ON d.tags @> p.q
ORDER BY p.id, d.id
----
1
10
2
11
2
12
3
10
3
11
3
12
3
13
3
14

# LEFT null-extension remains sound for misses, NULL, and provably-empty opclass queries.
# cost: 46
query II nosort
SELECT p.id, d.id
FROM gin_probe p LEFT JOIN gin_doc d ON d.tags @> p.q
ORDER BY p.id, d.id
----
1
10
2
11
2
12
3
10
3
11
3
12
3
13
3
14
4
NULL
5
NULL

# && uses posting-list union; the extra ON and WHERE conjuncts are residual-rechecked.
# cost: 38
query II nosort
SELECT p.id, d.id
FROM gin_probe p JOIN gin_doc d ON d.tags && p.q AND d.id > 10
WHERE p.id < 4
ORDER BY p.id, d.id
----
1
11
2
11
2
12

# Array equality gathers an @>-superset and rechecks exact equality.
# cost: 51
query II nosort
SELECT p.id, d.id
FROM gin_probe p JOIN gin_doc d ON d.tags = p.q
ORDER BY p.id, d.id
----
3
13
4
14

# Scalar membership admits a bare earlier-sibling scalar query operand.
# cost: 42
query II nosort
SELECT p.id, d.id
FROM gin_probe p JOIN gin_doc d ON p.term = ANY(d.tags)
ORDER BY p.id, d.id
----
1
10
1
11
2
11
2
12
5
10

# The sibling predicate may come from WHERE on a CROSS join.
# cost: 19
query II nosort
SELECT p.id, d.id
FROM gin_probe p CROSS JOIN gin_doc d
WHERE d.tags && p.q AND p.id = 1
ORDER BY p.id, d.id
----
1
10
1
11

# A usable sibling bound overrides the once-materialized constant GIN bound. Both predicates remain
# residual, so the result is their intersection.
# cost: 37
query II nosort
SELECT p.id, d.id
FROM gin_probe p JOIN gin_doc d ON d.tags && p.q
WHERE d.tags @> ARRAY[40]
ORDER BY p.id, d.id
----
1
11
2
11
2
12

# Phase 5's join top-N lane accepts storage-key-ordered GIN candidates and stops opening later
# outer-row bounds once the requested window is full.
# cost: 19
query II nosort
SELECT p.id, d.id
FROM gin_probe p JOIN gin_doc d ON d.tags && p.q
ORDER BY p.id
LIMIT 2
----
1
10
1
11
