# jed-specific hash-join plan shapes and structural fallbacks. PostgreSQL exposes different plan
# text, so this suite is cross-core checked and intentionally not oracle-imported.
# requires: ddl.create_table, ddl.primary_key, ddl.secondary_index, dml.insert, dml.insert_multi_row, query.select, query.join_inner, query.join_left, query.join_right, query.qualified_column, query.logical_connectives, query.explain, query.hash_join, query.index_nested_loop, types.i32, resource.cost_limit

statement ok
CREATE TABLE hx_l (id i32 PRIMARY KEY, k i32, v i32)

statement ok
CREATE TABLE hx_r (id i32 PRIMARY KEY, k i32, v i32)

statement ok
INSERT INTO hx_l VALUES (1, 1, 10), (2, 2, 20)

statement ok
INSERT INTO hx_r VALUES (10, 1, 30), (11, 2, 40)

query ITTII nosort
EXPLAIN SELECT l.id, r.id FROM hx_l l JOIN hx_r r ON l.k = r.k
----
0
Hash Join
inner; keys=1; on:conjuncts=1
1
32
1
Scan hx_l
Full scan; touched=2
2
3
1
Scan hx_r
Full scan; touched=2
2
3

# Hash build/probe work is cost-bounded. This ceiling is intentionally below the full query.
# max_cost: 10
statement error 54P01
SELECT l.id, r.id FROM hx_l l JOIN hx_r r ON l.k = r.k

query ITTII nosort
EXPLAIN SELECT l.id, r.id FROM hx_l l LEFT JOIN hx_r r ON l.k = r.k AND l.v = r.v
