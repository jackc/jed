# FULL [OUTER] JOIN ... ON (spec/design/grammar.md §15): keeps EVERY row from both sides — matched
# pairs, then unmatched-left rows (right side NULL), then unmatched-right rows (left side NULL). The
# OUTER keyword is optional. The ON stays three-valued (a NULL join key on either side never
# matches → that row is preserved, the absent side NULL). A right row matched by ANY left row is
# never re-emitted as unmatched. The emit order is deterministic: per left row its matches in right
# key order then its NULL-extended row, and all unmatched right rows last in right key order. Cost
# is the cost.md §3 contract: ON over the same |running|×|right| candidate set, only the produced
# count grows. The chained query exercises a FULL join whose left side is an accumulated INNER join
# (the left NULL-pad spans all prior columns, width taken from the scope).
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.select_star, query.where_eq, query.is_null, query.logical_connectives, query.order_by, query.order_by_keys, query.join_inner, query.join_full, query.qualified_column, null.three_valued, types.int32, types.text, resource.cost_metering

statement ok
CREATE TABLE a (id int32 PRIMARY KEY, k int32)

statement ok
CREATE TABLE b (id int32 PRIMARY KEY, k int32, label text)

statement ok
CREATE TABLE c (id int32 PRIMARY KEY, bid int32, tag text)

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30), (4, NULL)

statement ok
INSERT INTO b VALUES (10, 10, 'ten'), (20, 20, 'twenty'), (21, 20, 'twentyish'), (30, NULL, 'nullk')

statement ok
INSERT INTO c VALUES (100, 20, 'cee'), (200, 99, 'orphan')

# Equi-join on k, FULL. Matched: a(1)↔b(10), a(2)↔b(20), a(2)↔b(21). Unmatched left: a(3) k=30,
# a(4) k=NULL → (id, NULL). Unmatched right: b(30) k=NULL → (NULL, id). 4+4 materialize (8) + 16 ON
# + 6 produced (3 matched + 2 left-extended + 1 right-extended) = 30.
# names: id, id
# cost: 32
query II nosort
SELECT a.id, b.id FROM a FULL JOIN b ON a.k = b.k ORDER BY a.id, b.id
----
1
10
2
20
2
21
3
NULL
4
NULL
NULL
30

# SELECT * — unmatched-left rows carry NULL across b's three columns; the unmatched-right b(30)
# carries NULL across a's two columns. 8 materialize + 16 ON + 6 produced = 30.
# names: id, k, id, k, label
# cost: 32
query IIIIT nosort
SELECT * FROM a FULL JOIN b ON a.k = b.k ORDER BY a.id, b.id
----
1
10
10
10
ten
2
20
20
20
twenty
2
20
21
20
twentyish
3
30
NULL
NULL
NULL
4
NULL
NULL
NULL
NULL
NULL
NULL
30
NULL
nullk

# The symmetric anti-join: `a.id IS NULL OR b.id IS NULL` keeps exactly the rows present on only
# one side — a(3), a(4) (no b) and b(30) (no a). 6 combined rows; the WHERE has 3 interior nodes
# (or + two is_null) → 18; 8 materialize + 16 ON + 18 WHERE + 3 produced = 45.
# names: id, id
# cost: 47
query II nosort
SELECT a.id, b.id FROM a FULL JOIN b ON a.k = b.k WHERE a.id IS NULL OR b.id IS NULL ORDER BY a.id, b.id
----
3
NULL
4
NULL
NULL
30

# Chained: (a INNER JOIN b) FULL JOIN c. The INNER step yields 3 rows (width 5). FULL JOIN c ON
# b.id=c.bid: b.id=20 matches c(100); the b.id=10 and b.id=21 running rows match no c (right NULL);
# c(200) bid=99 matches no running row (left NULL across all 5 prior columns — pad width from the
# scope). Cost: 4+4+2 materialize (10) + 16 ON (step1, 4x4) + 6 ON (step2, 3x2) + 4 produced = 36.
# names: id, id, id, tag
# cost: 39
query IIIT nosort
SELECT a.id, b.id, c.id, c.tag FROM a JOIN b ON a.k = b.k FULL JOIN c ON b.id = c.bid ORDER BY a.id, b.id, c.id
----
1
10
NULL
NULL
2
20
100
cee
2
21
NULL
NULL
NULL
NULL
200
orphan
