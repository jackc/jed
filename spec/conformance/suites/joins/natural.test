# NATURAL JOIN (spec/design/grammar.md §15): a join whose USING column list is DERIVED as the column
# names common to both sides, in left order, then merged exactly like USING. `a NATURAL JOIN b` joins
# on every shared column name and the output carries each once (merged first, then a's other columns,
# then b's). Composes with the join kinds (NATURAL [INNER|LEFT|RIGHT] JOIN); with NO common column it
# degenerates to a CROSS join (the Cartesian product). NATURAL is non-reserved (positional). It
# reuses the USING merge machinery, so NATURAL FULL JOIN with a common column is the same 0A000 as
# FULL JOIN USING (a documented divergence from PostgreSQL in oracle_overrides.toml).
# requires: ddl.create_table, dml.insert, dml.insert_multi_row, query.select, query.select_star, query.order_by, query.order_by_keys, query.join_natural, query.join_inner, query.join_left, query.join_right, query.cross_join, query.qualified_column, query.hash_join, types.i32, resource.cost_metering

statement ok
CREATE TABLE a (k i32, x i32)

statement ok
CREATE TABLE b (k i32, y i32)

statement ok
CREATE TABLE c (k i32, z i32)

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30)

statement ok
INSERT INTO b VALUES (2, 200), (3, 300), (4, 400)

statement ok
INSERT INTO c VALUES (3, 3000), (5, 5000)

# NATURAL JOIN derives USING(k) (the common column). `*` → merged k, then a's x, then b's y.
# names: k, x, y
# cost: 19
query III nosort
SELECT * FROM a NATURAL JOIN b ORDER BY k
----
2
20
200
3
30
300

# A bare `k` is the merged column; explicit columns work too.
# names: k, x, y
# cost: 19
query III nosort
SELECT k, x, y FROM a NATURAL JOIN b ORDER BY k
----
2
20
200
3
30
300

# NATURAL LEFT JOIN: every left row kept; unmatched-left k=1 keeps the left value.
# names: k, x, y
# cost: 53
query III nosort
SELECT k, x, y FROM a NATURAL LEFT JOIN b ORDER BY k
----
1
10
NULL
2
20
200
3
30
300

# NATURAL RIGHT JOIN: every right row kept; unmatched-right k=4 keeps the right value.
# names: k, x, y
# cost: 20
query III nosort
SELECT k, x, y FROM a NATURAL RIGHT JOIN b ORDER BY k
----
2
20
200
3
30
300
4
NULL
400

# A NATURAL chain re-merges k across all three: only k present in all (k=3).
# names: k, x, y, z
# cost: 21
query IIII nosort
SELECT * FROM a NATURAL JOIN b NATURAL JOIN c ORDER BY k
----
3
30
300
3000

# Multiple common columns are all merged (k, m).
statement ok
CREATE TABLE m1 (k i32, m i32, x i32)

statement ok
CREATE TABLE m2 (k i32, m i32, y i32)

statement ok
INSERT INTO m1 VALUES (1, 1, 10), (1, 2, 20)

statement ok
INSERT INTO m2 VALUES (1, 2, 200), (1, 3, 300)

# names: k, m, x, y
# cost: 19
query IIII nosort
SELECT * FROM m1 NATURAL JOIN m2 ORDER BY k, m
----
1
2
20
200

# With NO common column a NATURAL join is a CROSS join (the Cartesian product).
statement ok
CREATE TABLE d (p i32)

statement ok
CREATE TABLE e (q i32)

statement ok
INSERT INTO d VALUES (1), (2)

statement ok
INSERT INTO e VALUES (10), (20)

# names: p, q
# cost: 10
query II nosort
SELECT * FROM d NATURAL JOIN e ORDER BY p, q
----
1
10
1
20
2
10
2
20

# NATURAL CROSS JOIN is a syntax error (NATURAL implies a derived condition) — 42601.
statement error 42601
SELECT * FROM a NATURAL CROSS JOIN b

# A NATURAL join takes no ON — a trailing ON is 42601 (matching PostgreSQL).
statement error 42601
SELECT * FROM a NATURAL JOIN b ON a.k = b.k

# NATURAL FULL JOIN with a common column reuses the USING merge → the same deferred 0A000 as FULL
# JOIN USING (PostgreSQL supports it via a COALESCE merge).
statement error 0A000
SELECT * FROM a NATURAL FULL JOIN b
