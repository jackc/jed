# Subqueries returning / comparing NON-INTEGER values — scalar (SELECT ...), x IN (SELECT ...),
# and correlated EXISTS over text, decimal, and timestamp (grammar.md §26). The dedicated
# subquery/*.test exercise only integer subqueries; this file pins that a scalar subquery folds to
# a constant carrying its OUTPUT type and then promotes/compares like that type, that IN membership
# inherits the element type's value-canonical equality, and that the typed values flow through
# correlation. The §8 hotspots covered: decimal cross-scale equality through a subquery (1.50 =
# 1.5), the timestamp instant order via MAX in a scalar subquery, and a 0-row scalar subquery
# folding to a TYPED NULL (so the comparison is UNKNOWN, never an error). Rows are `rowsort`.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.where_eq, query.comparison_order, query.aggregates, query.subquery_scalar, query.subquery_in, query.subquery_exists, query.subquery_correlated, types.int32, types.text, types.decimal, types.timestamp

statement ok
CREATE TABLE products (id int32 PRIMARY KEY, name text, price numeric, made timestamp)

statement ok
INSERT INTO products VALUES
  (1, 'apple', 1.50, '2024-01-01 00:00:00'),
  (2, 'banana', 2.00, '2024-06-01 00:00:00'),
  (3, 'apple', 1.50, '2024-03-01 00:00:00'),
  (4, 'cherry', 3.25, '2024-12-01 00:00:00')

# --- scalar subquery returning TEXT: folds to a text constant, compared to a text column -------
# (SELECT name … id=2) = 'banana' → the one banana row.
# names: id
query I rowsort
SELECT id FROM products WHERE name = (SELECT name FROM products WHERE id = 2)
----
2

# --- scalar subquery returning DECIMAL: cross-scale equality through the fold (1.50 vs 1.5) ----
# (SELECT price … id=1) = 1.50; rows whose price equals it value-canonically → both apples.
# names: id
query I rowsort
SELECT id FROM products WHERE price = (SELECT price FROM products WHERE id = 1)
----
1
3

# --- scalar subquery returning DECIMAL, ordering comparison ----------------------------------
# price > (SELECT price … id=2 = 2.00) → only cherry (3.25).
# names: id
query I rowsort
SELECT id FROM products WHERE price > (SELECT price FROM products WHERE id = 2)
----
4

# --- scalar subquery returning TIMESTAMP via MAX: the latest row -----------------------------
# made = (SELECT MAX(made) …) = 2024-12-01 → cherry.
# names: id
query I rowsort
SELECT id FROM products WHERE made = (SELECT MAX(made) FROM products)
----
4

# --- IN (SELECT text …): membership over a text subquery column ------------------------------
# name IN (names priced under 2.00) = {'apple'} → both apples.
# names: id
query I rowsort
SELECT id FROM products WHERE name IN (SELECT name FROM products WHERE price < 2.00)
----
1
3

# --- IN (SELECT timestamp …): membership over a timestamp subquery column --------------------
# made IN (made of rows priced >= 2.00) = {2024-06-01, 2024-12-01} → banana, cherry.
# names: id
query I rowsort
SELECT id FROM products WHERE made IN (SELECT made FROM products WHERE price >= 2.00)
----
2
4

# --- correlated EXISTS keyed on TEXT: the outer name flows into the inner predicate ----------
statement ok
CREATE TABLE sales (sid int32 PRIMARY KEY, pname text)

statement ok
INSERT INTO sales VALUES (1, 'apple'), (2, 'cherry'), (3, 'durian')

# products having at least one sale of the same name → apple (×2) and cherry.
# names: id
query I rowsort
SELECT id FROM products p WHERE EXISTS (SELECT 1 FROM sales s WHERE s.pname = p.name)
----
1
3
4

# --- 0-row scalar subquery folds to a TYPED NULL: the comparison is UNKNOWN, not an error -----
# (SELECT name … id=999) returns no row → typed NULL → name = NULL is UNKNOWN → zero rows.
# names: id
query I rowsort
SELECT id FROM products WHERE name = (SELECT name FROM products WHERE id = 999)
----
