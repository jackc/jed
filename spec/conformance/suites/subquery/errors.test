# Subquery error cases + the deliberate narrowings (spec/design/grammar.md §26). A scalar
# subquery returning >1 ROW is 21000 (cardinality_violation); a scalar or IN subquery returning
# >1 COLUMN is 42601. Correlation IS supported now (see correlated.test), as are subqueries in a
# DELETE/UPDATE (see mutation.test) and a bind parameter `$N` inside a subquery (typed by an inner
# context). A `$N` with NO type context anywhere stays uninferable -> 42P18 (a documented divergence
# from PostgreSQL, which defaults such a `$N` to text). Verified against PostgreSQL 18.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.where_eq, query.subquery_scalar, query.subquery_in, query.subquery_exists, types.i32

statement ok
CREATE TABLE a (id i32 PRIMARY KEY, k i32)

statement ok
CREATE TABLE b (id i32 PRIMARY KEY, k i32)

statement ok
CREATE TABLE one (id i32 PRIMARY KEY)

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30)

statement ok
INSERT INTO b VALUES (1, 20), (2, 30), (3, 40)

statement ok
INSERT INTO one VALUES (1)

# Scalar subquery returning more than one row -> 21000 (cardinality_violation).
statement error 21000
SELECT (SELECT k FROM b) FROM one

# Scalar subquery returning more than one column -> 42601 ("subquery must return only one column").
statement error 42601
SELECT (SELECT id, k FROM b WHERE id = 1) FROM one

# IN subquery returning more than one column -> 42601 ("subquery has too many columns").
statement error 42601
SELECT id FROM a WHERE k IN (SELECT id, k FROM b)

# The >1-column check is caught at PLAN time, so it fires even when the outer (and the subquery's
# own filter) select no rows -- there is no row for it to "succeed" on.
statement error 42601
SELECT (SELECT id, k FROM b WHERE id = 99) FROM one

# A bind parameter `$N` inside a subquery is allowed, but one whose ONLY position is a context-free
# select-list slot can't be typed from anywhere -> 42P18 (PG defaults it to text; jed reports the
# indeterminate type — a documented divergence, §26). Caught at plan/finalize, so no value is needed.
statement error 42P18
SELECT id FROM a WHERE k = (SELECT $1 FROM b LIMIT 1)

# A `$N` typed by an INNER context (b.k = $1) IS inferred — proven here by the count check: $1 is
# expected but this no-parameter harness supplies none, so it is 42601 (not the old 0A000 rejection).
statement error 42601
SELECT id FROM a WHERE EXISTS (SELECT 1 FROM b WHERE b.k = $1)
