# Subqueries in a DELETE / UPDATE (spec/design/grammar.md §26). A subquery is legal in a DELETE
# or UPDATE WHERE, and in an UPDATE assignment RHS; it may be uncorrelated (folded once) or
# correlated to the TARGET row (re-run per scanned row, reading the OLD row). The mutation stays
# two-phase / all-or-nothing: the subquery reads the pre-statement snapshot (DELETE collects keys
# before removing; UPDATE validates all rows before writing). Costs (cost.md §3): an uncorrelated
# subquery folds once, a correlated one re-runs per scanned row. Results verified against PostgreSQL 18.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, dml.delete, dml.update, query.select, query.where_eq, query.comparison_order, query.order_by, query.aggregates, query.qualified_column, expr.arithmetic, query.subquery_scalar, query.subquery_in, query.subquery_exists, query.subquery_correlated, types.int32, resource.cost_metering

statement ok
CREATE TABLE a (id int32 PRIMARY KEY, k int32)

statement ok
CREATE TABLE b (id int32 PRIMARY KEY, k int32)

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30)

statement ok
INSERT INTO b VALUES (1, 20), (2, 30), (3, 40)

# --- DELETE with an uncorrelated IN subquery (folded once) -----------------------------------
# Delete a's rows whose k is one of b's k values {20,30,40}: ids 2 (k=20) and 3 (k=30) go; id 1
# (k=10) stays. Cost (cost.md §3): the uncorrelated `SELECT k FROM b` is folded ONCE — scan b (3)
# + 3 row_produced = 6. Then scan a (3); per a row the folded `k IN (20,30,40)` charges 1
# operator_eval for the node + 1 per element compared (3, no short-circuit — deterministic) = 4,
# over 3 rows = 12. DELETE emits no rows. 6 + 3 + 12 = 21.
# cost: 21
statement ok
DELETE FROM a WHERE k IN (SELECT k FROM b)

query II nosort
SELECT id, k FROM a ORDER BY id
----
1
10

# Reset a to the initial three rows for the next scenario.
statement ok
DELETE FROM a

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30)

# --- DELETE with a correlated EXISTS subquery (re-run per row) --------------------------------
# Keep/drop each a row by whether some b row has the SAME k: a.k ∈ {10,20,30}, b.k ∈ {20,30,40},
# so 20 and 30 match -> ids 2,3 deleted, id 1 survives. Cost: scan a (3). Per a row the EXISTS
# node (1 operator_eval) runs `SELECT 1 FROM b WHERE b.k = a.k`: scan b (3) + `b.k = a.k` per b
# row (3 operator_eval) + 1 row_produced per inner match. a.k=10 -> 0 match: 1+3+3+0=7;
# a.k=20 -> 1: 1+3+3+1=8; a.k=30 -> 1: 1+3+3+1=8. DELETE emits no rows. 3 + 7 + 8 + 8 = 26.
# cost: 26
statement ok
DELETE FROM a WHERE EXISTS (SELECT 1 FROM b WHERE b.k = a.k)

query II nosort
SELECT id, k FROM a ORDER BY id
----
1
10

statement ok
DELETE FROM a

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30)

# --- DELETE with a correlated NOT EXISTS (the complement) ------------------------------------
statement ok
DELETE FROM a WHERE NOT EXISTS (SELECT 1 FROM b WHERE b.k = a.k)

query II nosort
SELECT id, k FROM a ORDER BY id
----
2
20
3
30

statement ok
DELETE FROM a

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30)

# --- UPDATE SET to a correlated scalar subquery ----------------------------------------------
# Each a.k becomes max(b.k) over the b rows with b.k > the OLD a.k: 10 -> max(20,30,40)=40,
# 20 -> max(30,40)=40, 30 -> max(40)=40. (The subquery reads the OLD row — the two-phase pass
# validates all before writing.)
statement ok
UPDATE a SET k = (SELECT max(b.k) FROM b WHERE b.k > a.k)

query II nosort
SELECT id, k FROM a ORDER BY id
----
1
40
2
40
3
40

statement ok
DELETE FROM a

# A row whose k exceeds every b.k makes its correlated scalar empty -> the typed NULL.
statement ok
INSERT INTO a VALUES (1, 5), (2, 100)

statement ok
UPDATE a SET k = (SELECT max(b.k) FROM b WHERE b.k > a.k)

query II nosort
SELECT id, k FROM a ORDER BY id
----
1
40
2
NULL

statement ok
DELETE FROM a

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30)

# --- UPDATE with a correlated WHERE and an uncorrelated SET ------------------------------------
# WHERE: keep a row iff a.k + 10 is one of b's k {20,30,40} -> 10+10,20+10,30+10 all match, so all
# three rows update. SET: the uncorrelated `min(b.k)` = 20, folded once. So every a.k becomes 20.
statement ok
UPDATE a SET k = (SELECT min(k) FROM b) WHERE EXISTS (SELECT 1 FROM b WHERE b.k = a.k + 10)

query II nosort
SELECT id, k FROM a ORDER BY id
----
1
20
2
20
3
20
