# Uncorrelated SCALAR subqueries (spec/design/grammar.md §26): a `( SELECT … )` used as a value.
# It is executed ONCE at plan setup and folded to a constant carrying its output type — so its
# value participates in promotion/comparison like a column of that type, a 0-row result is a typed
# NULL, and the per-row evaluator is untouched. A >1-row result is 21000 and a >1-column result is
# 42601 (see errors.test). Cost = the enclosing query's cost PLUS the subquery's cost counted once;
# the folded constant is a leaf (no operator_eval). Verified against the live PostgreSQL 18 oracle.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.where_eq, query.comparison_order, query.order_by, query.aggregates, expr.arithmetic, query.subquery_scalar, types.i32, resource.cost_metering

statement ok
CREATE TABLE a (id i32 PRIMARY KEY, k i32)

statement ok
CREATE TABLE b (id i32 PRIMARY KEY, k i32)

statement ok
CREATE TABLE one (id i32 PRIMARY KEY)

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30)

statement ok
INSERT INTO b VALUES (1, 20), (2, 30), (3, 40)

statement ok
INSERT INTO one VALUES (1)

# Scalar in WHERE: only the a-row whose k equals max(a.k)=30. The subquery runs once: scan b/a (3
# storage_row_read) + 3 aggregate_accumulate + 1 row_produced = 7. The outer scans a (3) + filters
# `k = <const>` per row (3 operator_eval) + produces 1 row (1) = 7. cost = 7 + 7 = 14.
# cost: 16
query I nosort
SELECT id FROM a WHERE k = (SELECT max(k) FROM a) ORDER BY id
----
3

# Scalar in the select list — the same constant appended to every row (count(*) of b = 3). The
# folded constant is a leaf, so each produced row charges only row_produced.
# names: ?column?
query I nosort
SELECT (SELECT count(*) FROM b) FROM a ORDER BY id
----
3
3
3

# A 0-row scalar subquery is NULL (projected). Anchored on the single-row table `one`.
query I nosort
SELECT (SELECT k FROM b WHERE id = 99) FROM one
----
NULL

# A 0-row scalar in WHERE: `k = NULL` is never TRUE, so no rows survive.
query I nosort
SELECT id FROM a WHERE k = (SELECT k FROM b WHERE id = 99) ORDER BY id
----

# Scalar folded into a larger per-row expression: k + max(b.k)=k+40.
query I nosort
SELECT k + (SELECT max(k) FROM b) FROM a ORDER BY id
----
50
60
70

# Nested scalar subqueries fold inner-first (every SELECT needs a FROM in jed). Inner max(b.k)=40,
# carried out through two levels.
query I nosort
SELECT (SELECT (SELECT max(k) FROM b) FROM one) FROM one
----
40

# A scalar subquery compared with a column promotes by type (i32 column vs the subquery's value).
query I nosort
SELECT id FROM a WHERE k = (SELECT min(k) FROM b) ORDER BY id
----
2
