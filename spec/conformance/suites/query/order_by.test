# Richer ORDER BY (spec/design/grammar.md §10): multiple sort keys, per-key ASC/DESC, and
# per-key NULLS FIRST|LAST. Keys are bare table columns, applied left to right (first key
# primary, later keys break ties, a full tie is broken by the primary key (a STABLE
# sort over the PK scan today). NULL placement is a CROSS-CORE determinism contract (CLAUDE.md §8): the physical key
# order ratifies NULL as the LARGEST value (types.md §4), so a key with no NULLS clause
# defaults to ASC => NULLS LAST, DESC => NULLS FIRST — the PostgreSQL model. An explicit NULLS
# FIRST|LAST overrides that default regardless of direction. The sort is unmetered (cost.md
# §3): cost = storage_row_read per scanned row + row_produced per produced row (+ filter
# operator_eval); multi-key/NULLS placement adds nothing.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.order_by, query.order_by_keys, query.order_by_ordinal, query.order_by_expr, query.order_by_alias, query.select_star, query.column_alias, query.comparison_order, query.limit, expr.arithmetic, func.abs, types.i32, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, a i32, b i32)

# Deliberate ties in `a` (rows 1,2,4 all have a=10) and NULLs in both `a` (row 5) and `b`
# (row 2) to exercise secondary keys, stable tie-breaking, and NULL placement.
statement ok
INSERT INTO t VALUES (1, 10, 5)

statement ok
INSERT INTO t VALUES (2, 10, NULL)

statement ok
INSERT INTO t VALUES (3, 20, 7)

statement ok
INSERT INTO t VALUES (4, 10, 5)

statement ok
INSERT INTO t VALUES (5, NULL, 9)

# ASC with no NULLS clause defaults to NULLS LAST (NULL is the largest value): the a=10 group
# in stable scan order, then a=20, then row 5 (a NULL) last. 5 scanned + 5 produced = 10.
# names: a
# cost: 11
query I nosort
SELECT a FROM t ORDER BY a
----
10
10
10
20
NULL

# DESC with no NULLS clause defaults to NULLS FIRST (descending inverts the physical order):
# NULL leads, then a=20, then the a=10 group. Matches PostgreSQL (NULL largest). 5 + 5 = 10.
# names: a
# cost: 11
query I nosort
SELECT a FROM t ORDER BY a DESC
----
NULL
20
10
10
10

# Explicit NULLS LAST overrides the DESC default (now NULLS FIRST): the non-NULL values stay
# descending and NULL goes last — the case that fails if NULL placement is not decoupled from
# the direction reversal (grammar.md §10). 5 + 5 = 10.
# names: a
# cost: 11
query I nosort
SELECT a FROM t ORDER BY a DESC NULLS LAST
----
20
10
10
10
NULL

# Explicit NULLS FIRST overrides the ASC default (now NULLS LAST): the non-NULL values stay
# ascending and NULL leads. 5 + 5 = 10.
# names: a
# cost: 11
query I nosort
SELECT a FROM t ORDER BY a ASC NULLS FIRST
----
NULL
10
10
10
20

# Two keys, mixed direction: primary `a` ASC (NULLs last by default), ties broken by `id`
# DESC. Within a=10 the ids descend (4,2,1), then a=20, then row 5 (a NULL) last. 5 + 5 = 10.
# names: id, a
# cost: 11
query II nosort
SELECT id, a FROM t ORDER BY a ASC, id DESC
----
4
10
2
10
1
10
3
20
5
NULL

# Two keys: `a` ASC (NULLs last by default), then `b` ASC NULLS LAST. Within a=10 the b
# values are 5 (id1), NULL (id2), 5 (id4); NULLS LAST puts id2 after the two b=5 rows, which
# keep stable scan order (id1 before id4). Then a=20, then the a NULL row (id5) last. 5 + 5 = 10.
# names: id, a, b
# cost: 11
query III nosort
SELECT id, a, b FROM t ORDER BY a ASC, b ASC NULLS LAST
----
1
10
5
4
10
5
2
10
NULL
3
20
7
5
NULL
9

# A full tie across every key is broken by the primary key (a stable sort over the PK scan):
# ordering by `b` alone leaves the two b=5 rows in id order. WHERE keeps rows 1 and
# 4 (b=5). 5 scanned + 5 filter + 2 produced = 12.
# names: id
# cost: 13
query I nosort
SELECT id FROM t WHERE b = 5 ORDER BY b
----
1
4

# Multi-key sort under WHERE + LIMIT: the filter runs on every scanned row, the sort orders the
# survivors, and LIMIT windows AFTER the sort (excluded rows still pay scan + filter but no
# produce). WHERE a >= 10 drops row 5 (NULL >= 10 is unknown). Survivors ordered by a DESC then
# id ASC are 3,1,2,4; LIMIT 2 keeps 3,1. 5 scanned + 5 filter + 2 produced = 12.
# names: id
# cost: 13
query I nosort
SELECT id FROM t WHERE a >= 10 ORDER BY a DESC, id ASC LIMIT 2
----
3
1

# An output-column ordinal (ORDER BY 1) names the 1-based position of a select-list item
# (grammar.md §10). Position 1 here is `a`, so this is identical to `ORDER BY a` — the a=10 group
# in stable scan order, then a=20, then the a NULL last (ASC defaults NULLS LAST). 5 + 5.
# names: a
# cost: 11
query I nosort
SELECT a FROM t ORDER BY 1
----
10
10
10
20
NULL

# Ordinals compose with per-key direction and tie-breaking: position 2 (`a`) DESC (NULLS FIRST)
# then position 1 (`id`) ASC. NULL `a` (id5) leads, then a=20 (id3), then the a=10 group in id
# order (1,2,4). Mixing an ordinal with another ordinal across keys. 5 + 5.
# names: id, a
# cost: 11
query II nosort
SELECT id, a FROM t ORDER BY 2 DESC, 1 ASC
----
5
NULL
3
20
1
10
2
10
4
10

# With SELECT * the ordinal indexes the expanded scope columns left to right: position 3 is `b`.
# b ASC NULLS LAST: the two b=5 rows (id1 before id4, the PK tie-break), then b=7, b=9, then the
# b NULL row (id2) last. Proves ordinal resolution over the star projection. 5 + 5.
# names: id, a, b
query III nosort
SELECT * FROM t ORDER BY 3
----
1
10
5
4
10
5
3
20
7
5
NULL
9
2
10
NULL

# An ordinal resolves to the item's underlying column, NOT its output alias: position 1 is the
# real column `a` even though it is labeled `x`. a ASC (NULLS LAST), the a=10 group broken by the
# PK (id1, id2, id4), then a=20, then the a NULL last. 5 + 5.
# names: x, b
query II nosort
SELECT a AS x, b FROM t ORDER BY 1
----
10
5
10
NULL
10
5
20
7
NULL
9

# NULLS must be followed by FIRST or LAST — a bare trailing NULLS is a syntax error.
statement error 42601
SELECT a FROM t ORDER BY a NULLS

# ... and an unknown NULLS placement keyword likewise.
statement error 42601
SELECT a FROM t ORDER BY a NULLS MIDDLE

# A trailing comma with no following sort key is a syntax error.
statement error 42601
SELECT a FROM t ORDER BY a,

# An ordinal greater than the number of output columns is 42P10 (invalid_column_reference) — the
# select list has one column, so position 2 is "not in select list" (matches PostgreSQL).
statement error 42P10
SELECT a FROM t ORDER BY 2

# Position 0 is out of range the same way (ordinals are 1-based).
statement error 42P10
SELECT a FROM t ORDER BY 0

# A negative ordinal is folded into the position and is likewise 42P10 (not a syntax error) —
# PostgreSQL reports "ORDER BY position -1 is not in select list".
statement error 42P10
SELECT a FROM t ORDER BY -1

# --- General-expression sort keys (grammar.md §10, query.order_by_expr) ---------------------------
# A general expression is evaluated per row and sorted by the computed value. ORDER BY a + 1: the
# a+1 values are 11,11,21,11,NULL, so ASC NULLS LAST gives the a=10 group (output 10 for each, the
# tie is invisible in the output), then a=20, then the a NULL row last. The expression is
# materialized — evaluated once per scanned row — so it charges operator_eval per node: 1 page_read
# + 5 storage_row_read + 5 operator_eval (the `+`) + 5 row_produced = 16.
# names: a
# cost: 16
query I nosort
SELECT a FROM t ORDER BY a + 1
----
10
10
10
20
NULL

# A two-key sort whose primary key is an expression and secondary is a column: ORDER BY a % 100, id.
# a % 100 is 10,10,20,10,NULL → ASC NULLS LAST, broken by id: (a=10: id1,id2,id4), a=20 (id3), then
# a NULL (id5). The output `id` makes the order fully observable.
# names: id
query I nosort
SELECT id FROM t ORDER BY a % 100, id
----
1
2
4
3
5

# `ORDER BY 1 + 1` is a CONSTANT expression (not an ordinal — only a bare integer literal is): a no-op
# sort, matching PostgreSQL. The order is therefore unspecified, so the multiset is asserted with
# rowsort (the constant key fixes nothing).
# names: a
query I rowsort
SELECT a FROM t ORDER BY 1 + 1
----
10
10
10
20
NULL

# An ordinal that points at a COMPUTED select-list item now sorts by that item's value (the old 0A000
# is lifted — grammar.md §10): ORDER BY 1 over `SELECT a + 1` sorts by a+1 = 11,11,11,21,NULL.
# names: ?column?
query I nosort
SELECT a + 1 FROM t ORDER BY 1
----
11
11
11
21
NULL

# An expression key over the FROM columns need not appear in the select list (it is materialized from
# the scanned row): ORDER BY abs(b - 6) ranks rows by distance of b from 6 — b = 5,NULL,7,5,9 gives
# 1,NULL,1,1,3, so the |·|=1 rows (id1,id3,id4) then |·|=3 (id5) then NULL (id2), broken by id.
# names: id
query I nosort
SELECT id FROM t ORDER BY abs(b - 6), id
----
1
3
4
5
2

# A boolean expression key (false < true, NULLs last): ORDER BY (a > 15) puts the a<=15 rows first.
# a = 10,10,20,10,NULL → (a>15) = false,false,true,false,NULL, so the four non-true rows (a=10 ×3
# then... no: id1,id2,id4 are a=10=false, id3 a=20=true, id5 a NULL=unknown→last). Broken by id.
# names: id
query I nosort
SELECT id FROM t ORDER BY (a > 15), id
----
1
2
4
3
5

# An ORDER BY key that names no column is an undefined-column error, reusing the existing path.
statement error 42703
SELECT a FROM t ORDER BY nope

# A general expression referencing an unknown column is likewise 42703 (resolved like any expression).
statement error 42703
SELECT a FROM t ORDER BY nope + 1

# --- Output-alias sort keys (grammar.md §10, query.order_by_alias) --------------------------------
# A bare ORDER BY name resolves an OUTPUT column (an AS alias or item's derived name) BEFORE an input
# column — PostgreSQL's SQL92 rule. `ORDER BY x` binds the alias `x` for column `a`, so this is
# identical to `ORDER BY a` and stays on the COLUMN fast path (no materialization): 1 page + 5
# storage_row_read + 5 row_produced = 11. The output column is named by the alias, as written (§8).
# names: x
# cost: 11
query I nosort
SELECT a AS x FROM t ORDER BY x
----
10
10
10
20
NULL

# The alias binds a COMPUTED item too, materialized like a general-expression key: `bp` is `b + 1`,
# so this sorts by b+1 = 6,NULL,8,6,10 → DESC NULLS FIRST gives NULL, 10, 8, 6, 6. (The alias `s + 1`
# case below shows the alias is NOT in scope inside a larger expression — only a bare name binds.)
# names: bp
query I nosort
SELECT b + 1 AS bp FROM t ORDER BY bp DESC
----
NULL
10
8
6
6

# PRIORITY: a bare name binds the OUTPUT column even when it SHADOWS a same-named input column —
# `ORDER BY b` here binds the alias `b` (for column `a`), NOT the table column `b`. So the order is by
# `a` (10,10,10,20,NULL), not by `b` (which would be 5,5,5,7,9,NULL). This is PostgreSQL's documented
# inconsistency vs GROUP BY (which would bind the input column). Column fast path: cost 11.
# names: b
# cost: 11
query I nosort
SELECT a AS b FROM t ORDER BY b
----
10
10
10
20
NULL

# Two select-list items that are the SAME expression sharing a name are NOT ambiguous (PostgreSQL):
# `ORDER BY a` binds either — both are column `a`. Orders by a (the tie within the a=10 group is
# invisible). names: a, a
query II nosort
SELECT a, a FROM t ORDER BY a
----
10
10
10
10
10
10
20
20
NULL
NULL

# AMBIGUOUS: two output columns named `b` with DIFFERENT expressions (`a AS b` and the column `b`)
# make a bare `ORDER BY b` key 42702 — there is no single output column to bind (PostgreSQL).
statement error 42702
SELECT a AS b, b FROM t ORDER BY b

# The alias is visible ONLY for a bare-name key. Inside a larger expression (`s + 1`) the name `s`
# resolves against the INPUT columns like any expression operand — there is no column `s`, so 42703
# (PostgreSQL: an alias is not in scope within an ORDER BY expression).
statement error 42703
SELECT a + b AS s FROM t ORDER BY s + 1

# An alias composes with a second column key and a direction: `ORDER BY x DESC, id` sorts by `a`
# (the alias) descending, ties broken by id. a = 10,10,20,10,NULL → DESC NULLS FIRST: NULL (id5),
# 20 (id3), then the a=10 group by id (1,2,4). Both output columns make the order observable.
# names: x, id
query II nosort
SELECT a AS x, id FROM t ORDER BY x DESC, id
----
NULL
5
20
3
10
1
10
2
10
4

# G12 — empty scanned table. ORDER BY over zero rows yields zero rows at zero cost: nothing is
# scanned (no storage_row_read), nothing is produced (no row_produced), and the sort is a no-op
# over an empty input. LIMIT windows the same empty input to nothing. (The DISTINCT counterpart
# lives in distinct.test.)
statement ok
CREATE TABLE e (id i32 PRIMARY KEY, a i32)

# names: a
# cost: 0
query I nosort
SELECT a FROM e ORDER BY a
----

# LIMIT over an empty table: still zero rows, zero cost. No ORDER BY, so rowsort (the empty set
# carries no order to assert).
# names: a
# cost: 0
query I rowsort
SELECT a FROM e LIMIT 5
----
