# ORDER BY the first source's PK makes FROM order strictly cheaper and keeps p7_ra outer.
query ITTII nosort
EXPLAIN SELECT a.id, b.id FROM p7_ra a JOIN p7_rb b ON a.id > 0 ORDER BY a.id LIMIT 2
