1
Scan p7_tb
Full scan; touched=2
2
3

# cost: 12
query II nosort
SELECT a.id, b.id FROM p7_ta a JOIN p7_tb b ON a.k = b.k ORDER BY a.id
----
1
11
2
12

# --- selected physical order drives join top-N -----------------------------------------

statement ok
