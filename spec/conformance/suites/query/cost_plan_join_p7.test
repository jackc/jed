# An outer join is a P7 barrier. It retains logical/FROM order and the established LEFT hash path.
query ITTII nosort
EXPLAIN SELECT i.id, d.id FROM p7_ix i LEFT JOIN p7_drv d ON i.id = d.ixid
----
