# --- reverse-orientation INL ------------------------------------------------------------

statement ok
CREATE TABLE p7_ix (id i32 PRIMARY KEY, v i32)

statement ok
CREATE TABLE p7_drv (id i32 PRIMARY KEY, ixid i32)

statement ok
INSERT INTO p7_ix VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50),
  (6, 60), (7, 70), (8, 80), (9, 90), (10, 100), (11, 110), (12, 120),
  (13, 130), (14, 140), (15, 150), (16, 160), (17, 170), (18, 180),
  (19, 190), (20, 200)

statement ok
INSERT INTO p7_drv VALUES (1, 2), (2, 15), (3, 99)

# p7_ix appears first in FROM, but its PK depends on p7_drv. Only [p7_drv,p7_ix] makes that
# dependency physical-left, so the reverse INL wins and EXPLAIN renders the driver first.
query ITTII nosort
EXPLAIN SELECT i.id, d.id FROM p7_ix i JOIN p7_drv d ON i.id = d.ixid
----
0
Nested Loop
inner; on:conjuncts=1
