# P7 cost-selects the complete two-base-relation INNER/CROSS pipeline across both physical
# orientations and nested-loop, index-nested-loop, and hash algorithms. Logical column slots stay
# in source order even when EXPLAIN renders the selected reverse physical order. This is jed-owned
# plan/cost behavior and is intentionally not PostgreSQL-oracle output.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.join_inner, query.join_left, query.cross_join, query.qualified_column, query.comparison_order, query.order_by, query.order_by_keys, query.limit, query.explain, query.hash_join, query.index_nested_loop, query.order_by_join_scan, expr.arithmetic, types.i32, resource.cost_metering

# --- canonical exact tie: FROM order wins -----------------------------------------------

statement ok
CREATE TABLE p7_ta (id i32 PRIMARY KEY, k i32)

statement ok
CREATE TABLE p7_tb (id i32 PRIMARY KEY, k i32)

statement ok
INSERT INTO p7_ta VALUES (1, 1), (2, 2)

statement ok
INSERT INTO p7_tb VALUES (11, 1), (12, 2)

# Both nested-loop orientations have exactly the same complete estimate. Canonical physical
# relation order [0,1] retains FROM order; nested beats hash for this small pair.
query ITTII nosort
EXPLAIN SELECT a.id, b.id FROM p7_ta a JOIN p7_tb b ON a.k = b.k
----
0
Nested Loop
inner; on:conjuncts=1
1
