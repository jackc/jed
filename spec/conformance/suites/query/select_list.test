# Select-list output naming: SELECT *, explicit AS aliases, and the names of bare columns
# vs computed expressions (spec/design/grammar.md §8). Output column names are a CROSS-CORE
# determinism contract (no reference impl, §2): every core must derive the BYTE-IDENTICAL
# name for the same query. The `# names: ...` directive — a comment the stock sqllogictest
# runner ignores, like `# cost:` / `# requires:` — asserts the NEXT query's output column
# names, in order, for Rust, Go, and TS alike (../../../design/conformance.md §1).
#
# The naming rule: a bare column reference takes the catalog's CANONICAL name (the CREATE
# TABLE spelling, never the SELECT spelling); `expr AS alias` takes the alias as written;
# `*` takes each column's canonical name; any other un-aliased expression takes `?column?`.
# Aliases are output labels only — invisible to WHERE/ORDER BY resolution.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.select_star, query.column_alias, query.where_eq, query.order_by, expr.arithmetic, types.i32, query.point_lookup, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, a i32, b i32)

statement ok
INSERT INTO t VALUES (1, 6, 4)

statement ok
INSERT INTO t VALUES (2, 20, 10)

# A bare column takes its CANONICAL name: column `id` was declared lower-case, so selecting
# it as `ID` still names the output `id` — the user's casing must not leak (grammar.md §8).
# names: id
query I nosort
SELECT ID FROM t ORDER BY id
----
1
2

# An explicit `AS` alias is the output name, as written.
# names: total
query I nosort
SELECT a + b AS total FROM t WHERE id = 1
----
10

# `*` expands to every column's canonical name, in column order.
# names: id, a, b
query III nosort
SELECT * FROM t ORDER BY id
----
1
6
4
2
20
10

# An un-aliased computed expression takes the fixed placeholder `?column?` (no SQL-text
# echo — grammar.md §8).
# names: ?column?
query I nosort
SELECT a + b FROM t WHERE id = 1
----
10

# A mixed list exercises all four naming cases at once: bare column, aliased expression,
# un-aliased expression, bare column.
# names: id, total, ?column?, b
query IIII nosort
SELECT id, a + b AS total, a * 2, b FROM t ORDER BY id
----
1
10
12
4
2
30
40
10

# An alias may collide with a real column name; it is a pure output label and is never
# entered into resolution, so it does not shadow the column. Here the output is named `b`
# but carries column `a`'s values.
# names: b
query I nosort
SELECT a AS b FROM t ORDER BY id
----
6
20

# Proof the collision is harmless: WHERE still resolves `b` to the real column (value 10 in
# row 2), unaffected by the `AS b` output label on the projection.
# names: b
query I nosort
SELECT a AS b FROM t WHERE b = 10
----
20

# `# names:` and `# cost:` bind the same query independently. `id = 1` is a primary-key point
# lookup (cost.md §3 "bounded scan") — it reads only the one matched row, not both: 1 page + 1
# scanned + 1 filter (one `=`) + 1 produced + 1 projection (`a + b` is one Add) = 5.
# names: total
# cost: 5
query I nosort
SELECT a + b AS total FROM t WHERE id = 1
----
10
