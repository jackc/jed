# Every complete estimate ties. Canonical relation order [0,1,2] and nested loops win.
query ITTII nosort
EXPLAIN SELECT a.id, b.id, c.id
FROM p8_ta a JOIN p8_tb b ON a.k = b.k JOIN p8_tc c ON b.k = c.k
