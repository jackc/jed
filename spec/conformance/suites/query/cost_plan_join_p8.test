# The leading island reverses to use p8_fa's PK. LEFT remains a fixed barrier, and the suffix
# island is searched only after that fixed prefix; no relation crosses p8_fc.
query ITTII nosort
EXPLAIN SELECT a.id, b.id, c.id, d.id, e.id
FROM p8_fa a
JOIN p8_fb b ON a.id = b.id
LEFT JOIN p8_fc c ON b.id = c.id
JOIN p8_fd d ON c.id = d.id
JOIN p8_fe e ON d.id = e.id
