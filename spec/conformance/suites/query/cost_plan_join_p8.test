# P8 searches maximal contiguous base-table INNER/CROSS islands as complete N-way physical
# pipelines. Fixed join barriers remain in source order, authored ON trees schedule intact, and
# DP switches to deterministic greedy construction above join_dp_limit=8. This is jed-owned
# plan/cost behavior and is intentionally not PostgreSQL-oracle output.
# requires: ddl.create_table, ddl.primary_key, ddl.secondary_index, dml.insert, dml.insert_multi_row, query.select, query.join_inner, query.join_left, query.cross_join, query.qualified_column, query.comparison_order, query.logical_connectives, query.where_eq, query.order_by, query.order_by_keys, query.limit, query.explain, query.hash_join, query.index_nested_loop, query.order_by_join_scan, types.i32, resource.cost_metering

