# Both conjuncts authored on m3 stay together and schedule exactly once when m3 is added.
query ITTII nosort
EXPLAIN SELECT a.id, b.id, c.id, d.id
FROM p8_m0 a
JOIN p8_m1 b ON a.k = b.k
JOIN p8_m2 c ON b.k = c.k
JOIN p8_m3 d ON c.k = d.k AND b.k = d.k
