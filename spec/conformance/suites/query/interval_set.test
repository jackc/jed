# Canonical interval-set algebra (cost.md §3): OR range unions and IN/point-set intersections are
# encoded at runtime, clipped, sorted, and merged into disjoint key intervals. The full predicate is
# still the residual recheck. All trees here fit in one leaf.
# requires: ddl.create_table, ddl.primary_key, ddl.secondary_index, dml.insert, dml.insert_multi_row, dml.update, dml.delete, query.select, query.where_eq, query.comparison_order, query.logical_connectives, query.order_by, query.point_lookup, query.or_in_point_lookup, query.interval_set, query.index_range, query.index_mutation, expr.in_list, expr.between, types.i32, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, v i32)

statement ok
INSERT INTO t VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50), (6, 60), (7, 70), (8, 80)

# Point-set ∩ range keeps only 5 and 7; each remains an isolated point probe.
# cost: 24
query I nosort
SELECT id FROM t WHERE id IN (1, 3, 5, 7) AND id > 3 ORDER BY id
----
5
7

# Empty intersection performs no probe and costs zero.
# cost: 0
query I nosort
SELECT id FROM t WHERE id IN (1, 2) AND id > 5
----

# A union of two disjoint ranges scans two canonical intervals.
# cost: 22
query I nosort
SELECT id FROM t WHERE id < 3 OR id >= 7 ORDER BY id
----
1
2
7
8

# Overlapping BETWEEN disjuncts merge to one [2,7] interval; rows 4 and 5 are emitted once.
# cost: 55
query I nosort
SELECT id FROM t WHERE id BETWEEN 2 AND 5 OR id BETWEEN 4 AND 7 ORDER BY id
----
2
3
4
5
6
7

# Fixed-width byte-adjacent closed intervals merge: the union covers the whole key space in one scan.
# cost: 41
query I nosort
SELECT id FROM t WHERE id <= 3 OR id >= 4 ORDER BY id
----
1
2
3
4
5
6
7
8

# Duplicate points collapse to one canonical point.
# cost: 6
query I nosort
SELECT id FROM t WHERE id = 2 OR id = 2
----
2

# NULL makes only its source interval empty; a contradictory AND leaf also disappears. Reversed
# operands normalize to the same key directions.
query I nosort
SELECT id FROM t WHERE id = 2 OR id < NULL
----
2

query I nosort
SELECT id FROM t WHERE (id > 6 AND id < 4) OR id = 2
----
2

query I nosort
SELECT id FROM t WHERE 3 > id OR 7 <= id ORDER BY id
----
1
2
7
8

# Secondary-index range unions use the same logical canonicalizer, then map each interval into the
# index's present-value key space.
statement ok
CREATE TABLE s (id i32 PRIMARY KEY, x i32, v i32)

statement ok
CREATE INDEX sx ON s (x)

statement ok
INSERT INTO s VALUES (1, 10, 1), (2, 20, 2), (3, 30, 3), (4, 40, 4), (5, 40, 5), (6, 50, 6)

# cost: 26
query I nosort
SELECT id FROM s WHERE x < 20 OR x >= 40 ORDER BY id
----
1
4
5
6

# Overlap at x=40 emits both non-unique rows once.
query I nosort
SELECT id FROM s WHERE x <= 40 OR x >= 40 ORDER BY id
----
1
2
3
4
5
6

# Mutation consumers gather the canonical union once from the pre-mutation state.
# cost: 26
statement ok
UPDATE s SET v = v + 100 WHERE x < 20 OR x >= 40

# The overlapping source ranges canonicalize before mutation, so x=40 rows update once, not twice.
statement ok
UPDATE s SET v = v + 1 WHERE x <= 40 OR x >= 40

# cost: 10
statement ok
DELETE FROM t WHERE id < 2 OR id >= 8

query II nosort
SELECT id, v FROM s ORDER BY id
----
1
102
2
3
3
4
4
105
5
106
6
107

query I nosort
SELECT id FROM t ORDER BY id
----
2
3
4
5
6
7
