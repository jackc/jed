# generate_series — the engine's first set-returning function, a FROM-clause row source
# (spec/design/functions.md §10, grammar.md §35). generate_series(start, stop[, step]) over the
# integer family is a COMPUTED relation (not a scanned table): one column named generate_series,
# typed at the promoted integer type of the args. PostgreSQL semantics: ascending/descending by
# the step, inclusive of stop when it lands on the sequence; any NULL arg → zero rows; start past
# stop for the step's direction → zero rows; a step of zero → 22023. It composes with WHERE /
# ORDER BY / LIMIT, joins/cross-joins other FROM relations, and (implicitly lateral, grammar.md §44)
# takes a $N, a correlated OUTER column, or an earlier sibling as an argument. Each generated element charges one generated_row, so a
# query's cost is the generated rows plus the usual evaluation + row_produced (spec/design/cost.md
# §3) — distinct from a table scan's page_read/storage_row_read, of which an SRF charges none.
# PostgreSQL-oracle-verified (postgres:18). The integer-literal args default to int64 (jed's
# literal typing), so the column is int64 — value-identical to PG's int4/int8.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.set_returning, query.comparison_order, query.order_by, query.limit, query.cross_join, query.table_alias, query.qualified_column, query.subquery_scalar, query.subquery_correlated, query.aggregates, expr.comparison_value, types.int32, types.int64, resource.cost_metering, resource.cost_limit

# --- the basic two-argument series: one int64 column named generate_series ---------------
# 5 generated_row + 5 row_produced; the integer-literal args are leaves (no operator_eval).
# names: generate_series
# types: int64
# cost: 10
query I rowsort
SELECT * FROM generate_series(1, 5)
----
1
2
3
4
5

# --- three-argument form: an explicit step --------------------------------------------
# cost: 10
query I rowsort
SELECT * FROM generate_series(1, 10, 2)
----
1
3
5
7
9

# --- a descending step --------------------------------------------------------------
# cost: 10
query I rowsort
SELECT * FROM generate_series(5, 1, -1)
----
1
2
3
4
5

# --- start past stop for the step direction → zero rows -------------------------------
# Zero rows generated and produced.
# cost: 0
query I rowsort
SELECT * FROM generate_series(5, 1)
----

# G30 — an EXPLICIT step whose sign disagrees with the start→stop direction yields zero rows:
# generate_series(1, 5, -1) would have to count DOWN from 1 to reach 5 (it never does), and
# generate_series(5, 1, 1) would have to count UP from 5 to reach 1. Both are empty.
# cost: 0
query I rowsort
SELECT * FROM generate_series(1, 5, -1)
----

# cost: 0
query I rowsort
SELECT * FROM generate_series(5, 1, 1)
----

# --- a single-element series ---------------------------------------------------------
# cost: 2
query I rowsort
SELECT * FROM generate_series(3, 3)
----
3

# --- any NULL argument → zero rows ---------------------------------------------------
# cost: 0
query I rowsort
SELECT * FROM generate_series(NULL, 5)
----

# cost: 0
query I rowsort
SELECT * FROM generate_series(1, 5, NULL)
----

# --- a step of zero is invalid_parameter_value ---------------------------------------
statement error 22023
SELECT * FROM generate_series(1, 5, 0)

# --- WHERE over the generated rows ---------------------------------------------------
# 5 generated_row + 5 operator_eval (the `>` per row) + 3 row_produced.
# cost: 13
query I rowsort
SELECT * FROM generate_series(1, 5) WHERE generate_series > 2
----
3
4
5

# --- ORDER BY + LIMIT over the generated rows (the SRF takes the eager path) ----------
# 5 generated_row + 2 row_produced (the sort/limit are unmetered — cost.md §3).
# cost: 7
query I nosort
SELECT * FROM generate_series(1, 5) ORDER BY generate_series DESC LIMIT 2
----
5
4

# --- alias + qualified column reference ----------------------------------------------
# PG's single-column function-alias rule: `AS g` renames the output column to `g`, so the
# qualified reference is `g.g` (and `g.generate_series` would be 42703 — there is no such column).
# cost: 6
query I rowsort
SELECT g.g FROM generate_series(1, 3) AS g
----
1
2
3

# --- CROSS JOIN with a base table: the series is one operand of the product -----------
statement ok
CREATE TABLE t (id int32 PRIMARY KEY, n int32)

statement ok
INSERT INTO t VALUES (1, 0), (2, 2), (3, 3)

# id-keyed scan of t (page_read + 3 storage_row_read) + 3 generated_row + 9 row_produced.
# names: id, n, generate_series
# cost: 16
query III rowsort
SELECT * FROM t CROSS JOIN generate_series(1, 3)
----
1
0
1
1
0
2
1
0
3
2
2
1
2
2
2
2
2
3
3
3
1
3
3
2
3
3
3

# --- a correlated OUTER column as an argument (non-LATERAL): per-row series length ----
query I rowsort
SELECT (SELECT count(*) FROM generate_series(1, o.n)) FROM t o
----
0
2
3

# G16 — the §13 untrusted-SRF guarantee actually firing. A series that would generate a million
# rows is bounded by the cost ceiling: each generated element charges one generated_row, so accrued
# cost reaches the ceiling long before the series finishes and execution aborts deterministically
# (54P01) rather than materializing 1,000,000 rows. The abort is mid-generation — the SRF is lazy,
# so the meter strikes without first building the whole relation. (PG has no cost ceiling, so this
# is a jed-only guarantee; it cannot be oracle-verified — corpus:check warns, like cost_limit.test.)
# max_cost: 100
statement error 54P01
SELECT * FROM generate_series(1, 1000000)
