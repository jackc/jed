# GIN-bounded `= ANY` membership — `c = ANY(col)` narrows a SELECT over a GIN-indexed array
# column (spec/design/gin.md §6). `c = ANY(col)` is the array spelling of membership, semantically
# `col @> ARRAY[c]`; with a GIN index present, jed gathers the single query term `c`'s posting list
# as the candidate rows and keeps the original `= ANY` predicate as the residual WHERE filter, so
# the RESULT is identical to the full-scan answer — this file pins that the index is transparent
# (correct rows with the index, including across DELETE maintenance). The PostgreSQL oracle agrees
# (the rows do not depend on whether an index is used); note PG itself does NOT GIN-accelerate
# `= ANY(array)` — a jed acceleration divergence (same rows, lower cost — gin.md §9). The membership
# semantics themselves are pinned in expr/array_quantified.test.
#
# The `# cost:` assertions PIN that the GIN bound (not a full scan) is taken: page_read for the
# single term's posting-list range + gin_entry per posting entry visited + per-candidate point
# lookup (page_read + storage_row_read) + the residual `operator_eval` + row_produced (gin.md §6 /
# cost.md §3). A provably-empty bound — a NULL `c` or a `c` outside the i32 element range — charges
# 0. The costs are cross-core identical (CLAUDE.md §8). Format: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, ddl.gin_index, query.gin_any_eq, dml.insert, dml.insert_multi_row, dml.delete, query.select, query.order_by, query.where_eq, types.i32, types.i64, types.array, func.array_quantified, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, tags i32[])

statement ok
CREATE INDEX t_tags_gin ON t USING gin (tags)

# shared / disjoint / duplicate-element / empty / NULL element sets
statement ok
INSERT INTO t VALUES
  (1, ARRAY[10,20,30]),
  (2, ARRAY[20,40]),
  (3, ARRAY[40,50]),
  (4, ARRAY[10,10,20]),
  (5, '{}'),
  (6, NULL)

# --- c = ANY(col): rows whose tags contain c (a single-term posting gather) -----------------
# 20 → rows 1, 2, 4 (the bare literal adapts to tags's i32 element)
# cost: 22
query I nosort
SELECT id FROM t WHERE 20 = ANY(tags) ORDER BY id
----
1
2
4

# 10 → rows 1 and 4 (row 4's duplicate 10 is one posting entry per row — term dedup)
# cost: 13
query I nosort
SELECT id FROM t WHERE 10 = ANY(tags) ORDER BY id
----
1
4

# no row contains 99 → empty (an in-range term whose posting list is empty)
# cost: 1
query I nosort
SELECT id FROM t WHERE 99 = ANY(tags) ORDER BY id
----

# SOME is a synonym for ANY
# cost: 14
query I nosort
SELECT id FROM t WHERE 40 = SOME(tags) ORDER BY id
----
2
3

# --- degenerate constants (provably-empty bounds, gin.md §6) -------------------------------
# NULL = ANY(...) is never TRUE → empty (a typed NULL; a bare untyped NULL operand is 42P18)
# cost: 0
query I nosort
SELECT id FROM t WHERE NULL::i32 = ANY(tags) ORDER BY id
----

# --- the index is transparent under maintenance: results stay correct after DELETE ----------
statement ok
DELETE FROM t WHERE id = 1

# row 1's entries are gone from every posting — rows containing 20 are now just 2 and 4
# cost: 15
query I nosort
SELECT id FROM t WHERE 20 = ANY(tags) ORDER BY id
----
2
4
