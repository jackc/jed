# Composite-primary-key tuple bounds (constraints.md §3; cost.md §3). The planner consumes the
# maximal equality prefix in PRIMARY-KEY order plus an optional range on the next member. The whole
# WHERE / ON remains the residual recheck, so only cost changes. All tables here fit in one leaf.
# requires: ddl.create_table, ddl.primary_key, ddl.composite_primary_key, ddl.collate_column, dml.insert, dml.insert_multi_row, dml.update, dml.delete, query.select, query.where_eq, query.comparison_order, query.logical_connectives, query.order_by, query.qualified_column, query.join_inner, query.index_nested_loop, query.hash_join, query.subquery_exists, query.subquery_correlated, query.correlated_pushdown, query.point_lookup, query.composite_pk_pushdown, types.i16, types.i32, types.text, null.three_valued, resource.cost_metering

# The PK order is (b,a), deliberately different from declaration order.
statement ok
CREATE TABLE cp (a i32, b i16, v text, PRIMARY KEY (b, a))

statement ok
INSERT INTO cp VALUES (1, 1, 'one'), (2, 1, 'two'), (3, 1, 'three'), (1, 2, 'four'), (2, 2, 'five')

# Complete tuple equality is an exact point: 1 page + 1 row + 3-node AND + 1 output = 6.
# cost: 6
query T nosort
SELECT v FROM cp WHERE a = 2 AND b = 1
----
two

# A proper leading equality prefix scans its byte-prefix interval: three admitted rows.
# 1 page + 3 rows + 3 filters + 3 outputs = 10.
# cost: 10
query IT nosort
SELECT a, v FROM cp WHERE b = 1 ORDER BY a
----
1
one
2
two
3
three

# Equality prefix plus range on the next member: rows (1,2) and (1,3).
# 1 page + 2 rows + 6 AND-node evals + 2 outputs = 11.
# cost: 11
query I nosort
SELECT a FROM cp WHERE b = 1 AND a >= 2 ORDER BY a
----
2
3

# Conflicting equalities on a consumed member are provably empty and touch nothing.
# cost: 0
query I nosort
SELECT a FROM cp WHERE b = 1 AND b = 2
----

# Equality plus a false same-member range is also empty (the range must not be discarded merely
# because equality completes that member).
# cost: 0
query I nosort
SELECT a FROM cp WHERE b = 1 AND b > 3
----

# A NULL equality source is likewise 3VL-empty.
# cost: 0
query I nosort
SELECT a FROM cp WHERE b = 1 AND a = NULL
----

# No leading member means no skip-scan: full scan (1 page + 5 rows + 5 filters + 2 outputs).
# cost: 13
query T nosort
SELECT v FROM cp WHERE a = 2 ORDER BY v
----
five
two

# UPDATE and DELETE use the same tuple bound. Exact UPDATE: 1 page + 1 row + 3 filter nodes = 5.
# cost: 5
statement ok
UPDATE cp SET v = 'TWO' WHERE b = 1 AND a = 2

# Prefix DELETE admits two b=2 rows: 1 page + 2 rows + 2 filters = 5.
# cost: 5
statement ok
DELETE FROM cp WHERE b = 2

query IT nosort
SELECT a, v FROM cp WHERE b = 1 ORDER BY a
----
1
one
2
TWO
3
three

# Correlated complete tuples seek once per outer row. Outer = 1 page + 3 rows. Two hits each cost
# inner (1 page + 1 row + 3 filter + 1 output) + EXISTS node = 7; one miss costs 1 page + node = 2;
# two outer outputs. Total 4 + 7 + 7 + 2 + 2 = 22.
statement ok
CREATE TABLE co (id i32 PRIMARY KEY, a i32, b i16)

statement ok
INSERT INTO co VALUES (1, 1, 1), (2, 3, 1), (3, 9, 1)

# cost: 22
query I nosort
SELECT co.id FROM co WHERE EXISTS (SELECT 1 FROM cp WHERE cp.a = co.a AND cp.b = co.b) ORDER BY co.id
----
1
2

# Index-nested-loop accepts a usable leading tuple from sibling columns. Outer materialization is 4;
# the two hits and one miss charge 3 pages + 2 rows = 5, ON recheck is 3 nodes × 2 hits, outputs 2.
# cost: 17
query IT nosort
SELECT co.id, cp.v FROM co JOIN cp ON cp.a = co.a AND cp.b = co.b ORDER BY co.id
----
1
one
2
three

# A sibling predicate on only the non-leading member cannot seed composite INL, so the inner scans
# once; the same-type equality instead selects hash join and emits two exact-key matches.
# cost: 52
query II nosort
SELECT co.id, cp.a FROM co JOIN cp ON cp.a = co.a ORDER BY co.id, cp.a
----
1
1
2
3

# Variable-width text members are self-delimiting, so a prefix and its trailing range compose.
statement ok
CREATE TABLE ct (g i32, name text, v i32, PRIMARY KEY (g, name))

statement ok
INSERT INTO ct VALUES (1, 'a', 1), (1, 'aa', 2), (1, 'b', 3), (2, 'a', 4)

# 1 page + 2 rows + 6 filter nodes + 2 outputs = 11.
# cost: 11
query T nosort
SELECT name FROM ct WHERE g = 1 AND name < 'b' ORDER BY name
----
a
aa

# Full tuple miss still follows the one-leaf point path.
# cost: 1
query I nosort
SELECT v FROM ct WHERE g = 1 AND name = 'missing'
----

# A non-C collated trailing member encodes endpoints with the same frozen sort-key form as storage.
# load-collation: unicode = collation/17.0.0/root.allkeys
statement ok
CREATE TABLE cc (g i32, name text COLLATE "unicode", PRIMARY KEY (g, name))

statement ok
INSERT INTO cc VALUES (1, 'a'), (1, 'A'), (1, 'b'), (2, 'a')

# Unicode order a < A < b. Two admitted rows; each residual ordering comparison also charges
# collate by two code points: 1 page + 2 rows + 6 filter + 4 collate + 2 outputs = 15.
# cost: 15
query T nosort
SELECT name FROM cc WHERE g = 1 AND name < 'b' ORDER BY name
----
a
A

# Explicit C collation disagrees with the stored unicode member and therefore cannot seed the
# second-member range. The leading g=1 prefix remains usable and the residual C comparison filters.
# The leading g prefix admits all three g=1 rows: 1 page + 3 rows + 9 filter nodes + 2 outputs = 15.
# cost: 15
query T nosort
SELECT name FROM cc WHERE g = 1 AND name < 'b' COLLATE "C" ORDER BY name COLLATE "C"
----
A
a
