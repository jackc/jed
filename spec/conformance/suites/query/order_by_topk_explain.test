# EXPLAIN surface and exclusion gates for blocking ORDER BY LIMIT top-k (planner.md §4).
# requires: ddl.create_table, ddl.primary_key, dml.insert_multi_row, query.select, query.order_by, query.order_by_topk, query.limit, query.offset, query.explain, query.distinct, query.aggregates, query.group_by, query.union, types.i32

statement ok
CREATE TABLE tkx (id i32 PRIMARY KEY, a i32)

statement ok
INSERT INTO tkx VALUES (1, 10), (2, 20), (3, 10)

statement ok
CREATE TABLE tkxu (id i32 PRIMARY KEY, score i32)

statement ok
INSERT INTO tkxu VALUES (1, 30), (2, 5)

# The physical decision is visible on the blocking Sort node.
query ITTII nosort
EXPLAIN SELECT id FROM tkx ORDER BY a DESC, id LIMIT 3 OFFSET 2
----
0
Limit
limit=3 offset=2
1
5
1
Sort
keys=2, top-k=5
3
4
2
Scan tkx
Full scan; touched=2
3
4

# LIMIT 0 records K=0 even with a huge OFFSET.
query ITTII nosort
EXPLAIN SELECT id FROM tkx ORDER BY a LIMIT 0 OFFSET 9223372036854775807
----
0
Limit
limit=0 offset=9223372036854775807
0
4
1
Sort
keys=1, top-k=0
3
4
2
Scan tkx
Full scan; touched=2
3
4

# K overflow is guarded identically and falls back to the full sort.
query ITTII nosort
EXPLAIN SELECT id FROM tkx ORDER BY a LIMIT 1 OFFSET 9223372036854775807
----
0
Limit
limit=1 offset=9223372036854775807
0
4
1
Sort
keys=1
3
4
2
Scan tkx
Full scan; touched=2
3
4

