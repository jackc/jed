# Multi-column secondary index with a VARIABLE-WIDTH trailing key column
# (spec/design/indexes.md §5, encoding.md §2.4/§2.5/§2.6/§2.10).
#
# The index-bounded scan (query/index_scan.test) walks each index entry and skips the
# remaining key components to recover the row's storage key. That skip advances over each
# trailing component by its FIXED key width, which exists only for the fixed-width scalars.
# A tail column of a variable-width type (text / decimal / bytea / interval — all keyable)
# has no fixed width, so an equality on the LEADING column must NOT push down through such
# an index: it falls back to the full scan + residual filter (the same narrowing as a
# non-scalar / range tail column). The rows are identical either way; only the cost differs,
# so engagement is pinned the cost way (query/index_scan.test, collation/collated_pushdown.test):
# each variable-width-tail query costs the FULL scan, proving the bound did NOT engage —
#   full scan = page_read(1) + storage_row_read(rows) + filter operator_evals(rows) + row_produced(matches).
# The closing fixed-width control proves the guard is PRECISE: a multi-column index whose
# tail is fixed-width DOES still push down (strictly lower cost). This is the cross-core
# contract (Rust == Go == TS). Before the fix, the variable-width tail-skip aborted the
# scan (a panic / mis-parsed key) instead of returning these rows.
# Format: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, ddl.secondary_index, dml.insert, dml.insert_multi_row, query.select, query.where_eq, query.order_by, types.i32, types.text, types.decimal, types.bytea, resource.cost_metering

# --- text tail column --------------------------------------------------------------

statement ok
CREATE TABLE vt (id i32 PRIMARY KEY, a i32, b text)

statement ok
INSERT INTO vt VALUES (1, 10, 'apple'), (2, 10, 'banana'), (3, 20, 'cherry'), (4, 10, 'date'), (5, 30, 'elderberry')

statement ok
CREATE INDEX vt_ab ON vt (a, b)

# equality on the leading column would attempt the index bound, whose tail-skip over the
# `text` component has no fixed width — so it does NOT push down. Full scan, correct rows:
# page_read(1) + 5 storage_row_read + 5 filter evals + 3 produced = 14.
# cost: 14
query I nosort
SELECT id FROM vt WHERE a = 10 ORDER BY id
----
1
2
4

# --- decimal tail column -----------------------------------------------------------

statement ok
CREATE TABLE vd (id i32 PRIMARY KEY, a i32, b decimal)

statement ok
INSERT INTO vd VALUES (1, 10, 1.5), (2, 10, 2.25), (3, 20, 3.0), (4, 10, 4.125)

statement ok
CREATE INDEX vd_ab ON vd (a, b)

# full scan: page_read(1) + 4 storage_row_read + 4 filter evals + 3 produced = 12.
# cost: 12
query I nosort
SELECT id FROM vd WHERE a = 10 ORDER BY id
----
1
2
4

# --- bytea tail column -------------------------------------------------------------

statement ok
CREATE TABLE vb (id i32 PRIMARY KEY, a i32, b bytea)

statement ok
INSERT INTO vb VALUES (1, 10, '\x0102'), (2, 10, '\x03'), (3, 20, '\x04'), (4, 10, '\xdeadbeef')

statement ok
CREATE INDEX vb_ab ON vb (a, b)

# full scan: page_read(1) + 4 storage_row_read + 4 filter evals + 3 produced = 12.
# cost: 12
query I nosort
SELECT id FROM vb WHERE a = 10 ORDER BY id
----
1
2
4

# --- fixed-width tail control: pushdown still engages ------------------------------

statement ok
CREATE TABLE fw (id i32 PRIMARY KEY, a i32, c i32)

statement ok
INSERT INTO fw VALUES (1, 10, 100), (2, 10, 200), (3, 20, 300), (4, 10, 400), (5, 30, 500)

statement ok
CREATE INDEX fw_ac ON fw (a, c)

# the (a, c) tail is fixed-width, so this DOES push down — index node(1) + 3 point lookups
# + 3 storage_row_read + 3 filter evals + 3 produced = 13, strictly cheaper than the 14 a
# full scan of these 5 rows would cost (the same scan the variable-width tails are forced into).
# cost: 13
query I nosort
SELECT id FROM fw WHERE a = 10 ORDER BY id
----
1
2
4
