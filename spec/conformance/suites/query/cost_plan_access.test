# P6a: deterministic estimated-cost selection among full, PK, and ordered B-tree paths for a
# one-base-relation SELECT. Row-count changes alter the shared estimate and can therefore change the
# selected physical path. The complete WHERE always remains the residual filter. UPDATE/DELETE and
# joins retain their staged legacy policies.
# requires: ddl.create_table, ddl.primary_key, ddl.secondary_index, dml.insert, dml.insert_multi_row, dml.update, query.select, query.where_eq, query.comparison_order, query.logical_connectives, query.point_lookup, query.index_range, query.order_by, query.order_by_keys, query.limit, query.order_by_pk_scan, query.order_by_index_scan, query.explain, dml.explain, resource.cost_metering, types.i32

statement ok
CREATE TABLE p6a (id i32 PRIMARY KEY, a i32, b i32)

statement ok
CREATE INDEX a_first ON p6a (a)

statement ok
CREATE INDEX z_b ON p6a (b)

statement ok
INSERT INTO p6a VALUES (1, 7, 1)

# At one row, the full scan costs less than a secondary-index descent plus table point fetch.
# names: depth, node, detail, est_rows, est_cost
# types: i32, text, text, i64, i64
query ITTII nosort
EXPLAIN SELECT id FROM p6a WHERE a = 7
----
0
Filter
conjuncts=1
1
4
1
Scan p6a
Full scan; touched=2
1
2

# cost: 4
query I nosort
SELECT id FROM p6a WHERE a = 7
----
1

statement ok
INSERT INTO p6a VALUES (2, 8, 2)

# At two rows, the equality index estimate is cheaper and the plan flips.
query ITTII nosort
EXPLAIN SELECT id FROM p6a WHERE a = 7
