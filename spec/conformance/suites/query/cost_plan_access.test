# UPDATE remains on the mutation legacy policy: PK precedence is unchanged even though the
# one-relation SELECT above chooses z_b for the same predicate.
query ITTII nosort
EXPLAIN UPDATE p6a SET a = a WHERE id > 0 AND b = 1
