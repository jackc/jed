# cost: 5
query I nosort
SELECT id FROM p6a WHERE a = 7
----
1

# The selected B-tree emits a_first order, not table-PK order, so ORDER BY id remains a blocking
# Sort. Scan-order claims are recomputed after cost selection.
query ITTII nosort
EXPLAIN SELECT id FROM p6a WHERE a = 7 ORDER BY id
----
0
