query I nosort
SELECT id FROM p6a WHERE id > 0 AND b = 1
----
1

statement ok
INSERT INTO p6a VALUES (3, 9, 3), (4, 10, 4)

# At four rows, the equality B-tree estimate beats the one-sided PK-range estimate.
query ITTII nosort
EXPLAIN SELECT id FROM p6a WHERE id > 0 AND b = 1
