# VERBOSE replaces predicate counts with a fully parenthesized resolved-expression spelling and
# appends the projection list to the outermost SELECT node. LANE is statement-wide.
# names: depth, node, detail, lane
query ITTT nosort
EXPLAIN (VERBOSE TRUE, COSTS OFF, LANE ON) SELECT v + 1 FROM t WHERE id = 1 AND v > 0
----
