# EXPLAIN follow-on surface: parenthesized boolean options, canonical verbose expressions, exact
# float literal text, lane classification, per-node ANALYZE costs, DML touched sets, and writable
# WITH plans. This is jed-owned deterministic output (spec/design/explain.md).
# requires: ddl.create_table, ddl.primary_key, ddl.secondary_index, ddl.sequence, dml.insert, dml.insert_multi_row, dml.insert_select, dml.update, dml.returning, query.select, query.where_eq, query.comparison_order, query.logical_connectives, query.limit, query.order_by, query.order_by_pk_scan, query.order_by_index_scan, query.order_by_join_inl, query.order_by_topk, query.window, query.window_ranking, query.cte, query.cte_data_modifying, query.union, query.explain, query.explain_analyze, query.aggregates, query.subquery_scalar, query.derived_table, query.join_inner, query.qualified_column, query.hash_join, dml.explain, expr.arithmetic, expr.json_query_fns, func.sequence, func.jsonb_path, types.i32, types.i64, types.f64, types.jsonb, types.jsonpath, resource.cost_metering

