# P9 statistics refine stale NDV scaling, equality joins, and simple-column GROUP BY/DISTINCT
# cardinality (spec/design/statistics.md §§5–6). Low-cardinality NDV stays fixed; key-like NDV scales
# proportionally to the current non-NULL population. These deterministic integer estimates and plan
# choices are jed-owned and cross-core checked.
# requires: maintenance.analyze, introspect.statistics, ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, dml.insert_select, query.select, query.set_returning, query.comparison_order, query.aggregates, query.group_by, query.distinct, query.join_inner, query.table_alias, query.qualified_column, query.explain, query.order_by, expr.arithmetic, expr.between, cast.explicit, types.i32, types.i64

# --- fixed versus proportional NDV under retained stale facts -----------------------------------

statement ok
CREATE TABLE p9_scale (id i32 PRIMARY KEY, enumv i32)

statement ok
INSERT INTO p9_scale
SELECT CAST(generate_series AS i32), CAST(generate_series % 2 AS i32)
FROM generate_series(1, 100)

statement ok
ANALYZE p9_scale

# Double the population without refreshing. Raw facts remain at 100 rows and stale; current enumv
# NDV remains 2 while key-like id NDV scales from 100 to 200.
statement ok
INSERT INTO p9_scale
SELECT CAST(generate_series + 100 AS i32), CAST(generate_series % 2 AS i32)
FROM generate_series(1, 100)

query TIBI nosort
SELECT column_name, analyzed_rows, is_stale, distinct_count
FROM jed_statistics ORDER BY column_name
----
enumv
100
true
2
id
100
true
100

