# --- histogram target ---------------------------------------------------------------------------

# More than 100 complete-population groups produces no one-off MCVs and exactly 101 equi-depth
# bounds. This also exercises exact KMV NDV below the 4,096-hash cap.
statement ok
CREATE TABLE p9_histogram (id i32 PRIMARY KEY, v i32)

statement ok
INSERT INTO p9_histogram
SELECT CAST(generate_series AS i32), CAST(generate_series AS i32)
FROM generate_series(1, 102)

statement ok
ANALYZE p9_histogram (v)

query IIIII nosort
SELECT analyzed_rows, distinct_count, sample_rows, mcv_count, histogram_count
FROM jed_statistics WHERE table_name = 'p9_histogram'
----
102
102
102
0
101

# Step-CDF one-sided and paired-range estimates use the stored 101 bounds without within-bucket
# interpolation. The paired form is evaluated once rather than multiplying two inequalities.
query ITTII nosort
EXPLAIN SELECT id FROM p9_histogram WHERE v < 52
----
0
Filter
conjuncts=1
53
258
1
Scan p9_histogram
Full scan; touched=2
102
103

query ITTII nosort
EXPLAIN SELECT id FROM p9_histogram WHERE v BETWEEN 26 AND 76
----
0
Filter
conjuncts=2
53
462
1
Scan p9_histogram
Full scan; touched=2
102
103

# --- bounded sample and KMV cap ----------------------------------------------------------------

# 30,001 unique values force the 30,000-row priority-sample cap and the 4,096-hash KMV estimate.
# FNV-1a over the canonical i32 keys makes the stored deterministic estimate 14,315; the bounded
# sample has no duplicate groups, so it produces 101 equi-depth bounds and no MCVs.
statement ok
CREATE TABLE p9_bounded (id i32 PRIMARY KEY, v i32)

statement ok
INSERT INTO p9_bounded
SELECT CAST(generate_series AS i32), CAST(generate_series AS i32)
FROM generate_series(1, 30001)

statement ok
ANALYZE p9_bounded (v)

query IIIII nosort
SELECT analyzed_rows, distinct_count, sample_rows, mcv_count, histogram_count
FROM jed_statistics WHERE table_name = 'p9_bounded'
----
30001
14315
30000
0
101
