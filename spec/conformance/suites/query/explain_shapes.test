# EXPLAIN over the richer read-query shapes (spec/design/explain.md): aggregation, joins, window
# functions, set operations, derived tables / subqueries, CTEs, VALUES, and set-returning functions.
# The plan tree is rendered in pre-order (depth-numbered), so the rows read top-down as the executor's
# pipeline reads bottom-up. Deterministic and cross-core-identical, asserted with `nosort`.
# requires: ddl.create_table, ddl.primary_key, ddl.composite_primary_key, ddl.secondary_index, dml.insert, query.select, query.where_eq, query.comparison_order, query.logical_connectives, query.point_lookup, query.composite_pk_pushdown, query.interval_set, query.index_range, query.bounded_limit_streaming, query.limit, query.order_by, query.order_by_ordinal, query.order_by_index_scan, query.order_by_join_scan, query.order_by_join_inl, query.aggregates, query.group_by, query.having, query.join_inner, query.cross_join, query.join_pushdown, query.index_nested_loop, query.union, query.derived_table, query.subquery_scalar, query.cte, query.window, query.window_aggregate, query.set_returning, query.values, query.explain, cast.explicit, types.i16, types.i32, types.text

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, v i32, s text)

statement ok
CREATE TABLE u (id i32 PRIMARY KEY, tid i32)

statement ok
INSERT INTO t VALUES (1, 10, 'a')

statement ok
INSERT INTO u VALUES (1, 1)

# A whole-table aggregate: no grouping keys, one aggregate, no touched columns for count(*).
query ITT nosort
EXPLAIN SELECT count(*) FROM t
----
0
Aggregate
groups=0 aggs=1
1
Scan t
Full scan

# GROUP BY + HAVING: the grouping-key / aggregate / HAVING-conjunct counts appear on the Aggregate.
query ITT nosort
EXPLAIN SELECT v, count(*) FROM t GROUP BY v HAVING count(*) > 1
----
0
Aggregate
groups=1 aggs=2; having:conjuncts=1
1
Scan t
Full scan; touched=1

# An inner join is a Nested Loop with the ON conjunct count; each base table is a Scan child.
query ITT nosort
EXPLAIN SELECT * FROM t JOIN u ON u.tid = t.id
----
0
Nested Loop
inner; on:conjuncts=1
1
Scan t
Full scan; touched=3
1
Scan u
Full scan; touched=2

# Index-nested-loop join: the inner relation `t` has its PK compared to the sibling `u.tid`, so its
# scan is a per-outer-row seek — the access path shows `Index-nested-loop PK bound` (query.index_nested_loop).
query ITT nosort
EXPLAIN SELECT * FROM u JOIN t ON t.id = u.tid
----
0
Nested Loop
inner; on:conjuncts=1
1
Scan u
Full scan; touched=2
1
Scan t
Index-nested-loop PK bound: id = join; touched=3

# Join sort-elision and the inner per-outer bound are independent decisions and both stay visible.
query ITT nosort
EXPLAIN SELECT u.id, t.id FROM u JOIN t ON t.id = u.tid ORDER BY u.id LIMIT 2
----
0
Limit
limit=2
1
Nested Loop
inner; on:conjuncts=1; ordered: join pk ordered
2
Scan u
Full scan; touched=2
2
Scan t
Index-nested-loop PK bound: id = join; touched=1

# A CROSS JOIN with a WHERE: the residual Filter is the parent; the per-table PK bound shows on t.
query ITT nosort
EXPLAIN SELECT * FROM t CROSS JOIN u WHERE t.id = 1
----
0
Filter
conjuncts=1
1
Nested Loop
cross
2
Scan t
PK bound: id = 1; touched=3
2
Scan u
Full scan; touched=2

# A set operation renders as a Union / Intersect / Except node over its two operand plans.
query ITT nosort
EXPLAIN SELECT v FROM t UNION SELECT id FROM u
----
0
Union
distinct
1
Scan t
Full scan; touched=1
1
Scan u
Full scan; touched=1

# A trailing ORDER BY / LIMIT on a set operation sits above the Union.
query ITT nosort
EXPLAIN SELECT v FROM t UNION ALL SELECT id FROM u ORDER BY 1 LIMIT 3
----
0
Limit
limit=3
1
Sort
keys=1
2
Union
all
3
Scan t
Full scan; touched=1
3
Scan u
Full scan; touched=1

# A derived table is a Subquery node whose inner plan recurses one level deeper.
query ITT nosort
EXPLAIN SELECT * FROM (SELECT v FROM t WHERE id = 1) x
----
0
Subquery x
-
1
Filter
conjuncts=1
2
Scan t
PK bound: id = 1; touched=2

# A WITH renders the WITH node, each CTE (with its materialization mode + body), then the main body.
query ITT nosort
EXPLAIN WITH c AS (SELECT v FROM t) SELECT * FROM c
----
0
WITH
ctes=1
1
CTE c
inlined
2
Scan t
Full scan; touched=1
1
CTE Scan c
-

# A window function adds a Window node carrying the number of window functions.
query ITT nosort
EXPLAIN SELECT sum(v) OVER (PARTITION BY id) FROM t
----
0
Window
funcs=1
1
Scan t
Full scan; touched=2

# A FROM-less query is a single Result node.
query ITT nosort
EXPLAIN SELECT 1
----
0
Result
-

# A set-returning function in FROM is an SRF node.
query ITT nosort
EXPLAIN SELECT * FROM generate_series(1, 5)
----
0
SRF generate_series
-

# A VALUES relation (as a derived table) is a Values leaf carrying its row count.
query ITT nosort
EXPLAIN SELECT * FROM (VALUES (1),(2)) x
----
0
Subquery x
-
1
Values
rows=2

# Composite-PK bounds render consumed members in PK key order, independent of WHERE source order.
statement ok
CREATE TABLE cpk (a i32, b i16, v text, PRIMARY KEY (b, a))

query ITT nosort
EXPLAIN SELECT v FROM cpk WHERE a = 2 AND b = 1
----
0
Filter
conjuncts=2
1
Scan cpk
PK bound: b = 1 and a = 2; touched=3

query ITT nosort
EXPLAIN SELECT a FROM cpk WHERE b = 1 AND a >= 2
----
0
Filter
conjuncts=2
1
Scan cpk
PK bound: b = 1 and a >= 2; touched=2

# A non-leading member alone cannot seed a tuple bound.
query ITT nosort
EXPLAIN SELECT v FROM cpk WHERE a = 2
----
0
Filter
conjuncts=1
1
Scan cpk
Full scan; touched=2

# A promoted comparison wraps the narrow key member rather than comparing in its storage type, so
# it remains residual and cannot seed a tuple bound.
query ITT nosort
EXPLAIN SELECT v FROM cpk WHERE b = 1::i32
----
0
Filter
conjuncts=1
1
Scan cpk
Full scan; touched=2

# Canonical interval sets expose a stable structural disjunct count, independent of runtime values.
statement ok
CREATE TABLE intervals (id i32 PRIMARY KEY, v i32)

statement ok
CREATE INDEX intervals_v_idx ON intervals (v)

query ITT nosort
EXPLAIN SELECT id FROM intervals WHERE id < 3 OR id >= 7
----
0
Filter
conjuncts=1
1
Scan intervals
PK interval set: id; intervals=2; touched=1

query ITT nosort
EXPLAIN SELECT id FROM intervals WHERE v < 20 OR v >= 40
----
0
Filter
conjuncts=1
1
Scan intervals
Index interval set: using intervals_v_idx; intervals=2; touched=2

# A bounded scan can satisfy ORDER BY only through the same index it is already walking.
query ITT nosort
EXPLAIN SELECT id FROM intervals WHERE v >= 20 ORDER BY v LIMIT 2
----
0
Limit
limit=2
1
Filter
conjuncts=1
2
Scan intervals
Index bound: using intervals_v_idx; touched=2; ordered: index order: intervals_v_idx

# Mixed-key disjuncts cannot form a sound interval set and retain the full scan.
query ITT nosort
EXPLAIN SELECT id FROM intervals WHERE id < 3 OR v >= 40
----
0
Filter
conjuncts=1
1
Scan intervals
Full scan; touched=2

# A variable-width leading index key supports point intervals, but not range unions: recovering the
# row-key suffix from an arbitrary text interval still needs the deferred variable-width skip.
statement ok
CREATE TABLE text_intervals (id i32 PRIMARY KEY, v text)

statement ok
CREATE INDEX text_intervals_v_idx ON text_intervals (v)

query ITT nosort
EXPLAIN SELECT id FROM text_intervals WHERE v < 'b' OR v >= 'z'
----
0
Filter
conjuncts=1
1
Scan text_intervals
Full scan; touched=2
