# GROUPING SETS ((a),(b),()) with the GROUPING() function. For the (a) sets b is grouped away so
# GROUPING(b)=1; for (b) sets GROUPING(a)=1; for () both are 1 (GROUPING(a,b)=3). GROUPING(a,b) is
# the 2-bit value 2*GROUPING(a)+GROUPING(b).
# names: a, b, grouping, grouping, grouping, count
query IIIIII nosort
SELECT a, b, GROUPING(a), GROUPING(b), GROUPING(a, b), COUNT(*)
FROM gt GROUP BY GROUPING SETS ((a), (b), ()) ORDER BY a, b
----
1
NULL
0
1
1
3
2
NULL
0
1
1
2
NULL
1
1
0
2
3
NULL
2
1
0
2
2
NULL
NULL
1
1
3
5

# A plain term mixed with GROUPING SETS cross-products: GROUP BY a, GROUPING SETS((b),()) = {(a,b),(a)}.
# cost pins the cross-core contract: 5 storage_row_read + 2 sets x 5 rows x 1 aggregate accumulate
# (COUNT(*), no operand) + 8 row_produced (4 (a,b) groups + 2 (a) groups = 6... see below) — pinned
# to jed's metered value.
# names: a, b, count
query III nosort
SELECT a, b, COUNT(*) FROM gt GROUP BY a, GROUPING SETS ((b), ()) ORDER BY a, b
----
1
1
2
1
2
1
1
NULL
3
2
1
1
2
2
1
2
NULL
2

# GROUP BY () alone is the whole-table grand total (one row), like no GROUP BY.
# names: count, sum
query II nosort
SELECT COUNT(*), SUM(v) FROM gt GROUP BY ()
----
5
150

# Duplicate grouping sets are KEPT — each produces its own rows (GROUPING SETS ((a),(a))).
# names: a, count
query II rowsort
SELECT a, COUNT(*) FROM gt GROUP BY GROUPING SETS ((a), (a))
----
1
3
1
3
2
2
2
2

# HAVING filters the grouped rows of every set (here keep groups of >= 2 rows).
# names: a, b, count
query III nosort
SELECT a, b, COUNT(*) FROM gt GROUP BY ROLLUP(a, b) HAVING COUNT(*) >= 2 ORDER BY a, b
----
1
1
2
1
NULL
3
2
NULL
2
NULL
NULL
5

# Over an empty table only the empty grouping set () emits a row (COUNT 0); the non-empty sets emit
# nothing (spec/design/aggregates.md §12).
statement ok
CREATE TABLE ge (id i32 PRIMARY KEY, a i32, b i32)

# names: a, b, count
query III nosort
SELECT a, b, COUNT(*) FROM ge GROUP BY GROUPING SETS ((a), (b), ()) ORDER BY a, b
----
NULL
NULL
0

# Cost pin: ROLLUP(a) = {(a),()} over 5 rows, one COUNT(*) aggregate. 5 storage_row_read +
# 2 sets x 5 rows accumulate (10) + 3 row_produced (a=1, a=2, grand total) + the aggregate-query
# constant.
# names: a, count
# cost: 19
query II nosort
SELECT a, COUNT(*) FROM gt GROUP BY ROLLUP(a) ORDER BY a
----
1
3
2
2
NULL
5

# --- GROUPING() inside an ORDER BY key (query.order_by_grouping) -----------------------------
# The GROUPING() bitmask may sort the result rows — typically to push the higher-level subtotal /
# grand-total rows (GROUPING = 1) to one end. The call collects into the same grouping set as a
# select-list GROUPING(), is materialized as the ORDER BY key, and sorted over the grouped rows.

# ROLLUP: detail rows (GROUPING(a)=0) first, then the grand total (NULL, GROUPING(a)=1).
# names: a, sum
query II nosort
SELECT a, sum(v) FROM gt GROUP BY ROLLUP (a) ORDER BY GROUPING(a), a
----
1
80
2
70
NULL
150

# CUBE ordered by both GROUPING() bits then the columns: full detail, then a-subtotals, then
# b-subtotals, then the grand total.
# names: a, b, sum
query III nosort
SELECT a, b, sum(v) FROM gt GROUP BY CUBE (a, b) ORDER BY GROUPING(a), GROUPING(b), a, b
----
1
1
60
1
2
20
2
1
30
2
2
40
1
NULL
80
2
NULL
70
NULL
1
90
NULL
2
60
NULL
NULL
150

# A plain GROUP BY: GROUPING(a) is always 0, so it is a constant leading key (rows ordered by a).
# names: a, sum
query II nosort
SELECT a, sum(v) FROM gt GROUP BY a ORDER BY GROUPING(a), a
----
1
80
2
70

# GROUPING() DESC pushes the grand total to the top.
# names: a, sum
query II nosort
SELECT a, sum(v) FROM gt GROUP BY ROLLUP (a) ORDER BY GROUPING(a) DESC, a NULLS FIRST
----
NULL
150
1
80
2
70

# --- error cases ----------------------------------------------------------------------------

# GROUPING of a non-grouping column is 42803 (v is not a grouping expression here).
statement error 42803
SELECT a, GROUPING(v) FROM gt GROUP BY ROLLUP(a)

# GROUPING outside a grouped query (no GROUP BY) is 42803.
statement error 42803
SELECT GROUPING(a) FROM gt

# A select-list column not in ANY grouping set is the ordinary grouping error 42803.
statement error 42803
SELECT a, b, COUNT(*) FROM gt GROUP BY GROUPING SETS ((a), ())

# GROUPING(*) is a syntax error (42601) — * is only valid as the argument of COUNT.
statement error 42601
SELECT GROUPING(*) FROM gt GROUP BY a

# GROUPING with no arguments is a syntax error (42601).
statement error 42601
SELECT GROUPING() FROM gt GROUP BY a

# GROUPING is not a window function — OVER is a syntax error (42601).
statement error 42601
SELECT GROUPING(a) OVER () FROM gt GROUP BY a

# GROUPING SETS combined with a window function runs the window stage over the unioned grouping-set
# rows (aggregates.md §21, aggregates/grouping_sets_window.test). count(*) OVER () is the total number
# of grouped rows (4 here), the same for every row.
# names: a, count, count
query III nosort
SELECT a, COUNT(*), count(*) OVER () FROM gt GROUP BY GROUPING SETS ((a), (b)) ORDER BY a NULLS LAST, COUNT(*)
----
1
3
4
2
2
4
NULL
2
4
NULL
3
4

# A GROUP BY whose grouping sets exceed the limit (CUBE of 13 columns = 8192 > 4096) is 54001.
statement error 54001
SELECT a FROM gt GROUP BY CUBE (a, a, a, a, a, a, a, a, a, a, a, a, a)
