# GROUPING SETS / ROLLUP / CUBE and the GROUPING() function (spec/design/aggregates.md §12).
# `GROUP BY` may name several grouping sets at once: GROUPING SETS ((a),(b),()) computes each set's
# grouping independently and unions the results; ROLLUP(a,b) is sugar for the prefixes
# {(a,b),(a),()}; CUBE(a,b) for every subset {(a,b),(a),(b),()}; a plain term mixed with these
# cross-products (GROUP BY a, GROUPING SETS((b),()) = {(a,b),(a)}). A column not grouped in the set a
# row came from projects as NULL. GROUPING(c1,...,ck) returns an integer bitmask: bit (k-1-j) is 1
# iff c_j was grouped away (NULL because not in this set), 0 if actually grouped. Columns only (the
# same narrowing as plain GROUP BY); GROUPING() args must be grouping columns (else 42803).
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.aggregates, query.group_by, query.having, query.grouping_sets, query.window, query.order_by, query.order_by_expr, query.order_by_grouping, types.i32, resource.cost_metering

statement ok
CREATE TABLE gt (id i32 PRIMARY KEY, a i32, b i32, v i32)

statement ok
INSERT INTO gt VALUES (1,1,1,10),(2,1,2,20),(3,2,1,30),(4,2,2,40),(5,1,1,50)

# ROLLUP(a,b) = grouping sets {(a,b),(a),()}: the (a,b) groups, then the per-a subtotals (b NULL),
# then the grand total (a,b both NULL). v = {10,20,30,40,50}.
# names: a, b, count, sum
query IIII nosort
SELECT a, b, COUNT(*), SUM(v) FROM gt GROUP BY ROLLUP(a, b) ORDER BY a, b
----
