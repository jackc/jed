# Aggregate AVG — always decimal, computed as sum::decimal / count::decimal using the exact
# decimal division (select_div_scale + half-away rounding, spec/design/decimal.md §4;
# aggregates.md §3). The running sum is decimal even for integer input. NULL inputs skipped;
# an empty/all-NULL group -> NULL. Output name `avg`. The rendered scale (16 here) is fixed by
# select_div_scale — a cross-core determinism contract (decimal.md §7.2).
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.aggregates, types.i32, types.decimal, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, a i32)

statement ok
INSERT INTO t VALUES (1, 10), (2, 20), (3, 30)

# AVG over integers -> decimal. 60 / 3 = 20, rendered at the division scale (16 frac digits).
# names: avg
# cost: 8
query D nosort
SELECT AVG(a) FROM t
----
20.0000000000000000

# 10 / 4 = 2.5 at scale 16.
statement ok
CREATE TABLE t4 (id i32 PRIMARY KEY, a i32)

statement ok
INSERT INTO t4 VALUES (1, 1), (2, 2), (3, 3), (4, 4)

# names: avg
query D nosort
SELECT AVG(a) FROM t4
----
2.5000000000000000

# AVG over decimal: (1.00 + 2.00) / 2 = 1.5 at scale 16 (>= the operand scale).
statement ok
CREATE TABLE tdec (id i32 PRIMARY KEY, d numeric(10,2))

statement ok
INSERT INTO tdec VALUES (1, 1.00), (2, 2.00)

# names: avg
query D nosort
SELECT AVG(d) FROM tdec
----
1.5000000000000000

# NULL inputs skipped: AVG over the present rows. (10 + 30) / 2 = 20.
statement ok
CREATE TABLE tmix (id i32 PRIMARY KEY, a i32)

statement ok
INSERT INTO tmix VALUES (1, 10), (2, NULL), (3, 30)

# names: avg
query D nosort
SELECT AVG(a) FROM tmix
----
20.0000000000000000

# All-NULL group: AVG -> NULL (count 0, no division).
statement ok
CREATE TABLE tnull (id i32 PRIMARY KEY, a i32)

statement ok
INSERT INTO tnull VALUES (1, NULL), (2, NULL)

# names: avg
query D nosort
SELECT AVG(a) FROM tnull
----
NULL

# Empty table: AVG -> NULL as ONE row.
statement ok
CREATE TABLE e (id i32 PRIMARY KEY, a i32)

# names: avg
query D nosort
SELECT AVG(a) FROM e
----
NULL

# G29 — AVG over LARGE-coefficient decimals accrues the decimal_work cost unit (the per-digit-slab
# arithmetic charge, cost.md §2): the running decimal sum + the final division over two ~17-digit
# values cost more than a small-decimal AVG would, proving decimal_work is metered in this path.
statement ok
CREATE TABLE bd (id i32 PRIMARY KEY, d numeric)

statement ok
INSERT INTO bd VALUES (1, 123456789012345.67), (2, 987654321098765.43)

# names: avg
# cost: 14
query D nosort
SELECT AVG(d) FROM bd
----
555555555055555.5500
