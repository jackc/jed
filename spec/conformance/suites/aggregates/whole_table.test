# Whole-table aggregation (no GROUP BY) — multiple aggregates in one row, aggregates mixed
# with constants/operators, and the misplacement errors (spec/design/aggregates.md §4/§5/§6).
# An aggregate in WHERE / nested in another aggregate / a non-aggregated column alongside an
# aggregate are all 42803; an unknown function is 42883. (DISTINCT in an aggregate is supported
# — aggregates/distinct.test.)
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.aggregates, types.i32, types.decimal, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, a i32)

statement ok
INSERT INTO t VALUES (1, 10), (2, 20), (3, 30)

# Four aggregates -> one row. 3 scanned + 3x4 accumulate + 1 produced = 16.
# names: count, sum, min, max
# cost: 17
query IIII nosort
SELECT COUNT(*), SUM(a), MIN(a), MAX(a) FROM t
----
3
60
10
30

# Aggregate combined with an operator: SUM(a) + 1 = 61. The `+` is one interior projection
# node charged once per emitted group row. Output name is ?column? (an expression, not a
# bare aggregate). 3 scanned + 3 accumulate + 1 produced + 1 operator_eval = 8.
# names: ?column?
# cost: 9
query I nosort
SELECT SUM(a) + 1 FROM t
----
61

# A constant alongside an aggregate is fine (a constant is not a non-aggregated column).
# names: count, ?column?
query II nosort
SELECT COUNT(*), 1 FROM t
----
3
1

# A non-aggregated COLUMN alongside an aggregate, with no GROUP BY, is 42803 (§4 degenerate
# case of the grouping-error rule).
statement error 42803
SELECT a, COUNT(*) FROM t

# An aggregate in WHERE is 42803 (WHERE filters input rows, before grouping; §6).
statement error 42803
SELECT COUNT(*) FROM t WHERE SUM(a) > 0

# A nested aggregate is 42803.
statement error 42803
SELECT SUM(COUNT(a)) FROM t

# An unknown function name is 42883 (undefined_function).
statement error 42883
SELECT bogus(a) FROM t

# DISTINCT inside an aggregate (COUNT(DISTINCT x)) is supported — see aggregates/distinct.test.

# G29 — every aggregate over an EMPTY table yields ONE row: COUNT is 0 but SUM/AVG/MIN/MAX are all
# NULL (count is the only aggregate with an identity element). Nothing is scanned; 1 produced = 1.
statement ok
CREATE TABLE e (id i32 PRIMARY KEY, a i32)

# names: count, sum, avg, min, max
# cost: 1
query IIDII nosort
SELECT COUNT(*), SUM(a), AVG(a), MIN(a), MAX(a) FROM e
----
0
NULL
NULL
NULL
NULL

# The COUNT(*)=n while everything-else-NULL contrast over an ALL-NULL column in one row: COUNT(*)
# counts rows (3), COUNT(a) counts non-NULL values (0), and SUM/AVG/MIN/MAX skip the NULLs to NULL.
# 1 page + 3 scan + 3x6 accumulate + 1 produced = 23.
statement ok
CREATE TABLE an (id i32 PRIMARY KEY, a i32)

statement ok
INSERT INTO an VALUES (1, NULL), (2, NULL), (3, NULL)

# names: count, count, sum, avg, min, max
# cost: 23
query IIIDII nosort
SELECT COUNT(*), COUNT(a), SUM(a), AVG(a), MIN(a), MAX(a) FROM an
----
3
0
NULL
NULL
NULL
NULL

# LIMIT / OFFSET apply to the whole-table aggregate's SINGLE grand-total row at emission, exactly
# like any other query result. A `LIMIT 0` (or an OFFSET past the one row) emits ZERO rows — so no
# row_produced is charged — even though the aggregate itself still scans + accumulates over the
# whole table. 1 page + 3 scan + 3 accumulate + 0 produced = 7.
# cost: 7
query I nosort
SELECT COUNT(*) FROM t LIMIT 0
----

# OFFSET 1 skips the one grand-total row -> zero rows, same cost as LIMIT 0 (nothing produced).
# cost: 7
query I nosort
SELECT SUM(a) FROM t OFFSET 1
----

# A LIMIT at or above the one row keeps it (the row is produced). 1 + 3 + 3 + 1 = 8.
# cost: 8
query I nosort
SELECT COUNT(*) FROM t LIMIT 5
----
3
