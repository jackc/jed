# Whole-table aggregation (no GROUP BY) — multiple aggregates in one row, aggregates mixed
# with constants/operators, and the misplacement errors (spec/design/aggregates.md §4/§5/§6).
# An aggregate in WHERE / nested in another aggregate / a non-aggregated column alongside an
# aggregate are all 42803; an unknown function is 42883; DISTINCT in an aggregate is 42601.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.aggregates, types.int32, resource.cost_metering

statement ok
CREATE TABLE t (id int32 PRIMARY KEY, a int32)

statement ok
INSERT INTO t VALUES (1, 10), (2, 20), (3, 30)

# Four aggregates -> one row. 3 scanned + 3x4 accumulate + 1 produced = 16.
# names: count, sum, min, max
# cost: 17
query IIII nosort
SELECT COUNT(*), SUM(a), MIN(a), MAX(a) FROM t
----
3
60
10
30

# Aggregate combined with an operator: SUM(a) + 1 = 61. The `+` is one interior projection
# node charged once per emitted group row. Output name is ?column? (an expression, not a
# bare aggregate). 3 scanned + 3 accumulate + 1 produced + 1 operator_eval = 8.
# names: ?column?
# cost: 9
query I nosort
SELECT SUM(a) + 1 FROM t
----
61

# A constant alongside an aggregate is fine (a constant is not a non-aggregated column).
# names: count, ?column?
query II nosort
SELECT COUNT(*), 1 FROM t
----
3
1

# A non-aggregated COLUMN alongside an aggregate, with no GROUP BY, is 42803 (§4 degenerate
# case of the grouping-error rule).
statement error 42803
SELECT a, COUNT(*) FROM t

# An aggregate in WHERE is 42803 (WHERE filters input rows, before grouping; §6).
statement error 42803
SELECT COUNT(*) FROM t WHERE SUM(a) > 0

# A nested aggregate is 42803.
statement error 42803
SELECT SUM(COUNT(a)) FROM t

# An unknown function name is 42883 (undefined_function).
statement error 42883
SELECT bogus(a) FROM t

# DISTINCT inside an aggregate is deferred -> 42601 (parse-time).
statement error 42601
SELECT COUNT(DISTINCT a) FROM t
