# DISTINCT inside an aggregate — COUNT(DISTINCT x), SUM/AVG/MIN/MAX(DISTINCT x)
# (spec/design/aggregates.md §5). The aggregate folds only the DISTINCT non-NULL argument
# values: dedup happens before the fold, value-canonically (the same Eq/Hash the group-key
# bucketing uses, so 1.5 == 1.50 and -0.0 == 0.0), keeping the first occurrence in scan order.
# NULL inputs are skipped as always; an empty / all-NULL group is COUNT 0, the rest NULL.
# DISTINCT on a window function is 0A000, on a scalar function 42809; `agg(DISTINCT *)` and
# `agg(DISTINCT)` (no argument) are 42601 syntax errors; wrong argument count stays 42883.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.aggregates, query.group_by, query.aggregate_distinct, types.i32, types.decimal, types.f64, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, a i32, b i32)

statement ok
INSERT INTO t VALUES (1,1,10),(2,1,20),(3,2,10),(4,2,10),(5,3,NULL),(6,NULL,5)

# COUNT(DISTINCT) over duplicates + NULLs: a = {1,1,2,2,3,NULL} -> 3 distinct non-NULL.
# Only storage_row_read (6) + aggregate_accumulate (6) + row_produced (1); a bare-column
# DISTINCT argument is a leaf (no operator_eval), and dedup/finalize are unmetered (§8).
# names: count
# cost: 14
query I nosort
SELECT COUNT(DISTINCT a) FROM t
----
3

# All five aggregates with DISTINCT in one query, contrasted with the non-DISTINCT COUNT(a)
# and COUNT(*): distinct b = {10,20,5} (count 3, sum 35), avg 35/3 at scale 16, min/max over
# distinct a = {1,2,3}; COUNT(a) skips the one NULL (5), COUNT(*) counts all 6 rows.
# names: count, count, sum, sum, avg, min, max, count, count
query IIIIDIIII nosort
SELECT COUNT(DISTINCT a), COUNT(DISTINCT b), SUM(DISTINCT a), SUM(DISTINCT b),
       AVG(DISTINCT b), MIN(DISTINCT a), MAX(DISTINCT a), COUNT(a), COUNT(*) FROM t
----
3
3
6
35
11.6666666666666667
1
3
5
6

# DISTINCT per GROUP: a=1 -> b {10,20} = 2; a=2 -> b {10,10} = 1; a=3 -> b {NULL} = 0;
# a=NULL -> b {5} = 1. NULL group sorts last (PG default ORDER BY).
# names: a, count
query II nosort
SELECT a, COUNT(DISTINCT b) FROM t GROUP BY a ORDER BY a
----
1
2
2
1
3
0
NULL
1

# An all-NULL / empty distinct group: COUNT(DISTINCT) is 0, SUM/AVG(DISTINCT) are NULL.
# names: count, sum, avg
query IID nosort
SELECT COUNT(DISTINCT a), SUM(DISTINCT a), AVG(DISTINCT a) FROM t WHERE a IS NULL AND a = 99
----
0
NULL
NULL

# --- decimal DISTINCT: value-canonical dedup (1.5 == 1.50) ----------------------------------
statement ok
CREATE TABLE td (id i32 PRIMARY KEY, d numeric)

statement ok
INSERT INTO td VALUES (1, 1.5), (2, 1.50), (3, 2.5), (4, 2.5)

# 1.5 and 1.50 collapse to one value -> distinct {1.5, 2.5}: count 2, sum 4.0, avg 4.0/2 = 2
# at the division scale 16.
# names: count, sum, avg
query IDD nosort
SELECT COUNT(DISTINCT d), SUM(DISTINCT d), AVG(DISTINCT d) FROM td
----
2
4.0
2.0000000000000000

# --- float DISTINCT: -0.0 and 0.0 collapse (the float total-order canonical form) -----------
statement ok
CREATE TABLE tf (id i32 PRIMARY KEY, f f64)

statement ok
INSERT INTO tf VALUES (1, 1.5), (2, 1.5), (3, 2.5), (4, 0.0), (5, -0.0)

# distinct {1.5, 2.5, 0.0} (the two zeros are one value): count 3, sum 4, min 0, max 2.5.
# names: count, sum, min, max
query IRRR nosort
SELECT COUNT(DISTINCT f), SUM(DISTINCT f), MIN(DISTINCT f), MAX(DISTINCT f) FROM tf
----
3
4
0
2.5

# --- error cases ----------------------------------------------------------------------------

# DISTINCT is not implemented for window functions (PG 0A000).
statement error 0A000
SELECT COUNT(DISTINCT a) OVER () FROM t

# DISTINCT on a non-aggregate (scalar) function is 42809 (wrong_object_type).
statement error 42809
SELECT abs(DISTINCT a) FROM t

# COUNT(DISTINCT *) is a syntax error (42601) — DISTINCT cannot combine with *.
statement error 42601
SELECT COUNT(DISTINCT *) FROM t

# DISTINCT with no argument is a syntax error (42601).
statement error 42601
SELECT COUNT(DISTINCT) FROM t

# Wrong argument count is still 42883 (no count(int, int) overload), DISTINCT or not.
statement error 42883
SELECT COUNT(DISTINCT a, b) FROM t
