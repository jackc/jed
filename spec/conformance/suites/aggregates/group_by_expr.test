# GROUP BY by a select-list ordinal, an output alias, or a general expression — not just a bare
# column (spec/design/aggregates.md §15). An expression key is materialized (evaluated per row) and
# a select-list / HAVING / ORDER BY expression that structurally matches it resolves to the group
# value; an aggregate operand stays per-row. A bare integer is an ordinal (GROUP BY 1); a bare name
# resolves an INPUT column first, then an output alias (PG, opposite of ORDER BY).
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.aggregates, query.group_by, query.group_by_expr, query.having, query.grouping_sets, types.i32, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, a i32, b i32)

statement ok
INSERT INTO t VALUES (1,1,10),(2,1,20),(3,2,30),(4,2,30),(5,3,40)

# GROUP BY ordinal (1-based select-list position): group by column a.
# names: a, count
query II nosort
SELECT a, count(*) FROM t GROUP BY 1 ORDER BY 1
----
1
2
2
2
3
1

# GROUP BY a general expression a+b; the projected a+b resolves to the group value.
# names: s, count
query II nosort
SELECT a+b AS s, count(*) FROM t GROUP BY a+b ORDER BY 1
----
11
1
21
1
32
2
43
1

# GROUP BY by output alias s (no input column named s, so the alias is used).
# names: s, count
query II nosort
SELECT a+b AS s, count(*) FROM t GROUP BY s ORDER BY 1
----
11
1
21
1
32
2
43
1

# GROUP BY ordinal pointing at a COMPUTED select item ((a+b)*2): the ordinal resolves to the
# expression, materialized as the group key.
# names: s2, count
query II nosort
SELECT (a+b)*2 AS s2, count(*) FROM t GROUP BY 1 ORDER BY 1
----
22
1
42
1
64
2
86
1

# An aggregate operand under GROUP BY a+b stays PER ROW: in the group a+b=32 there are two rows
# (a+b=32 each), so sum(a+b)=64 — the operand is not collapsed to the single group value.
# names: s, sum
query II nosort
SELECT a+b AS s, sum(a+b) FROM t GROUP BY a+b ORDER BY 1
----
11
11
21
21
32
64
43
43

# ORDER BY the grouping expression even when it is not in the select list.
# names: count
query I nosort
SELECT count(*) FROM t GROUP BY a+b ORDER BY a+b
----
1
1
2
1

# HAVING references the grouping expression.
# names: s, count
query II nosort
SELECT a+b AS s, count(*) FROM t GROUP BY a+b HAVING a+b > 20 ORDER BY 1
----
21
1
32
2
43
1

# A bare integer in GROUP BY is an ordinal, but 1+1 is a constant expression -> one group (all
# rows), so a non-aggregated column would be illegal; count(*) over the single group is 5.
# names: count
query I nosort
SELECT count(*) FROM t GROUP BY 1+1
----
5

# Expression keys compose with ROLLUP: ROLLUP(a, a+b) over the materialized a+b key.
# names: a, s, count
query III nosort
SELECT a, a+b AS s, count(*) FROM t GROUP BY ROLLUP(a, a+b) ORDER BY a NULLS LAST, s NULLS LAST
----
1
11
1
1
21
1
1
NULL
2
2
32
2
2
NULL
2
3
43
1
3
NULL
1
NULL
NULL
5

# An ordinal out of range is 42P10.
statement error 42P10
SELECT a, count(*) FROM t GROUP BY 5

# A select column that is not a grouping key is still 42803 (grouped by a+b, but a alone projected).
statement error 42803
SELECT a, count(*) FROM t GROUP BY a+b

# Bare-name precedence: with `a AS b`, GROUP BY b binds the INPUT column b (not the alias), so the
# projected a (= a AS b) is not a grouping key -> 42803 (PG).
statement error 42803
SELECT a AS b, count(*) FROM t GROUP BY b
