# Functional-dependency grouping (spec/design/aggregates.md §16, PG). GROUP BY a base table's full
# primary key lets any column of that table appear ungrouped — the PK functionally determines it, so
# there is one value per group. Holds across a join and for a composite PK (every member grouped). A
# partial PK, or a column of a table whose PK is not grouped, is still 42803.
# requires: ddl.create_table, ddl.primary_key, ddl.composite_primary_key, dml.insert, query.select, query.aggregates, query.group_by, query.group_by_functional_dependency, query.having, query.join_inner, types.i32

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, a i32, b i32)

statement ok
INSERT INTO t VALUES (1,1,10),(2,1,20),(3,2,30)

# GROUP BY the PK -> all of t's columns (a, b) are groupable without appearing in GROUP BY.
# names: id, a, b, count
query IIII nosort
SELECT id, a, b, count(*) FROM t GROUP BY id ORDER BY id
----
1
1
10
1
2
1
20
1
3
2
30
1

# Expressions over functionally-dependent columns are allowed too (a + b).
# names: id, s
query II nosort
SELECT id, a+b AS s FROM t GROUP BY id ORDER BY id
----
1
11
2
21
3
32

# HAVING and ORDER BY may reference functionally-dependent columns.
# names: id
query I nosort
SELECT id FROM t GROUP BY id HAVING b > 15 ORDER BY a
----
2
3

# Composite primary key: GROUP BY both members makes v groupable.
statement ok
CREATE TABLE ck (x i32, y i32, v i32, PRIMARY KEY (x, y))

statement ok
INSERT INTO ck VALUES (1,1,100),(1,2,200),(2,1,300)

# names: x, y, v, count
query IIII nosort
SELECT x, y, v, count(*) FROM ck GROUP BY x, y ORDER BY x, y
----
1
1
100
1
1
2
200
1
2
1
300
1

# A partial composite PK (only x grouped) does NOT determine v -> 42803.
statement error 42803
SELECT x, v FROM ck GROUP BY x

# Across a join: GROUP BY t's PK makes t's columns dependent (constant per t.id), even with multiple
# matching u rows; u's columns are NOT dependent (u's PK not grouped).
statement ok
CREATE TABLE u (uid i32 PRIMARY KEY, tid i32, w i32)

statement ok
INSERT INTO u VALUES (10,1,5),(11,1,6),(12,2,7)

# names: id, a, count
query III nosort
SELECT t.id, t.a, count(*) FROM t JOIN u ON u.tid = t.id GROUP BY t.id ORDER BY t.id
----
1
1
2
2
1
1

# u.w is not functionally dependent on t.id -> 42803.
statement error 42803
SELECT t.id, u.w FROM t JOIN u ON u.tid = t.id GROUP BY t.id
