# INTERSECT / INTERSECT ALL (spec/design/grammar.md §25): rows present in BOTH operands. The
# bare form is distinct (one row per key present in both); INTERSECT ALL keeps min(m, n) copies,
# where m, n are a row's multiplicity in the left and right operand. Matching is NULL-safe
# (NULL == NULL) and value-canonical (1.0 == 1, int converts to decimal first). Output columns
# count + names from the left operand. Cost = lhs.cost + rhs.cost (the match is unmetered) —
# cost.md §3.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.intersect, query.where_eq, query.comparison_order, query.order_by, types.int32, types.decimal, resource.cost_metering

statement ok
CREATE TABLE l (id int32 PRIMARY KEY, k int32)

statement ok
CREATE TABLE r (id int32 PRIMARY KEY, k int32)

# l.k multiplicities: 1->2, 2->1, 3->1 ; r.k multiplicities: 1->3, 2->1
statement ok
INSERT INTO l VALUES (1, 1), (2, 1), (3, 2), (4, 3)

statement ok
INSERT INTO r VALUES (1, 1), (2, 1), (3, 1), (4, 2)

# INTERSECT (distinct): keys present in both are {1, 2}. cost = 2*4 + 2*4 = 16.
# names: k
# cost: 16
query I rowsort
SELECT k FROM l INTERSECT SELECT k FROM r
----
1
2

# INTERSECT DISTINCT — explicit spelling of the bare form.
# names: k
query I rowsort
SELECT k FROM l INTERSECT DISTINCT SELECT k FROM r
----
1
2

# INTERSECT ALL keeps min(m, n): key 1 -> min(2,3)=2, key 2 -> min(1,1)=1, key 3 -> min(1,0)=0.
# Result {1, 1, 2}. cost still 16.
# names: k
# cost: 16
query I rowsort
SELECT k FROM l INTERSECT ALL SELECT k FROM r
----
1
1
2

# Trailing ORDER BY over the combined result.
# names: k
# cost: 16
query I nosort
SELECT k FROM l INTERSECT SELECT k FROM r ORDER BY k
----
1
2

# Empty intersection: left filtered to nothing. left = 4 scan + 4 compare + 0 produced = 8;
# right = 2*4 = 8; total 16. No rows.
# names: k
# cost: 16
query I rowsort
SELECT k FROM l WHERE k > 100 INTERSECT SELECT k FROM r
----

# --- NULL identity: NULL intersects NULL --------------------------------------------------------
statement ok
CREATE TABLE ln (id int32 PRIMARY KEY, k int32)

statement ok
CREATE TABLE rn (id int32 PRIMARY KEY, k int32)

statement ok
INSERT INTO ln VALUES (1, 5), (2, NULL)

statement ok
INSERT INTO rn VALUES (1, NULL), (2, 9)

# Common key is NULL only (5 and 9 are unique to a side). One NULL row. cost = 2*2 + 2*2 = 8.
# names: k
# cost: 8
query I rowsort
SELECT k FROM ln INTERSECT SELECT k FROM rn
----
NULL

# --- integer <-> decimal: the representative row is the LEFT operand's value -------------------
statement ok
CREATE TABLE ld (id int32 PRIMARY KEY, n decimal(10,1))

statement ok
CREATE TABLE ri (id int32 PRIMARY KEY, n int32)

statement ok
INSERT INTO ld VALUES (1, 1.0), (2, 2.5)

statement ok
INSERT INTO ri VALUES (1, 1), (2, 3)

# ld.n {1.0, 2.5}; ri.n converts to decimal {1, 3}. 1.0 == 1 matches; the emitted representative
# is the LEFT (ld) value `1.0`. Output type decimal. cost = 2*2 + 2*2 = 8.
# names: n
# cost: 8
query D rowsort
SELECT n FROM ld INTERSECT SELECT n FROM ri
----
1.0
