# Reader refcounting + a rolled-back writer across the watermark (spec/design/concurrency-testing.md
# §4, transactions.md §5/§8/§10). A second CONCURRENCY-format file: `# format: concurrency` routes
# it to the schedule runner. It complements snapshot_isolation.test by pinning the cases that file
# does not — two readers pinning the SAME committed version (the live-registry refcount), a writer
# that ROLLS BACK (publishing nothing, version unchanged), and the watermark held back until the
# LAST reader of a version closes. Deterministic on every core (the order fully determines output,
# §2): a single-threaded core runs it sequentially; Go/Rust also run it stepped-threaded under the
# race detector, where the same schedule drives the real concurrent code paths (§4.3).
# format: concurrency
# requires: txn.shared, txn.read_handle, txn.watermark, ddl.create_table, ddl.primary_key, dml.insert, query.select, query.order_by, types.i32

# --- seed one row, committed as version 1 -----------------------------------
open w write
on w statement ok
CREATE TABLE t (id i32 PRIMARY KEY)
on w statement ok
INSERT INTO t VALUES (1)
commit w
expect version 1

# --- two readers pin the SAME version 1 (refcount 2 in the live registry) ----
open r1 read
open r2 read
expect oldest_live 1

# --- a writer rolls back: nothing is published, the version is unchanged ------
open w2 write
on w2 statement ok
INSERT INTO t VALUES (2)
rollback w2
expect version 1

# both pinned readers still see only the one committed row (the rollback never showed)
on r1 query I rowsort
SELECT id FROM t
----
1
on r2 query I rowsort
SELECT id FROM t
----
1

# --- closing ONE of the two v1 readers must NOT advance the watermark ---------
close r1
expect oldest_live 1        # r2 still pins v1 → held at 1

# --- a fresh writer commits version 2 while r2 stays pinned -------------------
open w3 write
on w3 statement ok
INSERT INTO t VALUES (3)
commit w3
expect version 2
expect oldest_live 1        # r2 still pins v1 → watermark held at 1

# the still-pinned reader sees only its snapshot (version 1: one row)
on r2 query I rowsort
SELECT id FROM t
----
1

# --- closing the last v1 reader lets the watermark jump to the committed version
close r2
expect oldest_live 2
expect version 2
