# A composite-typed column on a SHARED temp table is CROSS-SESSION (spec/design/temp-tables.md §4/§8,
# concurrency-testing.md §4). The shared temp table's rows live in the database-wide shared snapshot,
# and each row's composite VALUE is decoded through the store's self-contained ColType tree (built once
# against the persistent type catalog when the table was staged, composite.md §4) — so a composite value
# written by one session decodes byte-identically when a DIFFERENT session reads it, with no per-read
# type-catalog lookup. The composite TYPE is persistent (visible to every session); only the shared temp
# ROWS are the cross-session surface here. The single-handle suites/ddl/temp_composite.test cannot
# express two sessions; this pins the cross-session composite-value visibility it cannot. Shared-temp
# writes ride the single-writer gate and become visible only at COMMIT (the two-root commit, §5), so the
# order below fully determines every output and the file is deterministic on every core.
#
# A core without the shared handle declares none of txn.shared/read_handle and SKIPS this file before
# parsing any record (the capability gate, conformance.md §3).
# format: concurrency
# requires: txn.shared, txn.read_handle, ddl.shared_temp_table, types.composite, ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.order_by, types.i32, types.text

# --- w creates the persistent composite type + a SHARED temp table using it, inserts two rows -------
open w write
on w statement ok
CREATE TYPE addr AS (street text, zip i32)
on w statement ok
CREATE SHARED TEMP TABLE places (id i32 PRIMARY KEY, home addr)
on w statement ok
INSERT INTO places VALUES (1, ROW('Main', 90210)), (2, ROW('Oak', NULL))
commit w
expect version 1

# --- a DIFFERENT writer appends a composite row to the SHARED temp table --------------------------
open w2 write
on w2 statement ok
INSERT INTO places VALUES (3, ROW('Elm', 12345))
commit w2
expect version 2

# --- a fresh reader sees all three composite values, decoded ACROSS the two sessions ----------------
open r read
on r query IT rowsort
SELECT id, home FROM places
----
1
(Main,90210)
2
(Oak,)
3
(Elm,12345)
close r
