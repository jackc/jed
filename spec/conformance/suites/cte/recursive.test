# Recursive common table expressions (spec/design/recursive-cte.md): WITH RECURSIVE name [(cols)]
# AS (non_recursive_term UNION [ALL] recursive_term) <query>. A recursive CTE references its own
# name in the recursive term and is evaluated to a fixpoint by the working-table method. UNION ALL
# keeps every row; UNION (distinct) drops rows duplicating any already-emitted row (so a cyclic
# walk terminates). Column types are fixed by the non-recursive term. Rows verified against the
# live PostgreSQL 18 oracle; the cost assertions are jed's deterministic cross-core contract
# (spec/design/cost.md §3, recursive-cte.md §5).
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.select_star, query.order_by, query.table_alias, query.qualified_column, query.cross_join, query.join_inner, query.union, query.aggregates, query.cte, query.cte_recursive, types.i32, resource.cost_metering

# A simple counter — UNION ALL, terminated by a WHERE on the recursive term.
# names: n
query I nosort
WITH RECURSIVE c(n) AS (SELECT 1 UNION ALL SELECT n + 1 FROM c WHERE n < 5) SELECT n FROM c ORDER BY n
----
1
2
3
4
5

# UNION (distinct) terminates a cycle: (n+1) % 3 revisits {0,1,2} but the de-duplication empties the
# working table once every value has been seen.
# names: n
query I nosort
WITH RECURSIVE c(n) AS (SELECT 1 UNION SELECT (n + 1) % 3 FROM c) SELECT n FROM c ORDER BY n
----
0
1
2

# Multi-column recursion — a running factorial.
# names: i, acc
query II nosort
WITH RECURSIVE f(i, acc) AS (
  SELECT 1, 1
  UNION ALL
  SELECT i + 1, acc * (i + 1) FROM f WHERE i < 5
)
SELECT i, acc FROM f ORDER BY i
----
1
1
2
2
3
6
4
24
5
120

# The non-recursive term may itself be a UNION (a left-deep `a UNION ALL b UNION ALL <recursive>`
# makes `a UNION ALL b` the combined anchor): seed {1,2}, then each iteration adds n+1 while n < 4.
# names: n
query I nosort
WITH RECURSIVE c(n) AS (
  SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT n + 1 FROM c WHERE n < 4
)
SELECT n FROM c ORDER BY n
----
1
2
2
3
3
4
4

# Graph reachability — the recursive term JOINs the self-reference to a base table; UNION dedups so
# the walk terminates. edges 1→2, 2→3, 3→4, 1→5: everything reachable from 1.
statement ok
CREATE TABLE edge (a i32, b i32, PRIMARY KEY (a, b))

statement ok
INSERT INTO edge VALUES (1, 2), (2, 3), (3, 4), (1, 5)

# names: n
query I nosort
WITH RECURSIVE reach(n) AS (
  SELECT 1
  UNION
  SELECT b FROM edge JOIN reach ON edge.a = reach.n
)
SELECT n FROM reach ORDER BY n
----
1
2
3
4
5

# A hierarchy walk carrying a derived depth column.
statement ok
CREATE TABLE org (id i32 PRIMARY KEY, mgr i32)

statement ok
INSERT INTO org VALUES (1, NULL), (2, 1), (3, 1), (4, 2), (5, 4)

# names: id, depth
query II nosort
WITH RECURSIVE chain(id, depth) AS (
  SELECT id, 0 FROM org WHERE mgr IS NULL
  UNION ALL
  SELECT o.id, c.depth + 1 FROM org o JOIN chain c ON o.mgr = c.id
)
SELECT id, depth FROM chain ORDER BY id
----
1
0
2
1
3
1
4
2
5
3

# A recursive CTE is ALWAYS materialized: referenced twice in the main query, both references scan
# the same buffered result (a self-cross-join of the three rows).
# names: x, y
query II rowsort
WITH RECURSIVE c(n) AS (SELECT 1 UNION ALL SELECT n + 1 FROM c WHERE n < 3)
SELECT a.n AS x, b.n AS y FROM c a CROSS JOIN c b
----
1
1
1
2
1
3
2
1
2
2
2
3
3
1
3
2
3
3

# A later non-recursive CTE may reference an earlier recursive one (forward visibility, cte.md §2).
# names: m
query I nosort
WITH RECURSIVE c(n) AS (SELECT 1 UNION ALL SELECT n + 1 FROM c WHERE n < 3),
               d AS (SELECT n * 10 AS m FROM c)
SELECT m FROM d ORDER BY m
----
10
20
30

# An aggregate in the MAIN query over a recursive CTE (the recursion ends, then count).
# names: cnt
query I nosort
WITH RECURSIVE c(n) AS (SELECT 1 UNION ALL SELECT n + 1 FROM c WHERE n < 4) SELECT count(*) AS cnt FROM c
----
4

# A CTE in a RECURSIVE list that does NOT reference itself is an ordinary non-recursive CTE.
# names: n
query I nosort
WITH RECURSIVE c AS (SELECT 1 AS n) SELECT n FROM c
----
1

# --- cost contract (spec/design/cost.md §3, recursive-cte.md §5) ---

# Iterate-to-fixpoint cost: anchor SELECT 1 = 1 row_produced. Each of the 4 producing iterations
# scans the 1-row working table (1 cte_scan_row), evaluates WHERE n<5 (1 operator_eval) and the
# projection n+1 (1 operator_eval), and emits 1 row (1 row_produced) = 4; the 5th iteration scans
# {5}, fails n<5 and emits nothing = 2. The main reference scans the 5-row materialized buffer
# (5 cte_scan_row) and projects n (5 row_produced) = 10. Total 1 + 4*4 + 2 + 10 = 29.
# cost: 29
query I nosort
WITH RECURSIVE c(n) AS (SELECT 1 UNION ALL SELECT n + 1 FROM c WHERE n < 5) SELECT n FROM c ORDER BY n
----
1
2
3
4
5
