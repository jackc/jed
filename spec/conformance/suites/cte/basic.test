# Non-recursive common table expressions (spec/design/cte.md): WITH name [(cols)] AS [NOT]
# MATERIALIZED (query) [, ...] <query>. A CTE is a named, statement-local relation the FROM clause
# references like a table. Evaluation follows PostgreSQL's hybrid rule — a single-reference CTE is
# INLINED, a multi-reference (or MATERIALIZED) one is MATERIALIZED (spec/design/cost.md §3). Rows
# verified against the live PostgreSQL 18 oracle; the cost assertions are jed's deterministic
# cross-core contract (spec/design/cost.md §3 "cte_scan_row").
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.select_star, query.order_by, query.table_alias, query.qualified_column, query.cross_join, query.union, query.aggregates, query.subquery_scalar, query.cte, types.i32, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, n i32)

statement ok
INSERT INTO t VALUES (1, 10), (2, 20), (3, 30)

# Single reference → INLINED. The CTE exposes t's rows as the relation `c`.
# names: id, n
query II nosort
WITH c AS (SELECT id, n FROM t) SELECT id, n FROM c ORDER BY id
----
1
10
2
20
3
30

# SELECT * expands the CTE's columns.
# names: id, n
query II nosort
WITH c AS (SELECT id, n FROM t) SELECT * FROM c ORDER BY id
----
1
10
2
20
3
30

# Column-rename list renames the body's output columns left-to-right.
# names: a, b
query II nosort
WITH c (a, b) AS (SELECT id, n FROM t) SELECT a, b FROM c ORDER BY a
----
1
10
2
20
3
30

# A PARTIAL rename — fewer aliases than body columns — renames the first columns and keeps the
# rest's body names (PostgreSQL): here the first column becomes `a`, the second stays `n`.
# names: a, n
query II nosort
WITH c (a) AS (SELECT id, n FROM t) SELECT a, n FROM c ORDER BY a
----
1
10
2
20
3
30

# Multiple CTEs; a later CTE references an earlier one (forward visibility).
# names: id, m
query II nosort
WITH c AS (SELECT id, n FROM t),
     d AS (SELECT id, n * 2 AS m FROM c)
SELECT id, m FROM d ORDER BY id
----
1
20
2
40
3
60

# A CTE referenced TWICE → MATERIALIZED; a self-CROSS-JOIN observes the same buffer twice.
# names: x, y
query II rowsort
WITH c (v) AS (SELECT id FROM t WHERE id <= 2)
SELECT a.v AS x, b.v AS y FROM c a CROSS JOIN c b
----
1
1
1
2
2
1
2
2

# A JOIN of two distinct CTEs.
# names: id, n
query II nosort
WITH c AS (SELECT id, n FROM t),
     d AS (SELECT id, n FROM t WHERE n >= 20)
SELECT c.id, d.n FROM c JOIN d ON c.id = d.id ORDER BY c.id
----
2
20
3
30

# A CTE body may be a set operation.
# names: n
query I nosort
WITH c AS (SELECT n FROM t WHERE id = 1 UNION ALL SELECT n FROM t WHERE id = 2)
SELECT n FROM c ORDER BY n
----
10
20

# A CTE body may be an aggregate query.
# names: cnt
query I nosort
WITH c AS (SELECT count(*) AS cnt FROM t) SELECT cnt FROM c
----
3

# A CTE referenced inside a nested subquery (the binding is inherited into the subquery scope).
# names: id
query I nosort
WITH c AS (SELECT n FROM t) SELECT id FROM t WHERE n = (SELECT max(n) FROM c) ORDER BY id
----
3

# MATERIALIZED forces buffering even for a single reference (rows unchanged).
# names: id
query I nosort
WITH c AS MATERIALIZED (SELECT id FROM t) SELECT id FROM c ORDER BY id
----
1
2
3

# NOT MATERIALIZED forces inlining even for a multi-reference CTE (rows unchanged).
# names: x, y
query II rowsort
WITH c (v) AS NOT MATERIALIZED (SELECT id FROM t WHERE id <= 2)
SELECT a.v AS x, b.v AS y FROM c a CROSS JOIN c b
----
1
1
1
2
2
1
2
2

# --- cost contract (spec/design/cost.md §3 "cte_scan_row") ---

# INLINED single reference: body = page_read(1) + 3 storage_row_read + 3 row_produced = 7; the
# outer scans the computed relation c (no store, no cte_scan_row) and emits 3 rows = 3 row_produced.
# cost: 10
query II nosort
WITH c AS (SELECT id, n FROM t) SELECT id, n FROM c ORDER BY id
----
1
10
2
20
3
30

# MATERIALIZED (two references): body once = 7, then 3 + 3 = 6 cte_scan_row for the two buffer
# scans, then 9 row_produced for the 3x3 product = 22.
# cost: 22
query II rowsort
WITH c AS (SELECT id, n FROM t)
SELECT a.id AS x, b.id AS y FROM c a CROSS JOIN c b
----
1
1
1
2
1
3
2
1
2
2
2
3
3
1
3
2
3
3

# An UNREFERENCED CTE is planned/type-checked but not executed: 0 cost for c; only SELECT 1's
# single row_produced.
# cost: 1
query I nosort
WITH c AS (SELECT id, n FROM t) SELECT 1
----
1
