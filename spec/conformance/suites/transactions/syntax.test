# skip: disk — a transaction spanning records cannot survive the disk-mode per-record reopen (spec/design/conformance.md §3).
# Transaction-statement spellings (spec/design/grammar.md §27). The openers BEGIN,
# BEGIN TRANSACTION, BEGIN WORK, and START TRANSACTION are equivalent; the closers COMMIT,
# COMMIT WORK, COMMIT TRANSACTION, and END are equivalent; ROLLBACK accepts the optional WORK /
# TRANSACTION noise word too. All the keywords are non-reserved. Format + the `requires`
# directive: ../../../design/conformance.md.
# requires: txn.explicit, ddl.create_table, ddl.primary_key, dml.insert, query.select, query.order_by, types.i32

statement ok
CREATE TABLE t (id i32 PRIMARY KEY)

# START TRANSACTION ... END
statement ok
START TRANSACTION

statement ok
INSERT INTO t VALUES (1)

statement ok
END

# BEGIN TRANSACTION READ WRITE ... COMMIT WORK
statement ok
BEGIN TRANSACTION READ WRITE

statement ok
INSERT INTO t VALUES (2)

statement ok
COMMIT WORK

# BEGIN WORK ... ROLLBACK WORK (the insert is discarded)
statement ok
BEGIN WORK

statement ok
INSERT INTO t VALUES (3)

statement ok
ROLLBACK WORK

# COMMIT TRANSACTION spelling
statement ok
BEGIN

statement ok
INSERT INTO t VALUES (4)

statement ok
COMMIT TRANSACTION

query I nosort
SELECT id FROM t ORDER BY id
----
1
2
4
