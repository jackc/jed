# skip: disk — a transaction spanning records cannot survive the disk-mode per-record reopen (spec/design/conformance.md §3).
# Failed-block poisoning (spec/design/transactions.md §6). A statement error inside an explicit
# block aborts the transaction: it enters the failed state, and every later statement but
# ROLLBACK / COMMIT is rejected with 25P02 (in_failed_sql_transaction). ROLLBACK clears the
# failed state; COMMIT of a failed block acts as a ROLLBACK (PostgreSQL). The whole working set
# is discarded — including statements that SUCCEEDED before the error. The error that aborts the
# block here is a duplicate primary key (23505). Format + the `requires` directive:
# ../../../design/conformance.md.
# requires: txn.failed_state, txn.explicit, ddl.create_table, ddl.primary_key, dml.insert, query.select, query.where_eq, query.order_by, expr.arithmetic, expr.parens, error.division_by_zero, types.i32

statement ok
CREATE TABLE t (id i32 PRIMARY KEY)

statement ok
INSERT INTO t VALUES (1)

# --- ROLLBACK clears a failed block -----------------------------------------
statement ok
BEGIN

statement error 23505
INSERT INTO t VALUES (1)

# the block is now failed: any statement but ROLLBACK/COMMIT is 25P02 — even a read
statement error 25P02
SELECT id FROM t

statement error 25P02
INSERT INTO t VALUES (2)

statement ok
ROLLBACK

# ROLLBACK cleared the failed state; autocommit resumes normally
query I rowsort
SELECT id FROM t
----
1

# --- COMMIT of a failed block acts as ROLLBACK, discarding earlier successes -
statement ok
BEGIN

# this INSERT succeeds within the block...
statement ok
INSERT INTO t VALUES (2)

# ...but this one aborts the block (duplicate key)
statement error 23505
INSERT INTO t VALUES (1)

statement error 25P02
SELECT id FROM t

# COMMIT of a failed block rolls back: the earlier successful INSERT (2) is discarded too
statement ok
COMMIT

query I nosort
SELECT id FROM t ORDER BY id
----
1

# --- G28: in AUTOCOMMIT (no explicit block), a failed statement does NOT poison the next -------
# Only an explicit BEGIN block enters the failed state; outside one, each statement is its own
# autocommit transaction, so a duplicate-key 23505 aborts only ITSELF and the following INSERT
# runs normally (no 25P02). This is the contrast that makes the poisoning above a property of the
# explicit block, not of an error per se.
statement error 23505
INSERT INTO t VALUES (1)

statement ok
INSERT INTO t VALUES (2)

# Both the pre-existing row 1 and the newly committed row 2 are present — no poisoning occurred.
query I nosort
SELECT id FROM t ORDER BY id
----
1
2

# --- a failing READ poisons the block too: open-time (missing table, 42P01) -------------------
# The aborting statement above is always a write; a READ that errors must abort the block just the
# same — PostgreSQL aborts on ANY statement error, not only a write. A missing-table SELECT errors
# when the statement is planned (before the cursor produces a row), and still poisons.
statement ok
BEGIN

statement error 42P01
SELECT id FROM no_such_table

statement error 25P02
SELECT id FROM t

statement ok
ROLLBACK

# --- a failing READ poisons the block too: drain-time (division by zero, 22012) ---------------
# A single-table scan streams its rows, so `100 / (id - 1)` traps only when the id=1 row is
# produced — mid-drain, AFTER the cursor opened. The block must abort all the same (the next
# statement is 25P02), so poisoning cannot depend on the error surfacing at plan time.
statement ok
BEGIN

statement error 22012
SELECT 100 / (id - 1) FROM t

statement error 25P02
SELECT id FROM t

statement ok
ROLLBACK

# t is unchanged by the two aborted read-only blocks.
query I nosort
SELECT id FROM t ORDER BY id
----
1
2
