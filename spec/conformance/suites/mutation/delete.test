# DELETE — remove rows matching an optional predicate (Kleene: only TRUE matches).
# No WHERE deletes every row. Includes the no-PK rowid regression: a monotonic rowid
# counter means DELETE-then-INSERT never collides with a freed key.
# Format + the `requires` directive: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.delete, query.select, query.where_eq, query.comparison_order, query.is_null, query.order_by, types.i16, types.i32

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, v i16)

statement ok
INSERT INTO t VALUES (1, 10)

statement ok
INSERT INTO t VALUES (2, 20)

statement ok
INSERT INTO t VALUES (3, 30)

statement ok
INSERT INTO t VALUES (4, NULL)

# delete one row by primary key
statement ok
DELETE FROM t WHERE id = 2

query I nosort
SELECT id FROM t ORDER BY id
----
1
3
4

# a predicate that is UNKNOWN for the NULL row (and FALSE for the rest) deletes
# nothing — three-valued logic, only TRUE matches
statement ok
DELETE FROM t WHERE v > 100

query I nosort
SELECT id FROM t ORDER BY id
----
1
3
4

# IS NULL deletes only the NULL row
statement ok
DELETE FROM t WHERE v IS NULL

query I nosort
SELECT id FROM t ORDER BY id
----
1
3

# delete with no WHERE empties the table
statement ok
DELETE FROM t

query I nosort
SELECT id FROM t ORDER BY id
----

# No-PK rowid regression: synthetic rowids are monotonic, so deleting a row and
# inserting again must NOT collide (it would wrongly trap 23505 if the rowid were the
# current row count).
statement ok
CREATE TABLE log (n i32)

statement ok
INSERT INTO log VALUES (100)

statement ok
INSERT INTO log VALUES (200)

statement ok
INSERT INTO log VALUES (300)

statement ok
DELETE FROM log WHERE n = 200

statement ok
INSERT INTO log VALUES (400)

query I nosort
SELECT n FROM log ORDER BY n
----
100
300
400
