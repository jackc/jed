# Window functions S1 — relative-rank ratios: percent_rank() and cume_dist() (window.md §4).
#
# percent_rank() = (rank-1)/(N-1), 0 when N=1; cume_dist() = (rows through the current peer group)/N.
# Both are peer-aware (peers = rows equal on the window ORDER BY only). The result is f64 — PG's
# float8: the ratio is ONE IEEE correctly-rounded division of small integers that convert exactly to
# binary64, so jed's value is bit-identical across cores AND to PostgreSQL (the in-contract float
# kernel, float.md §5). These rows therefore come straight from the oracle (the old decimal
# divergence D2 is gone). The pr/cd columns carry the `R` (real) render tag (conformance.md §1).
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.window, query.window_ratio, query.order_by, types.i32, types.f64, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, v i32)

statement ok
INSERT INTO t VALUES (1, 10), (2, 10), (3, 30), (4, 40)

# ORDER BY v — peer groups {10:id1,id2}[0,2), {30:id3}[2,3), {40:id4}[3,4); N=4.
# percent_rank: 0/3, 0/3, 2/3, 3/3 ; cume_dist: 2/4, 2/4, 3/4, 4/4.
# names: id, pr, cd
# cost: 17
query IRR nosort
SELECT id, percent_rank() OVER (ORDER BY v) AS pr, cume_dist() OVER (ORDER BY v) AS cd FROM t ORDER BY id
----
1
0
0.5
2
0
0.5
3
0.6666666666666666
0.75
4
1
1

# No window ORDER BY — the whole partition is one peer group [0,4): percent_rank = 0/3 = 0 for all,
# cume_dist = 4/4 = 1 for all.
# names: id, pr, cd
query IRR nosort
SELECT id, percent_rank() OVER () AS pr, cume_dist() OVER () AS cd FROM t ORDER BY id
----
1
0
1
2
0
1
3
0
1
4
0
1
