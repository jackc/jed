# An expression ORDER BY key in a GROUPED query that ALSO has window functions
# (query.order_by_grouped_window, spec/design/grammar.md §10, window.md §5.2). The window stage runs
# over the GROUPED rows; the ORDER BY key — an aggregate expression (ORDER BY sum(v) + 1), a window
# function over an aggregate (ORDER BY rank() OVER (ORDER BY sum(v))), or a window function over a
# grouped aggregate count — is resolved in the same grouped+window context as the projection, collects
# into the shared aggregate / window specs, is materialized over the grouped+windowed rows, and sorted
# by. Results verified against PostgreSQL 18.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.group_by, query.aggregates, query.window, query.window_ranking, query.window_aggregate, query.window_grouped, query.order_by, query.order_by_expr, query.order_by_window, query.order_by_grouped_window, expr.arithmetic, types.i32, resource.cost_metering

statement ok
CREATE TABLE gw (a i32 PRIMARY KEY, g i32, v i32)

statement ok
INSERT INTO gw VALUES (1,1,10),(2,1,20),(3,2,30),(4,2,5),(5,3,15)

# --- an aggregate-expression ORDER BY key alongside a select-list window function ---
# group sums: g=1 -> 30, g=2 -> 35, g=3 -> 15; ORDER BY sum(v)+1 sorts ascending by the sum;
# rank() over the sums ascending -> 1, 2, 3 down the (already sum-ordered) rows.
# names: g, sum, rank
query III nosort
SELECT g, sum(v), rank() OVER (ORDER BY sum(v)) FROM gw GROUP BY g ORDER BY sum(v) + 1
----
3
15
1
1
30
2
2
35
3

# --- a window function over an aggregate as the ORDER BY key, DESC ---
# rank() over the group sums ascending -> g3=1, g1=2, g2=3; DESC sorts g2, g1, g3.
# names: g, sum
query II nosort
SELECT g, sum(v) FROM gw GROUP BY g ORDER BY rank() OVER (ORDER BY sum(v)) DESC
----
2
35
1
30
3
15

# --- a window function over a grouped count(*) as the ORDER BY key ---
# counts: g1=2, g2=2, g3=1; row_number by (count desc, g) -> g1=1, g2=2, g3=3.
# names: g, count
query II nosort
SELECT g, count(*) FROM gw GROUP BY g ORDER BY row_number() OVER (ORDER BY count(*) DESC, g)
----
1
2
2
2
3
1

# --- the window value is also projected (aliased) and the sort key is the aggregate, DESC ---
# names: g, sum, r
query III nosort
SELECT g, sum(v), rank() OVER (ORDER BY sum(v)) AS r FROM gw GROUP BY g ORDER BY sum(v) DESC
----
2
35
3
1
30
2
3
15
1
