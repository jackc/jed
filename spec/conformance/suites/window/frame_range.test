# Window functions — explicit RANGE / GROUPS frames + value-based RANGE offsets (window.md §6).
#
# ROWS counts physical rows; GROUPS counts peer groups; RANGE works on the ordering-key VALUE.
# A RANGE value offset (n PRECEDING/FOLLOWING) frames the rows whose key is within n of the current
# key, and requires exactly one ORDER BY column (42P20 otherwise) of an integer/decimal type
# (0A000 otherwise). GROUPS requires an ORDER BY (42P20). CURRENT ROW spans the current peer group
# in both RANGE and GROUPS. Explicit EXCLUDE stays deferred 0A000.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.window, query.window_aggregate, query.window_frame, query.window_frame_range, query.order_by, types.i32, types.decimal, types.f64, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, g i32, x i32)

statement ok
INSERT INTO t VALUES (1,1,1), (2,1,1), (3,1,2), (4,1,4), (5,1,4), (6,2,1), (7,2,3), (8,2,6)

# RANGE value offset within a partition: sum over keys in [x-1, x+1]. g=1 has x {1,1,2,4,4};
# g=2 has x {1,3,6}. id4/id5 (x=4) see {4,4}=8; id3 (x=2) sees {1,1,2}=4; id7 (x=3) sees only {3}=3.
# names: id, s
query II nosort
SELECT id, sum(x) OVER (PARTITION BY g ORDER BY x RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING) AS s FROM t ORDER BY id
----
1
4
2
4
3
4
4
8
5
8
6
1
7
3
8
6

# Explicit RANGE UNBOUNDED PRECEDING AND CURRENT ROW = the running default frame, peer-aware: every
# peer of the current key is included. Keys sorted 1,1,1,2,3,4,4,6; id4/id5 (x=4) accumulate through
# the x=4 peer group: 1+1+1+2+3+4+4 = 16.
# names: id, s
# cost: 33
query II nosort
SELECT id, sum(x) OVER (ORDER BY x RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS s FROM t ORDER BY id
----
1
3
2
3
3
5
4
16
5
16
6
3
7
8
8
22

# GROUPS counts peer groups. Groups by x over all rows: [1×3],[2],[3],[4×2],[6]. GROUPS 1 PRECEDING
# AND CURRENT ROW folds the previous peer group + the current one. id7 (x=3, group 2) = group1(2) +
# group2(3) = 5; id8 (x=6, group 4) = group3(4+4) + group4(6) = 14.
# names: id, s
query II nosort
SELECT id, sum(x) OVER (ORDER BY x GROUPS BETWEEN 1 PRECEDING AND CURRENT ROW) AS s FROM t ORDER BY id
----
1
3
2
3
3
5
4
11
5
11
6
3
7
5
8
14

# GROUPS CURRENT ROW AND 1 FOLLOWING — count rows in the current + next peer group. id3 (x=2, group1)
# = group1(1 row) + group2(1 row) = 2; id8 (x=6, the last group) = just itself = 1.
# names: id, c
query II nosort
SELECT id, count(*) OVER (ORDER BY x GROUPS BETWEEN CURRENT ROW AND 1 FOLLOWING) AS c FROM t ORDER BY id
----
1
4
2
4
3
2
4
3
5
3
6
4
7
3
8
1

# first_value / last_value over a RANGE value-offset frame (the value picked is the ordering key, so
# it is unambiguous across peers). id3 (x=2) frame keys {1,1,1,2,3} -> first 1, last 3.
# names: id, fv, lv
query III nosort
SELECT id, first_value(x) OVER (ORDER BY x RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING) AS fv, last_value(x) OVER (ORDER BY x RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING) AS lv FROM t ORDER BY id
----
1
1
2
2
1
2
3
1
3
4
3
4
5
3
4
6
1
2
7
2
4
8
6
6

# DESC ordering flips the offset sides (a RANGE frame is still keys within [x-1, x+1]). id3 (x=2)
# sees {1,1,1,2,3}=8; id7 (x=3) sees {2,3,4,4}=13.
# names: id, s
query II nosort
SELECT id, sum(x) OVER (ORDER BY x DESC RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING) AS s FROM t ORDER BY id
----
1
5
2
5
3
8
4
11
5
11
6
5
7
13
8
6

# A NULL ordering key is its own peer group: an offset frame over a NULL current key sees only its
# NULL peers (here sum(x) over the NULLs is NULL), and non-NULL rows never include the NULLs.
statement ok
CREATE TABLE tn (id i32 PRIMARY KEY, x i32)

statement ok
INSERT INTO tn VALUES (1,1), (2,2), (3,2), (4,NULL), (5,NULL)

# names: id, x, s
query III nosort
SELECT id, x, sum(x) OVER (ORDER BY x RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING) AS s FROM tn ORDER BY id
----
1
1
5
2
2
5
3
2
5
4
NULL
NULL
5
NULL
NULL

# With an UNBOUNDED PRECEDING start, the NULL current rows reach the partition start (count includes
# every row), while the non-NULL rows still bound the FOLLOWING side on the key value.
# names: id, x, c
query III nosort
SELECT id, x, count(*) OVER (ORDER BY x RANGE BETWEEN UNBOUNDED PRECEDING AND 1 FOLLOWING) AS c FROM tn ORDER BY id
----
1
1
3
2
2
3
3
2
3
4
NULL
5
5
NULL
5

# RANGE value offsets over a decimal key: decimal offset (0.5) and a widened integer offset (1).
statement ok
CREATE TABLE td (id i32 PRIMARY KEY, x decimal(10,2))

statement ok
INSERT INTO td VALUES (1, 1.00), (2, 1.50), (3, 2.00), (4, 3.00)

# keys in [x-0.5, x+0.5]: id2 (1.50) sees {1.00,1.50,2.00}=4.50; id4 (3.00) sees only {3.00}=3.00.
# names: id, s
query ID nosort
SELECT id, sum(x) OVER (ORDER BY x RANGE BETWEEN 0.5 PRECEDING AND 0.5 FOLLOWING) AS s FROM td ORDER BY id
----
1
2.50
2
4.50
3
3.50
4
3.00

# integer offset widened to the decimal key: keys in [x-1, x] (running by value). id4 (3.00) sees
# {2.00,3.00}=5.00.
# names: id, s
query ID nosort
SELECT id, sum(x) OVER (ORDER BY x RANGE BETWEEN 1 PRECEDING AND CURRENT ROW) AS s FROM td ORDER BY id
----
1
1.00
2
2.50
3
4.50
4
5.00

# --- Error conditions (PG-agreeing) -------------------------------------------------------------

# GROUPS mode requires an ORDER BY clause — 42P20.
statement error 42P20
SELECT sum(x) OVER (GROUPS BETWEEN 1 PRECEDING AND CURRENT ROW) FROM t

# A RANGE value offset requires exactly one ORDER BY column — 42P20 (none here).
statement error 42P20
SELECT sum(x) OVER (RANGE BETWEEN 1 PRECEDING AND CURRENT ROW) FROM t

# A RANGE value offset requires exactly ONE ORDER BY column — 42P20 (two here).
statement error 42P20
SELECT sum(x) OVER (ORDER BY g, x RANGE BETWEEN 1 PRECEDING AND CURRENT ROW) FROM t

# A negative RANGE offset — 22013.
statement error 22013
SELECT sum(x) OVER (ORDER BY x RANGE BETWEEN -1 PRECEDING AND CURRENT ROW) FROM t

# A negative GROUPS offset — 22013.
statement error 22013
SELECT sum(x) OVER (ORDER BY x GROUPS BETWEEN -1 PRECEDING AND CURRENT ROW) FROM t

# An integer ordering key with a decimal RANGE offset is unsupported — 0A000 (matching PG).
statement error 0A000
SELECT sum(x) OVER (ORDER BY x RANGE BETWEEN 1.5 PRECEDING AND CURRENT ROW) FROM t

# A text ordering key cannot take a RANGE value offset — 0A000.
statement ok
CREATE TABLE tt (id i32 PRIMARY KEY, s text, x i32)

statement ok
INSERT INTO tt VALUES (1, 'a', 1), (2, 'b', 2)

statement error 0A000
SELECT sum(x) OVER (ORDER BY s RANGE BETWEEN 1 PRECEDING AND CURRENT ROW) FROM tt

# A float ordering key cannot take a RANGE value offset — 0A000 (divergence D3: keep floats out of
# the comparison path; PostgreSQL supports float8 RANGE offsets — oracle-overridden).
statement ok
CREATE TABLE tf (id i32 PRIMARY KEY, f f64, x i32)

statement ok
INSERT INTO tf VALUES (1, 1.0, 1), (2, 2.0, 2)

statement error 0A000
SELECT sum(x) OVER (ORDER BY f RANGE BETWEEN 1 PRECEDING AND CURRENT ROW) FROM tf
