# --- Error cases (all reuse 42P20 windowing_error / 42704 undefined_object) ---

# The extender may not add a PARTITION BY — even though the base's partition is identical.
statement error 42P20
SELECT sum(x) OVER (w PARTITION BY id) FROM wb WINDOW w AS (PARTITION BY g)

# The extender may add an ORDER BY only if the base has none; here the base already orders.
statement error 42P20
SELECT sum(x) OVER (w ORDER BY id) FROM wb WINDOW w AS (PARTITION BY g ORDER BY x)

# A base that carries a frame cannot be copied/extended (even by a bare `OVER (w)`).
statement error 42P20
SELECT sum(x) OVER (w) FROM wb WINDOW w AS (PARTITION BY g ORDER BY id ROWS UNBOUNDED PRECEDING)

# An inline extend naming a window that does not exist is 42704.
statement error 42704
SELECT sum(x) OVER (nonesuch ORDER BY id) FROM wb WINDOW w AS (PARTITION BY g)

# A forward reference inside the WINDOW clause (w names w2, defined later) is "does not exist" — the
# base must be an EARLIER entry.
statement error 42704
SELECT sum(x) OVER w FROM wb WINDOW w AS (w2 ORDER BY id), w2 AS (PARTITION BY g)

# Every WINDOW-clause entry is validated even when no OVER references it — an unreferenced entry that
# overrides PARTITION BY is still 42P20 (matching PostgreSQL's whole-clause check).
statement error 42P20
SELECT id FROM wb WINDOW w AS (PARTITION BY g), w2 AS (w PARTITION BY id) ORDER BY id
