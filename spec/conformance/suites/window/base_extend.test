# Two functions extend the same PARTITION-only base differently — rank adds `ORDER BY x`, the sum
# adds `ORDER BY id` — proving the base is a reusable template, not a shared resolved window.
# names: id, g, rk, rs
# cost: 31
query IIII nosort
SELECT id, g, rank() OVER (w ORDER BY x) AS rk, sum(x) OVER (w ORDER BY id) AS rs FROM wb WINDOW w AS (PARTITION BY g) ORDER BY id
----
1
10
2
5
2
10
1
8
3
