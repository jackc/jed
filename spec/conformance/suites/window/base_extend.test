# Base-window-extending definitions (spec/design/window.md §5, PostgreSQL `transformWindowDefinitions`).
#
# A window definition may begin with the name of an earlier WINDOW-clause entry to **extend** it:
# `OVER (w ORDER BY …)` / `WINDOW w2 AS (w ORDER BY …)`. The extending definition inherits the base's
# PARTITION BY (and its ORDER BY if the base has one) and supplies its own frame. The rules (all
# 42P20, in PostgreSQL's priority order PARTITION → ORDER → frame): the extender may not add a
# PARTITION BY; it may add an ORDER BY only if the base has none; the base must not carry a frame.
# A base that does not exist (including a self- or forward-reference within the WINDOW clause) is
# 42704. A pure `OVER name` reference (no parentheses) copies the named window whole — frame included,
# no merge rules — and stays query.window_named, not this slice.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.window, query.window_ranking, query.window_aggregate, query.window_frame, query.window_named, query.window_base_extend, query.order_by, types.i32, resource.cost_metering

statement ok
CREATE TABLE wb (id i32 PRIMARY KEY, g i32, x i32)

statement ok
INSERT INTO wb VALUES (1, 10, 5), (2, 10, 3), (3, 20, 7), (4, 20, 1), (5, 20, 4), (6, 30, 9)

# Extend a PARTITION-only base with an ORDER BY: a running per-group sum. The new window inherits
# `PARTITION BY g` from w and adds its own `ORDER BY id`.
# names: id, g, rs
# cost: 25
query III nosort
SELECT id, g, sum(x) OVER (w ORDER BY id) AS rs FROM wb WINDOW w AS (PARTITION BY g) ORDER BY id
----
1
10
5
2
10
8
3
20
7
4
20
8
5
20
12
6
30
9

# `OVER (w)` with no additions copies the full definition (PARTITION BY g, ORDER BY id) — the same
# running sum. (The base has no frame, so the copy is allowed.)
# names: id, g, rs
query III nosort
SELECT id, g, sum(x) OVER (w) AS rs FROM wb WINDOW w AS (PARTITION BY g ORDER BY id) ORDER BY id
----
1
10
5
2
10
8
3
20
7
4
20
8
5
20
12
6
30
9

# The extender supplies its OWN frame over an inherited PARTITION BY + ORDER BY (the base has none),
# so the sum is over the 1-preceding..current window rather than the running default.
# names: id, g, fs
query III nosort
SELECT id, g, sum(x) OVER (w ROWS BETWEEN 1 PRECEDING AND CURRENT ROW) AS fs FROM wb WINDOW w AS (PARTITION BY g ORDER BY id) ORDER BY id
----
1
10
5
2
10
8
3
20
7
4
20
8
5
20
5
6
30
9

# Chained extension inside the WINDOW clause: w2 extends an earlier entry w, then OVER w2 references
# the chain. Same running per-group sum as the inline extend above.
# names: id, g, rs
query III nosort
SELECT id, g, sum(x) OVER w2 AS rs FROM wb WINDOW w AS (PARTITION BY g), w2 AS (w ORDER BY id) ORDER BY id
----
1
10
5
2
10
8
3
20
7
4
20
8
5
20
12
6
30
9

# Copy a PARTITION-only base (no ORDER BY): the whole-partition sum, constant within each group.
# names: id, g, gs
query III nosort
SELECT id, g, sum(x) OVER (w) AS gs FROM wb WINDOW w AS (PARTITION BY g) ORDER BY id
----
1
10
