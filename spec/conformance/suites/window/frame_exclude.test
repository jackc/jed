# Window frame exclusion — EXCLUDE CURRENT ROW / GROUP / TIES / NO OTHERS (spec/design/window.md §6).
#
# Exclusion drops rows from the computed [lo, hi) frame, per current row, before a frame-sensitive
# function folds/picks over it: CURRENT ROW drops the row itself, GROUP its whole peer group, TIES
# its peers but not itself, NO OTHERS nothing. It removes only rows already inside the frame, so
# EXCLUDE CURRENT ROW on a frame that doesn't contain the current row is a no-op. first/last/nth_value
# pick over the survivors; an empty-after-exclusion frame is NULL (count 0). Works with ROWS/RANGE/GROUPS.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.window, query.window_aggregate, query.window_frame, query.window_frame_range, query.window_frame_exclude, query.order_by, types.i32, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, x i32)

# x = 1,1,2,2,2,3 (peer groups [1×2],[2×3],[3]); whole-partition sum is 11.
statement ok
INSERT INTO t VALUES (1,1), (2,1), (3,2), (4,2), (5,2), (6,3)

# EXCLUDE CURRENT ROW — drop the current row's value from the full-partition sum (11 - x).
# names: id, s
# cost: 49
query II nosort
SELECT id, sum(x) OVER (ORDER BY x ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING EXCLUDE CURRENT ROW) AS s FROM t ORDER BY id
----
1
10
2
10
3
9
4
9
5
9
6
8

# EXCLUDE GROUP — drop the current row's whole peer group (11 - group_sum). id1/id2 lose {1,1};
# id3..id5 lose {2,2,2}; id6 loses {3}.
# names: id, s
query II nosort
SELECT id, sum(x) OVER (ORDER BY x ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING EXCLUDE GROUP) AS s FROM t ORDER BY id
----
1
9
2
9
3
5
4
5
5
5
6
8

# EXCLUDE TIES — drop the peers but keep the current row. id1 loses id2 (1); id3 loses id4,id5 (4);
# id6 has no peers so the sum is unchanged (11).
# names: id, s
query II nosort
SELECT id, sum(x) OVER (ORDER BY x ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING EXCLUDE TIES) AS s FROM t ORDER BY id
----
1
10
2
10
3
7
4
7
5
7
6
11

# EXCLUDE NO OTHERS — the explicit default, identical to no EXCLUDE (whole partition = 11).
# names: id, s
query II nosort
SELECT id, sum(x) OVER (ORDER BY x ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING EXCLUDE NO OTHERS) AS s FROM t ORDER BY id
----
1
11
2
11
3
11
4
11
5
11
6
11

# EXCLUDE GROUP on a running RANGE frame: [0, peer_end) minus the current group. id1 (frame {id1,id2})
# loses its whole group -> empty -> 0; id3 (frame {id1..id5}) keeps {id1,id2} -> 2; id6 (whole frame)
# keeps {id1..id5} -> 5.
# names: id, c
query II nosort
SELECT id, count(*) OVER (ORDER BY x RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW EXCLUDE GROUP) AS c FROM t ORDER BY id
----
1
0
2
0
3
2
4
2
5
2
6
5

# EXCLUDE CURRENT ROW is a no-op when the current row is outside the frame (a strictly-preceding
# ROWS frame): the counts match the plain frame.
# names: id, c
query II nosort
SELECT id, count(*) OVER (ORDER BY id ROWS BETWEEN 2 PRECEDING AND 1 PRECEDING EXCLUDE CURRENT ROW) AS c FROM t ORDER BY id
----
1
0
2
1
3
2
4
2
5
2
6
2

# GROUPS frame + EXCLUDE GROUP: GROUPS 1 PRECEDING AND 1 FOLLOWING then drop the current group.
# id3 (frame = all) keeps {id1,id2,id6} -> 1+1+3 = 5.
# names: id, s
query II nosort
SELECT id, sum(x) OVER (ORDER BY x GROUPS BETWEEN 1 PRECEDING AND 1 FOLLOWING EXCLUDE GROUP) AS s FROM t ORDER BY id
----
1
6
2
6
3
5
4
5
5
5
6
6

# first_value/last_value skip excluded rows (EXCLUDE CURRENT ROW): first is the partition's first
# row unless that IS the current row (then the next), last symmetrically.
# names: id, fv, lv
query III nosort
SELECT id, first_value(id) OVER w AS fv, last_value(id) OVER w AS lv FROM t WINDOW w AS (ORDER BY id ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING EXCLUDE CURRENT ROW) ORDER BY id
----
1
2
6
2
1
6
3
1
6
4
1
6
5
1
6
6
1
5

# nth_value counts only the surviving rows (EXCLUDE GROUP): the 2nd survivor after dropping the
# current peer group. id1 (drop {x=1}) -> survivors x={2,2,2,3}, 2nd x = 2; id3 (drop {x=2}) ->
# survivors x={1,1,3}, 2nd x = 1. (Picks x, constant within a peer group, so it is unambiguous.)
# names: id, n2
query II nosort
SELECT id, nth_value(x, 2) OVER (ORDER BY x ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING EXCLUDE GROUP) AS n2 FROM t ORDER BY id
----
1
2
2
2
3
1
4
1
5
1
6
1

# Empty-after-exclusion: when the whole frame is one peer group and EXCLUDE GROUP drops it,
# first_value is NULL and count is 0 (PARTITION BY x makes each partition a single group).
# names: id, fv
query II nosort
SELECT id, first_value(id) OVER (PARTITION BY x ORDER BY x ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING EXCLUDE GROUP) AS fv FROM t ORDER BY id
----
1
NULL
2
NULL
3
NULL
4
NULL
5
NULL
6
NULL

# Malformed EXCLUDE — a syntax error (42601).
statement error 42601
SELECT sum(x) OVER (ORDER BY x ROWS UNBOUNDED PRECEDING EXCLUDE BOGUS) FROM t
