# Storable json / jsonb columns (J1/J1b, spec/design/json.md §1/§2/§4). A column type can now be
# `jsonb` (canonicalized tagged-node body, on-disk type code 19) or `json` (verbatim text body, type
# code 18) — format_version 19. A `jsonb` column stores the CANONICAL form (numbers exact, object
# keys deduped last-wins then sorted, one space after ':'/',') and selects it back canonical; a
# `json` column stores the input bytes VERBATIM and selects them back unchanged. A bare string
# literal adapts to a json/jsonb column (the same json_in/jsonb_in as the literal cast). NULL is a
# distinct, non-NULL-document value. Comparison/ordering of jsonb (J2) and the operator surface
# (J4–J6) are later slices, so rows are ordered by the i32 PK here. Output matches the postgres:18
# oracle byte-for-byte. A jsonb/json PRIMARY KEY is 0A000 (a per-core divergence test — PG allows a
# jsonb PK). Format: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.order_by, types.jsonb, types.json

statement ok
CREATE TABLE docs (id i32 PRIMARY KEY, body jsonb, raw json)

# A bare string literal adapts to the json/jsonb column. jsonb canonicalizes on store (key sort,
# dedup, number normalization); json keeps the input bytes verbatim.
statement ok
INSERT INTO docs VALUES
  (1, '{ "a" : 1, "tags": ["x", "y"] }', '{ "a" : 1 }'),
  (2, '[3, 2, 1]', '[3, 2, 1]'),
  (3, 'true', 'null'),
  (4, NULL, NULL)

# jsonb round-trips canonical; json round-trips verbatim; a SQL NULL document stays NULL.
query ITT nosort
SELECT id, body, raw FROM docs ORDER BY id
----
1
{"a": 1, "tags": ["x", "y"]}
{ "a" : 1 }
2
[3, 2, 1]
[3, 2, 1]
3
true
null
4
NULL
NULL

# A jsonb column stored from a duplicate-key / out-of-order object canonicalizes on the way in
# (last-wins dedup, length-then-bytewise key sort, exact-decimal numbers).
statement ok
INSERT INTO docs VALUES (5, '{"b":2,"aa":1,"b":3,"z":1e2}', '{"b":2,"aa":1,"b":3}')

query TT nosort
SELECT body, raw FROM docs WHERE id = 5
----
{"b": 3, "z": 100, "aa": 1}
{"b":2,"aa":1,"b":3}

# A whole-value IS NULL test (the only json predicate this slice): NULL documents are NULL, present
# documents (including the JSON null node and an empty object/array) are NOT NULL.
statement ok
INSERT INTO docs VALUES (6, '{}', '[]'), (7, 'null', '0')

query I nosort
SELECT id FROM docs WHERE body IS NOT NULL ORDER BY id
----
1
2
3
5
6
7

query I nosort
SELECT id FROM docs WHERE raw IS NULL
----
4
