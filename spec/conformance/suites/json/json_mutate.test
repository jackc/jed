# jsonb mutation operators (J6, spec/design/json-sql-functions.md §1): `||` concat/shallow-merge,
# `-` delete key/element/keys, `#-` delete at path. `||`: two objects merge (right wins); else each
# operand is array-wrapped and concatenated. `-`: text deletes a key (object) or matching string
# elements (array); int deletes an array element (negative from end, OOB no-op); text[] deletes each
# key. `#-` deletes the element at a text[] path (empty/missing/OOB step → no-op). A bare '{a,b}' is
# a single text KEY for `-` (verbatim, like PG) but a text[] PATH for `#-`. All jsonb, strict. A
# delete from a scalar / int-index into an object is 22023. Output matches the postgres:18 oracle.
# Format: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, types.jsonb, func.jsonb_mutate

# || concat / merge.
query TTTT nosort
SELECT '{"a":1,"b":2}'::jsonb || '{"b":3,"c":4}', '[1,2]'::jsonb || '[3,4]', '[1,2]'::jsonb || '3', '{"a":1}'::jsonb || '[2]'
----
{"a": 1, "b": 3, "c": 4}
[1, 2, 3, 4]
[1, 2, 3]
[{"a": 1}, 2]

query TTT nosort
SELECT '1'::jsonb || '2', '"x"'::jsonb || '"y"', '{"a":1}'::jsonb || '{}'
----
[1, 2]
["x", "y"]
{"a": 1}

# - delete key (object) / matching string elements (array) / element by index (negative from end).
query TTTT nosort
SELECT '{"a":1,"b":2}'::jsonb - 'a', '["a","b","a"]'::jsonb - 'a', '[1,2,3]'::jsonb - 1, '[1,2,3]'::jsonb - -1
----
{"b": 2}
["b"]
[1, 3]
[1, 2]

# - missing key / out-of-range index → no-op; a bare '{a,c}' is a single key (verbatim, no such key).
query TTT nosort
SELECT '{"a":1}'::jsonb - 'x', '[1,2,3]'::jsonb - 5, '{"a":1,"b":2,"c":3}'::jsonb - '{a,c}'
----
{"a": 1}
[1, 2, 3]
{"a": 1, "b": 2, "c": 3}

# - text[] delete each key (explicit text[] / ARRAY form).
query TT nosort
SELECT '{"a":1,"b":2,"c":3}'::jsonb - '{a,c}'::text[], '{"a":1,"b":2,"c":3}'::jsonb - ARRAY['a','c']
----
{"b": 2}
{"b": 2}

# #- delete at a text[] path (a bare '{a,b}' literal adapts); empty/missing path → no-op.
query TTTT nosort
SELECT '{"a":{"b":[1,2,3]}}'::jsonb #- '{a,b,1}', '{"a":1,"b":2}'::jsonb #- '{a}', '{"a":{"b":1}}'::jsonb #- '{a,x}', '{"a":1}'::jsonb #- '{}'
----
{"a": {"b": [1, 3]}}
{"b": 2}
{"a": {"b": 1}}
{"a": 1}

# Strict: a NULL operand → SQL NULL.
query TTT nosort
SELECT (NULL::jsonb) || '{}', '{"a":1}'::jsonb - (NULL::text), '{"a":1}'::jsonb #- (NULL::text[])
----
NULL
NULL
NULL

# Error cases: delete from a scalar / an integer index into an object / a path in a scalar.
statement error 22023
SELECT '5'::jsonb - 'a'

statement error 22023
SELECT '{"a":1}'::jsonb - 0

statement error 22023
SELECT '5'::jsonb #- '{a}'

# Used as a column update expression shape (in a SELECT here).
statement ok
CREATE TABLE t (id i32 PRIMARY KEY, b jsonb)

statement ok
INSERT INTO t VALUES (1, '{"a":1,"b":2}')

query T nosort
SELECT (b - 'a') || '{"c":3}' FROM t
----
{"b": 2, "c": 3}
