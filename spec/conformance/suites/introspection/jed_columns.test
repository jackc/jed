# PG-shorthand aliases render canonically too (int8 → i64, float4 → f32, numeric → decimal)
statement ok
CREATE TABLE aliased (x int8, y float4, z numeric(3,1))

query TT nosort
SELECT name, type FROM jed_columns WHERE table_name = 'aliased' ORDER BY ordinal
----
x
i64
y
f32
z
decimal(3,1)

# --- containers: arrays (typmod applies to the element), ranges, composites ----------------------

statement ok
CREATE TYPE addr AS (street text, zip i32)

# (a typmod on an array's ELEMENT type — varchar(5)[] — is not constructible yet, 0A000; when the
# narrowing lifts, the canonical rendering applies the typmod at the leaf: varchar(5)[].)
statement ok
CREATE TABLE containers (
  a i32[],
  b text[],
  e i32range,
  f i64range,
  g numrange,
  h tsrange,
  i tstzrange,
  j daterange,
  k addr,
  l addr[]
)

query TT nosort
SELECT name, type FROM jed_columns WHERE table_name = 'containers' ORDER BY ordinal
----
a
i32[]
b
text[]
e
i32range
f
i64range
g
numrange
h
tsrange
i
tstzrange
j
daterange
k
addr
l
addr[]

# --- not_null: declared NOT NULL or PRIMARY KEY membership; pk_ordinal is KEY order --------------

# the PK is declared (b, a) — key order differs from declaration order, and pk_ordinal follows the
# KEY: b → 1, a → 2. PK members are not_null without an explicit NOT NULL.
statement ok
CREATE TABLE keyed (a i32, b i64, c text NOT NULL, d text, PRIMARY KEY (b, a))

query TITBI nosort
SELECT name, ordinal, type, not_null, pk_ordinal FROM jed_columns WHERE table_name = 'keyed' ORDER BY ordinal
----
a
1
i32
true
2
b
2
i64
true
1
c
3
text
true
NULL
d
4
text
false
NULL

# a no-PK table: the synthetic rowid is NOT a column — only declared columns appear
statement ok
CREATE TABLE nopk (x i32, y text)

query TBI nosort
SELECT name, not_null, pk_ordinal FROM jed_columns WHERE table_name = 'nopk' ORDER BY ordinal
----
x
false
NULL
y
false
NULL

# --- ordinary composition: joins against jed_tables, aggregation over the catalog ----------------

query TI nosort
SELECT t.name, count(*) FROM jed_tables t JOIN jed_columns c ON c.table_name = t.name GROUP BY t.name ORDER BY t.name
----
aliased
3
containers
10
keyed
4
nopk
2
scalars
18

# --- read-only, like jed_tables -------------------------------------------------------------------

statement error 42809
INSERT INTO jed_columns VALUES ('t', 'c', 1, 'i32', false, NULL)

statement error 42809
DROP TABLE jed_columns

# --- cost: one generated_row per produced row (37 columns across the 5 tables), zero page_read ----

# 37 generated_row + the aggregate fold + 1 output row; the catalog is resident, so no page is read.
# cost: 75
query I nosort
SELECT count(*) FROM jed_columns
----
37
