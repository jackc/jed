# The jed_columns catalog relation (spec/design/introspection.md §5, slice I1): one row per column
# of every USER table of the qualified database — table_name / name / ordinal (1-based, CREATE
# TABLE order) / type (the CANONICAL type text) / not_null (declared NOT NULL or PRIMARY KEY
# member) / pk_ordinal (1-based position in the PRIMARY KEY in KEY order; NULL for a non-member).
# The canonical `type` text is a COMPATIBILITY SURFACE from the moment it ships — this file pins
# every renderable type: the scalar canonical names, the typmods applied at the leaf (varchar(10),
# decimal(8,2) — including through an array element: varchar(5)[]), a composite's name as created,
# a range's canonical id, `[]` per array. Growth of the relation is by ADDING columns — consumers
# select by name, never `SELECT *` positionally. Scoping / read-only / privileges / cost are the
# same model as jed_tables (pinned there). jed-specific, so CROSS-CORE-checked, NOT
# PostgreSQL-oracle-checked.
# requires: introspect.columns, introspect.tables, ddl.create_table, ddl.primary_key, ddl.composite_primary_key, ddl.not_null, dml.insert, query.select, query.where_eq, query.order_by, query.join_inner, query.aggregates, resource.cost_metering, types.i16, types.i32, types.i64, types.text, types.varchar_length, types.boolean_storable, types.decimal, types.bytea, types.uuid, types.timestamp, types.timestamptz, types.interval, types.f32, types.f64, types.date, types.json, types.jsonb, types.composite, types.array, types.array_composite, types.range

# --- an empty database yields no column rows ------------------------------------------------------

query T rowsort
SELECT name FROM jed_columns
----

# --- the full scalar surface: one column per canonical type text ----------------------------------

statement ok
CREATE TABLE scalars (
  a i16,
  b i32,
  c i64,
  d text,
  e varchar(10),
  f boolean,
  g decimal,
  h decimal(8,2),
  i bytea,
  j uuid,
  k timestamp,
  l timestamptz,
  m interval,
  n f32,
  o f64,
  p date,
  q json,
  r jsonb
)

# aliases normalize to the canonical name (int → i32, character names → text, numeric → decimal)
query ITT nosort
SELECT ordinal, name, type FROM jed_columns WHERE table_name = 'scalars' ORDER BY ordinal
