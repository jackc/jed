# Regular-expression match operators `~` `~*` `!~` `!~*` (spec/design/regex.md, grammar.md §22b).
# jed's own RE2-able flavor (a linear-time Pike VM, NOT PostgreSQL-compatible), but the BASIC subset
# tested here AGREES with PostgreSQL, so these rows oracle-check (rake corpus:check). UNANCHORED
# (matches a substring); text×text→boolean; NULL propagates; non-text 42804; malformed pattern 2201B.
# Match is by Unicode code point. The flavor-divergent surface (backreferences, lookaround — which PG
# accepts but jed rejects 2201B) is NOT exercised here; the per-step cost + capture detail live in the
# cross-core fixtures spec/regex/{program,match}_vectors.toml. Verified against PostgreSQL 18.
# Format + `requires`: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.where_eq, query.order_by, query.subquery_scalar, query.aggregates, expr.regex_match, expr.regex_imatch, expr.comparison_value, types.i32, types.text, null.three_valued, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, s text)

statement ok
INSERT INTO t VALUES (1, 'alice'), (2, 'bob'), (3, 'carol'), (4, NULL)

# `~` matches a SUBSTRING (unanchored, unlike LIKE): 'a' occurs in alice and carol.
query I nosort
SELECT id FROM t WHERE s ~ 'a' ORDER BY id
----
1
3

# `^` anchors at the start: only alice starts with 'a'.
query I nosort
SELECT id FROM t WHERE s ~ '^a' ORDER BY id
----
1

# `!~` is the negation; the NULL row is UNKNOWN and dropped. bob/carol contain 'o', alice does not.
query I nosort
SELECT id FROM t WHERE s !~ 'o' ORDER BY id
----
1

# `~*` is case-insensitive.
query I nosort
SELECT id FROM t WHERE s ~* 'ALICE' ORDER BY id
----
1

# A one-row table to evaluate constant patterns (anchors, classes, quantifiers, edges).
statement ok
CREATE TABLE one (id i32 PRIMARY KEY)

statement ok
INSERT INTO one VALUES (1)

# Unanchored substring vs. anchored.
query B nosort
SELECT 'abc' ~ 'b' FROM one
----
true

query B nosort
SELECT 'abc' ~ '^b' FROM one
----
false

query B nosort
SELECT 'abc' ~ 'c$' FROM one
----
true

# Alternation + grouping + whole-string anchors.
query B nosort
SELECT 'cat' ~ '^(cat|dog)$' FROM one
----
true

query B nosort
SELECT 'fish' ~ '^(cat|dog)$' FROM one
----
false

# Greedy quantifiers.
query B nosort
SELECT 'aaa' ~ '^a+$' FROM one
----
true

query B nosort
SELECT 'aaab' ~ '^a+$' FROM one
----
false

# Bounded repetition {n,m}.
query B nosort
SELECT 'aa' ~ '^a{2,3}$' FROM one
----
true

query B nosort
SELECT 'a' ~ '^a{2,3}$' FROM one
----
false

# Predefined class \d and a counted repeat.
query B nosort
SELECT 'x123y' ~ '\d{3}' FROM one
----
true

query B nosort
SELECT 'x12y' ~ '\d{3}' FROM one
----
false

# Character class with a range and negation.
query B nosort
SELECT 'b' ~ '^[a-c]$' FROM one
----
true

query B nosort
SELECT 'z' ~ '^[^a-c]$' FROM one
----
true

# `.` matches any code point EXCEPT newline.
query B nosort
SELECT 'axc' ~ '^a.c$' FROM one
----
true

# Case-insensitive `~*` and `!~*`.
query B nosort
SELECT 'FOO' ~* 'foo' FROM one
----
true

query B nosort
SELECT 'FOO' !~* 'bar' FROM one
----
true

# NULL on either side propagates (before the matcher runs).
query B nosort
SELECT NULL ~ 'a' FROM one
----
NULL

query B nosort
SELECT 'a' ~ NULL FROM one
----
NULL

# Code-point matching — the astral 😀 is ONE code point, so `.` matches it (a UTF-16-iterating core
# would see two units and get this wrong).
query B nosort
SELECT '😀x' ~ '^.x$' FROM one
----
true

# Metamorphic (involution): `~` and `!~` are exact negations, so `(s ~ p) <> (s !~ p)` is TRUE for
# every non-NULL row (and NULL — dropped — for the NULL row). A core that implemented `!~` as
# anything but the negation of `~` would drop a row here.
query I nosort
SELECT id FROM t WHERE (s ~ 'a') <> (s !~ 'a') ORDER BY id
----
1
2
3

# Metamorphic (ternary-logic partitioning): every row is in exactly one of `p` TRUE / `NOT p` /
# `p IS NULL`, so the three partition counts sum to the whole table (4 rows) for the regex predicate.
query I nosort
SELECT (SELECT count(*) FROM t WHERE s ~ 'o')
     + (SELECT count(*) FROM t WHERE NOT (s ~ 'o'))
     + (SELECT count(*) FROM t WHERE (s ~ 'o') IS NULL) FROM one
----
4

# Cost (cost.md §3 "regex compile/step"): the `~` node charges one operator_eval, plus regex_compile
# (the constant pattern's program size — once) and regex_step (the Pike-VM thread-steps). One-row
# scan = 1 storage_row_read + 1 page_read + 1 row_produced. Pattern 'a' compiles to 7 instructions
# (regex_compile = 7); matching 'xay' is 16 regex_step (match_vectors.toml). Total = 1+1+1+1+7+16.
# names: ?column?
# cost: 27
query B nosort
SELECT 'xay' ~ 'a' FROM one
----
true

# A non-text operand is a type error.
statement error 42804
SELECT 5 ~ '5' FROM one

# Malformed patterns are 2201B (PostgreSQL agrees on these).
statement error 2201B
SELECT 'a' ~ '(' FROM one

statement error 2201B
SELECT 'a' ~ 'a{2,1}' FROM one

statement error 2201B
SELECT 'a' ~ '[a' FROM one
