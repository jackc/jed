# Additional EXACT numeric scalar functions (spec/functions/catalog.toml, kind = "function"):
# sign, mod, div, gcd, lcm, factorial, width_bucket — the exact follow-ons named in float.md §8.
# Unlike the float transcendentals these are EXACT and IN-CONTRACT (byte-identical cross-core, no
# determinism-ledger entry): integer/decimal arithmetic is reproducible. They charge one
# operator_eval per call and propagate NULL. arg_resolution = "none": like sqrt, a bare integer
# where only a decimal/float overload exists is 42883 (no implicit cross-family promotion — a
# documented divergence from PG's implicit cast, oracle_overrides.toml). PostgreSQL-oracle-checked.
# Gated by the type capabilities the overloads use. Format: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.select_no_from, query.where_eq, types.i16, types.i32, types.i64, types.decimal, types.f64, resource.cost_metering

statement ok
CREATE TABLE nm (id i32 PRIMARY KEY, d numeric, f f64)

statement ok
INSERT INTO nm VALUES
  (1, 1.50, 2.5),
  (2, -2.5, -1.5),
  (3, 0.00, 0.0),
  (4, NULL, NULL)

# --- sign(numeric): -1 / 0 / +1 at scale 0 --------------------------------------------
query D nosort
SELECT sign(d) FROM nm WHERE id = 1
----
1

query D nosort
SELECT sign(d) FROM nm WHERE id = 2
----
-1

query D nosort
SELECT sign(d) FROM nm WHERE id = 3
----
0

# NULL propagates
query D nosort
SELECT sign(d) FROM nm WHERE id = 4
----
NULL

# --- sign(f64): EXACT, in-contract; sign(NaN) = 0, sign(±Inf) = ±1 --------------------
query R nosort
SELECT sign(f) FROM nm WHERE id = 1
----
1

query R nosort
SELECT sign(f) FROM nm WHERE id = 2
----
-1

query R nosort
SELECT sign(f64 'NaN')
----
0

query R nosort
SELECT sign(f64 'Infinity')
----
1

query R nosort
SELECT sign(f64 '-Infinity')
----
-1

# sign over a bare integer is 42883: no implicit int→decimal/float promotion (like sqrt(int)).
statement error 42883
SELECT sign(2)

# --- mod(a, b): the function spelling of the `%` (mod) operator; sign of the dividend --
query I nosort
SELECT mod(5, 3)
----
2

query I nosort
SELECT mod(-5, 3)
----
-2

query I nosort
SELECT mod(5, -3)
----
2

# mod over numeric (the integer divisor widens): result scale max(s1, s2)
query D nosort
SELECT mod(5.5, 2)
----
1.5

query D nosort
SELECT mod(-5.5, 2)
----
-1.5

# mod by zero traps 22012, exactly like the `%` operator
statement error 22012
SELECT mod(7, 0)

# --- div(a, b): truncated (toward zero) integer quotient at scale 0 -------------------
# integer operands promote to numeric (PG div(int,int) → numeric)
query D nosort
SELECT div(9, 4)
----
2

# truncation toward zero: div(9.5, 2) = 4 (not the rounded 5)
query D nosort
SELECT div(9.5, 2)
----
4

query D nosort
SELECT div(-9.5, 2)
----
-4

query D nosort
SELECT div(9.5, -2)
----
-4

# div over a NULL numeric column propagates
query D nosort
SELECT div(d, 2) FROM nm WHERE id = 4
----
NULL

# div by zero traps 22012
statement error 22012
SELECT div(7, 0)

# --- gcd(a, b): greatest common divisor, non-negative; gcd(0, 0) = 0 ------------------
query I nosort
SELECT gcd(12, 18)
----
6

# sign is dropped (result is non-negative)
query I nosort
SELECT gcd(-12, 18)
----
6

query I nosort
SELECT gcd(0, 5)
----
5

query I nosort
SELECT gcd(0, 0)
----
0

# gcd over numerics: result scale = max(sₐ, s_b)
query D nosort
SELECT gcd(8.40, 3.6)
----
1.20

query D nosort
SELECT gcd(6.0, 4.0)
----
2.0

# --- lcm(a, b): least common multiple, non-negative; lcm(_, 0) = 0 --------------------
query I nosort
SELECT lcm(4, 6)
----
12

query I nosort
SELECT lcm(-4, 6)
----
12

query I nosort
SELECT lcm(0, 5)
----
0

# lcm over numerics: result scale = max(sₐ, s_b)
query D nosort
SELECT lcm(8.40, 3.6)
----
25.20

# lcm overflow traps 22003 (the i64 product exceeds the type; bare integer literals are i64)
statement error 22003
SELECT lcm(9223372036854775807, 9223372036854775806)

# --- factorial(n): n! as exact numeric at scale 0 ------------------------------------
query D nosort
SELECT factorial(0)
----
1

query D nosort
SELECT factorial(5)
----
120

# beyond i64 range, exact (the result is arbitrary-precision numeric)
# cost: 51
query D nosort
SELECT factorial(25)
----
15511210043330985984000000

# a negative operand is undefined → 22003
statement error 22003
SELECT factorial(-3)

# --- width_bucket(op, low, high, count): equi-width histogram bucket -------------------
# numeric: bucket 3 of [0,10)/5; at low → 1; at/above high → count+1; below low → 0
query I nosort
SELECT width_bucket(5.0, 0, 10, 5)
----
3

query I nosort
SELECT width_bucket(0, 0, 10, 5)
----
1

query I nosort
SELECT width_bucket(10, 0, 10, 5)
----
6

query I nosort
SELECT width_bucket(-1, 0, 10, 5)
----
0

# a reversed (low > high) range buckets descending
query I nosort
SELECT width_bucket(5.0, 10, 0, 5)
----
3

# float overload (same index, computed in f64)
query I nosort
SELECT width_bucket(2.5::f64, 0::f64, 10::f64, 4)
----
2

# count <= 0 → 2201G
statement error 2201G
SELECT width_bucket(5.0, 0, 10, 0)

# equal bounds → 2201G
statement error 2201G
SELECT width_bucket(5.0, 3, 3, 5)

# a NaN operand on the float overload → 2201G
statement error 2201G
SELECT width_bucket(f64 'NaN', 0::f64, 10::f64, 5)

# --- scale(numeric): the display (fractional-digit) scale -----------------------------
query I nosort
SELECT scale(1.50)
----
2

query I nosort
SELECT scale(120.0)
----
1

query I nosort
SELECT scale(5.000)
----
3

query I nosort
SELECT scale(d) FROM nm WHERE id = 4
----
NULL

# --- min_scale(numeric): the smallest scale that represents the value exactly ----------
query I nosort
SELECT min_scale(1.50)
----
1

query I nosort
SELECT min_scale(1.00)
----
0

query I nosort
SELECT min_scale(0.0)
----
0

query I nosort
SELECT min_scale(120.0)
----
0

# a value with no trailing zeros keeps its scale
query I nosort
SELECT min_scale(1.23)
----
2

# --- trim_scale(numeric): drop trailing zeros (value-identical) ------------------------
query D nosort
SELECT trim_scale(1.50)
----
1.5

query D nosort
SELECT trim_scale(1.00)
----
1

query D nosort
SELECT trim_scale(120.0)
----
120

# no trailing zeros → unchanged
query D nosort
SELECT trim_scale(1.23)
----
1.23

# --- ceil / ceiling(numeric): round toward +∞ to scale 0 (decimal.md §6) --------------
query D nosort
SELECT ceil(2.3)
----
3

query D nosort
SELECT ceil(-2.3)
----
-2

# a fraction below zero rounds up to zero (no negative zero)
query D nosort
SELECT ceil(-0.5)
----
0

# an exact-integer value drops to scale 0 (ceil(2.00) is 2, not 2.00)
query D nosort
SELECT ceil(2.00)
----
2

# ceiling is the alias of ceil
query D nosort
SELECT ceiling(2.3)
----
3

query D nosort
SELECT ceiling(-2.3)
----
-2

# NULL propagates
query D nosort
SELECT ceil(d) FROM nm WHERE id = 4
----
NULL

# --- floor(numeric): round toward −∞ to scale 0 --------------------------------------
query D nosort
SELECT floor(2.7)
----
2

query D nosort
SELECT floor(-2.3)
----
-3

query D nosort
SELECT floor(0.5)
----
0

query D nosort
SELECT floor(-0.5)
----
-1

query D nosort
SELECT floor(2.00)
----
2

query D nosort
SELECT floor(d) FROM nm WHERE id = 4
----
NULL

# --- trunc(numeric): truncate toward zero to scale 0 ---------------------------------
query D nosort
SELECT trunc(2.7)
----
2

# toward zero: a negative truncates UP toward zero (unlike floor)
query D nosort
SELECT trunc(-2.7)
----
-2

query D nosort
SELECT trunc(0.9)
----
0

query D nosort
SELECT trunc(d) FROM nm WHERE id = 4
----
NULL

# --- trunc(numeric, n): truncate toward zero to n fractional places ------------------
query D nosort
SELECT trunc(1.567, 2)
----
1.56

# toward zero, NOT rounded (1.567 truncated to 2 places is 1.56, not 1.57)
query D nosort
SELECT trunc(-1.567, 2)
----
-1.56

# n greater than the value's scale pads with zeros (the display scale becomes n)
query D nosort
SELECT trunc(1.5, 3)
----
1.500

# a negative n truncates to the LEFT of the point (a multiple of 10^-n, scale 0)
query D nosort
SELECT trunc(1234.5, -2)
----
1200

query D nosort
SELECT trunc(1289.5, -2)
----
1200

# --- integer overloads return numeric (like round; PG resolves single-arg ceil/floor/
# --- trunc(int) to double precision — a documented result-type divergence, value-identical) ---
query D nosort
SELECT ceil(5)
----
5

query D nosort
SELECT floor(5)
----
5

query D nosort
SELECT trunc(5)
----
5

# trunc(int, int) is numeric in PostgreSQL too (its 2-arg trunc is numeric-only), so no divergence
query D nosort
SELECT trunc(150, -1)
----
150

# --- a non-numeric argument is 42883 (no such function; no implicit cast) -------------
statement error 42883
SELECT ceil(true)

statement error 42883
SELECT trunc(true)

# --- ceil/floor/trunc are valid in WHERE and over an arithmetic sub-expression --------
query I nosort
SELECT id FROM nm WHERE floor(d) = 1 ORDER BY id
----
1

# cost: 5
query D nosort
SELECT trunc(d, 1) FROM nm WHERE id = 1
----
1.5
