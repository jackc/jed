# Integer arithmetic in the general expression evaluator: + - * / %, operator
# precedence, parenthesization, and projection of computed columns. Overflow traps
# 22003 at the RESULT type's boundary (i32 + i32 overflows at i32, not i64);
# division and modulo by zero are a defined trap, 22012. Integer division truncates
# toward zero and the remainder takes the dividend's sign (spec/design/types.md §3,
# spec/design/functions.md §7). Format + `requires`: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.where_eq, query.order_by, types.i16, types.i32, types.i64, cast.explicit, expr.arithmetic, expr.parens, expr.precedence, error.overflow_trap, error.division_by_zero

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, a i32, b i32)

statement ok
INSERT INTO t VALUES (1, 6, 4)

statement ok
INSERT INTO t VALUES (2, 20, 6)

statement ok
INSERT INTO t VALUES (3, -7, 3)

# multiplication binds tighter than addition: 6 + 4 * 2 = 14, not 20
query I nosort
SELECT 6 + 4 * 2 FROM t WHERE id = 1
----
14

# parentheses override precedence: (6 + 4) * 2 = 20
query I nosort
SELECT (6 + 4) * 2 FROM t WHERE id = 1
----
20

# the four operators over columns
query I nosort
SELECT a + b FROM t WHERE id = 2
----
26

query I nosort
SELECT a - b FROM t WHERE id = 2
----
14

query I nosort
SELECT a * b FROM t WHERE id = 2
----
120

# integer division truncates toward zero; 20 / 6 = 3
query I nosort
SELECT a / b FROM t WHERE id = 2
----
3

# modulo; 20 % 6 = 2
query I nosort
SELECT a % b FROM t WHERE id = 2
----
2

# truncation toward zero and remainder sign follow the (negative) dividend:
# -7 / 3 = -2, -7 % 3 = -1
query I nosort
SELECT a / b FROM t WHERE id = 3
----
-2

query I nosort
SELECT a % b FROM t WHERE id = 3
----
-1

# arithmetic in a WHERE predicate (a + b = 26 holds only for row 2)
query I nosort
SELECT id FROM t WHERE a + b = 26 ORDER BY id
----
2

# division by zero is defined: it traps 22012
statement error 22012
SELECT a / 0 FROM t WHERE id = 1

# modulo by zero likewise
statement error 22012
SELECT a % 0 FROM t WHERE id = 1

# A separate table at the i32 boundary, so the overflow row does not poison the
# full-scan arithmetic predicate above.
statement ok
CREATE TABLE edge (id i32 PRIMARY KEY, a i32, b i32)

statement ok
INSERT INTO edge VALUES (1, 2147483647, 1)

# i32 + i32 overflows at the i32 boundary — the result type is i32, even
# though 2147483647 + 1 fits i64
statement error 22003
SELECT a + b FROM edge WHERE id = 1

# the SAME values widened to i64 do NOT overflow — the trap is at the result type
query I nosort
SELECT CAST(a AS i64) + b FROM edge WHERE id = 1
----
2147483648

# --- INT_MIN / -1 overflow: the negation of the most-negative value has no positive ----
# counterpart, so the division overflows at the result type and traps 22003 (matching PG,
# which raises "out of range" — and the hardware IDIV trap a naive core would hit). Pinned
# for all three widths; values staged via columns so the trap fires in the runtime
# evaluator over stored operands. (The literal -9223372036854775808 is itself writable —
# the unary-minus fold reaches i64's minimum; unary_minus.test pins that boundary.)
statement ok
CREATE TABLE divmin (id i32 PRIMARY KEY, i16 i16, i32 i32, i64 i64, neg1 i64)

statement ok
INSERT INTO divmin VALUES (1, -32768, -2147483648, -9223372036854775808, -1)

statement error 22003
SELECT i16 / CAST(neg1 AS i16) FROM divmin WHERE id = 1

statement error 22003
SELECT i32 / CAST(neg1 AS i32) FROM divmin WHERE id = 1

statement error 22003
SELECT i64 / neg1 FROM divmin WHERE id = 1

# --- INT_MIN % -1: the remainder is mathematically 0 for EVERY value, so it never traps —
# unlike the division above. All three widths return 0, including int64_min % -1, where each
# core special-cases divisor -1 rather than letting the 64-bit IDIV fault (types.md §3).
# Matches PostgreSQL.
query I nosort
SELECT i16 % CAST(neg1 AS i16) FROM divmin WHERE id = 1
----
0

query I nosort
SELECT i32 % CAST(neg1 AS i32) FROM divmin WHERE id = 1
----
0

query I nosort
SELECT i64 % neg1 FROM divmin WHERE id = 1
----
0
