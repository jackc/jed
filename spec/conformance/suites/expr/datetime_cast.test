# Cross-family datetime casts — timestamp / timestamptz / date "in a zone" (spec/design/timezones.md
# §9.3, spec/types/casts.toml). The six explicit cast pairs; the ones crossing the timestamptz
# boundary consult the SESSION zone. Oracle-checked against postgres:18. A timestamptz OUTPUT under a
# non-UTC session is rendered via AT TIME ZONE 'UTC' (jed renders a timestamptz in UTC regardless of
# the slot — the rendering follow-on, §9.5), so the test sees a zone-free wall clock.
#
# Format + the `requires` gate: ../../../design/conformance.md.
# requires: query.select, query.select_no_from, types.timestamp, types.timestamptz, types.date, cast.datetime, expr.at_time_zone, session.timezone

# ============================================================================================
# zone-free pairs: timestamp <-> date (no session zone involved)
# ============================================================================================

# timestamp -> date: the date part
query T nosort
SELECT (timestamp '2024-03-15 13:47:23.456')::date
----
2024-03-15

# date -> timestamp: midnight
query T nosort
SELECT (date '2024-03-15')::timestamp
----
2024-03-15 00:00:00

# the CAST(...) spelling is equivalent
query T nosort
SELECT CAST(timestamp '2024-03-15 13:47:23' AS date)
----
2024-03-15

# ============================================================================================
# timestamptz -> timestamp / date under a non-UTC session zone: render the instant locally.
# 02:30 UTC on 2024-03-15 is 22:30 on the 14th in New York (EDT -04).
# ============================================================================================

# timezone: America/New_York
query T nosort
SELECT (timestamptz '2024-03-15 02:30:00+00')::timestamp
----
2024-03-14 22:30:00

# timezone: America/New_York
query T nosort
SELECT (timestamptz '2024-03-15 02:30:00+00')::date
----
2024-03-14

# ============================================================================================
# timestamp / date -> timestamptz under a non-UTC session zone: interpret the wall clock in the
# zone (the result is a timestamptz, rendered via AT TIME ZONE 'UTC' to its UTC wall clock — §9.5).
# 02:30 in New York (EDT -04) is 06:30 UTC; New-York midnight on the 15th is 04:00 UTC.
# ============================================================================================

# timezone: America/New_York
query T nosort
SELECT (timestamp '2024-03-15 02:30:00')::timestamptz AT TIME ZONE 'UTC'
----
2024-03-15 06:30:00

# timezone: America/New_York
query T nosort
SELECT (date '2024-03-15')::timestamptz AT TIME ZONE 'UTC'
----
2024-03-15 04:00:00

# DST gap: 02:30 on 2024-03-10 does not exist in New York (spring forward 02:00->03:00); PG resolves
# it forward to 03:30 EDT = 07:30 UTC.
# timezone: America/New_York
query T nosort
SELECT (timestamp '2024-03-10 02:30:00')::timestamptz AT TIME ZONE 'UTC'
----
2024-03-10 07:30:00

# DST overlap: 01:30 on 2024-11-03 occurs twice (fall back); PG picks the standard-time reading
# (EST -05 = 06:30 UTC).
# timezone: America/New_York
query T nosort
SELECT (timestamp '2024-11-03 01:30:00')::timestamptz AT TIME ZONE 'UTC'
----
2024-11-03 06:30:00

# ============================================================================================
# under the default UTC session, a timestamptz result renders directly (no AT TIME ZONE needed)
# ============================================================================================

query T nosort
SELECT (timestamp '2024-03-15 02:30:00')::timestamptz
----
2024-03-15 02:30:00+00

query T nosort
SELECT (date '2024-03-15')::timestamptz
----
2024-03-15 00:00:00+00

# ============================================================================================
# ±infinity and NULL pass through
# ============================================================================================

query TT nosort
SELECT (timestamptz 'infinity')::timestamp, (timestamp 'infinity')::date
----
infinity
infinity

query T nosort
SELECT (date '-infinity')::timestamptz
----
-infinity

query T nosort
SELECT CAST(CAST(NULL AS timestamptz) AS date)
----
NULL

# (A non-datetime / non-literal-text source to a datetime target is a deferred 0A000 in jed where PG
# differs — text->datetime is a valid PG cast, int->datetime is PG 42846 — so it is a per-core unit
# test, not an oracle corpus entry.)
