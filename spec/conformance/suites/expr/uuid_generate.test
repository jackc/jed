# UUID generator functions (spec/design/entropy.md) — uuidv4() and uuidv7([shift interval]),
# VOLATILE, on the host-injected entropy+clock seam. The `# seed:` and `# clock:` directives pin
# the PRNG seed and the statement clock for the next record, so the output is fully deterministic
# and byte-identical across Rust/Go/TS — the generators are tested with EXACT assertions, not a
# property check. NOT oracle-imported (PG's entropy differs); expected values come from the spec'd
# splitmix64 PRNG (spec/encoding/prng.toml). uuidv7 folds a per-statement monotonic counter into
# rand_a, so successive calls sort in generation order. Format: ../../../design/conformance.md.
# requires: query.select, query.select_no_from, query.set_returning, types.uuid, types.timestamptz, types.interval, types.boolean, func.uuid_generate, func.uuid_extract, resource.cost_metering

# --- uuidv4: a fixed seed produces a fixed v4 uuid (two splitmix64 draws) -------------------
# seed: 1
# cost: 2
query T nosort
SELECT uuidv4()
----
910a2dec-8902-4cc1-beeb-8da1658eec67

# cost is independent of the random values: the SAME query under a different seed still costs 2.
# seed: 2
# cost: 2
query T nosort
SELECT uuidv4()
----
975835de-1c97-46ce-bfc8-46100bfc1e42

# --- uuidv7: the injected clock is embedded as the 48-bit ms field; version 7, RFC variant ---
# seed: 1
# clock: 1721056591872000
# cost: 2
query T nosort
SELECT uuidv7()
----
0190b6f7-8000-7000-910a-2dec89025cc1

# the embedded timestamp round-trips through uuid_extract_timestamp (pure inverse) ----------
# seed: 1
# clock: 1721056591872000
query T nosort
SELECT uuid_extract_timestamp(uuidv7())
----
2024-07-15 15:16:31.872+00

# --- monotonicity: within one statement-millisecond, the per-statement counter orders v7 ----
# the left call (counter 0) precedes the right call (counter 1), so the comparison is TRUE.
# seed: 1
# clock: 1721056591872000
query B nosort
SELECT uuidv7() < uuidv7()
----
true

# the two successive v7s, fully spelled — counter 0 then counter 1 in rand_a (bytes 6..7),
# distinct rand_b from successive PRNG draws. Pins the monotonic counter as cross-core truth.
# seed: 1
# clock: 1721056591872000
query TT nosort
SELECT uuidv7(), uuidv7()
----
0190b6f7-8000-7000-910a-2dec89025cc1
0190b6f7-8000-7001-beeb-8da1658eec67

# --- the optional `interval` shift offsets the embedded instant (calendar-aware arithmetic) --
# seed: 1
# clock: 1721056591872000
query T nosort
SELECT uuid_extract_timestamp(uuidv7(interval '1 hour'))
----
2024-07-15 16:16:31.872+00

# --- multi-row: each row draws fresh randomness → distinct values (rowsort, order unasserted)
# seed: 1
query T rowsort
SELECT uuidv4() FROM generate_series(1, 3)
----
910a2dec-8902-4cc1-beeb-8da1658eec67
f893a2ee-fb32-455e-b1c1-8690ee42c90b
71bb54d8-d101-45b9-834d-0bff90150280

# --- an out-of-range (pre-epoch) injected clock traps 22008 ---------------------------------
# seed: 1
# clock: -1000000
statement error 22008
SELECT uuidv7()
