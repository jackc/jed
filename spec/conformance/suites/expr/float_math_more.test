# Additional float math functions (spec/functions/catalog.toml, kind = "function") over f64,
# the easy follow-ons named in float.md §8: cbrt, the constant pi(), radians / degrees, the
# inverse-trig family (asin / acos / atan / atan2 / cot), the hyperbolics
# (sinh / cosh / tanh / asinh / acosh / atanh), and the PG-name `power` (an alias for jed's
# `pow`). Each takes the float family and returns f64 (the `R` render tag — compared by parsed
# value at tolerance, conformance.md §1), charges one operator_eval per call, and propagates
# NULL. They are TRANSCENDENTAL — exempted from cross-core byte-identity (native libm differs by
# an ULP) and share the `float-transcendental` determinism ledger entry; the out-of-domain
# trig functions return a NaN (PG-faithful), NOT a 22003. Argument resolution is `none`: a bare
# integer/decimal literal does NOT promote to float, so these are exercised through f64 columns
# and explicit f64 literals. PostgreSQL-oracle-checked (postgres:18). Gated by types.f64.
# Format: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.select_no_from, query.where_eq, types.i32, types.f64, resource.cost_metering

statement ok
CREATE TABLE m (id i32 PRIMARY KEY, x f64)

statement ok
INSERT INTO m VALUES
  (1, 27.0),
  (2, -8.0),
  (3, 2.0),
  (4, 0.0),
  (5, 1.0),
  (6, 0.5),
  (7, 180.0),
  (8, -1.0),
  (9, NULL)

# --- cbrt: the real cube root, defined for negatives (cbrt(-8) = -2), no domain trap ----
query R nosort
SELECT cbrt(x) FROM m WHERE id = 1
----
3

query R nosort
SELECT cbrt(x) FROM m WHERE id = 2
----
-2

query R nosort
SELECT cbrt(x) FROM m WHERE id = 3
----
1.2599210498948734

query R nosort
SELECT cbrt(x) FROM m WHERE id = 4
----
0

# cbrt of an irrational and a non-integer cube
query R nosort
SELECT cbrt(x) FROM m WHERE id = 6
----
0.7937005259840998

# NULL propagates
query R nosort
SELECT cbrt(x) FROM m WHERE id = 9
----
NULL

# --- pi(): the constant π, a zero-arg function (no FROM) ---------------------------------
query R nosort
SELECT pi()
----
3.141592653589793

# pi() composes in a float expression (f64 + f64; 2·π is an exact double)
query R nosort
SELECT pi() + pi()
----
6.283185307179586

# --- radians(x): degrees → radians; radians(180) = π exactly --------------------------
query R nosort
SELECT radians(x) FROM m WHERE id = 7
----
3.141592653589793

query R nosort
SELECT radians(x) FROM m WHERE id = 5
----
0.017453292519943295

query R nosort
SELECT radians(x) FROM m WHERE id = 4
----
0

# NULL propagates
query R nosort
SELECT radians(x) FROM m WHERE id = 9
----
NULL

# --- degrees(x): radians → degrees; degrees(π) = 180 exactly --------------------------
query R nosort
SELECT degrees(pi())
----
180

query R nosort
SELECT degrees(x) FROM m WHERE id = 5
----
57.29577951308232

query R nosort
SELECT degrees(x) FROM m WHERE id = 4
----
0

# NULL propagates
query R nosort
SELECT degrees(x) FROM m WHERE id = 9
----
NULL

# --- asin(x): inverse sine in radians; domain [-1, 1] ---------------------------------
query R nosort
SELECT asin(x) FROM m WHERE id = 6
----
0.5235987755982989

query R nosort
SELECT asin(x) FROM m WHERE id = 5
----
1.5707963267948966

query R nosort
SELECT asin(x) FROM m WHERE id = 8
----
-1.5707963267948966

query R nosort
SELECT asin(x) FROM m WHERE id = 4
----
0

# out of domain (|x| > 1) → 22003
statement error 22003
SELECT asin(x) FROM m WHERE id = 1

# NULL propagates
query R nosort
SELECT asin(x) FROM m WHERE id = 9
----
NULL

# --- acos(x): inverse cosine in radians; domain [-1, 1] -------------------------------
query R nosort
SELECT acos(x) FROM m WHERE id = 6
----
1.0471975511965979

query R nosort
SELECT acos(x) FROM m WHERE id = 5
----
0

query R nosort
SELECT acos(x) FROM m WHERE id = 8
----
3.141592653589793

query R nosort
SELECT acos(x) FROM m WHERE id = 4
----
1.5707963267948966

# out of domain (|x| > 1) → 22003
statement error 22003
SELECT acos(x) FROM m WHERE id = 2

# NULL propagates
query R nosort
SELECT acos(x) FROM m WHERE id = 9
----
NULL

# --- atan(x): inverse tangent in radians; defined on all of ℝ (no domain trap) --------
query R nosort
SELECT atan(x) FROM m WHERE id = 5
----
0.7853981633974483

query R nosort
SELECT atan(x) FROM m WHERE id = 4
----
0

query R nosort
SELECT atan(x) FROM m WHERE id = 1
----
1.5337762109209665

# NULL propagates
query R nosort
SELECT atan(x) FROM m WHERE id = 9
----
NULL

# --- atan2(y, x): quadrant-aware inverse tangent of y/x -------------------------------
statement ok
CREATE TABLE m2 (id i32 PRIMARY KEY, y f64, x f64)

statement ok
INSERT INTO m2 VALUES
  (1, 1.0, 1.0),
  (2, 1.0, 0.0),
  (3, 0.0, 1.0),
  (4, -1.0, -1.0),
  (5, NULL, 1.0)

query R nosort
SELECT atan2(y, x) FROM m2 WHERE id = 1
----
0.7853981633974483

query R nosort
SELECT atan2(y, x) FROM m2 WHERE id = 2
----
1.5707963267948966

query R nosort
SELECT atan2(y, x) FROM m2 WHERE id = 3
----
0

# third quadrant (both negative): -3π/4
query R nosort
SELECT atan2(y, x) FROM m2 WHERE id = 4
----
-2.356194490192345

# a NULL operand propagates
query R nosort
SELECT atan2(y, x) FROM m2 WHERE id = 5
----
NULL

# --- cot(x): cotangent = 1/tan(x); cot(0) = +Infinity (not a trap) --------------------
query R nosort
SELECT cot(x) FROM m WHERE id = 5
----
0.6420926159343306

query R nosort
SELECT cot(x) FROM m WHERE id = 6
----
1.830487721712452

# cot(0) is +Infinity (PG-faithful; no error)
query R nosort
SELECT cot(x) FROM m WHERE id = 4
----
Infinity

# NULL propagates
query R nosort
SELECT cot(x) FROM m WHERE id = 9
----
NULL
