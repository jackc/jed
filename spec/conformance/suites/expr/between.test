# BETWEEN / NOT BETWEEN — the range predicate (spec/design/grammar.md §21). `x BETWEEN lo AND
# hi` is `x >= lo AND x <= hi`; NOT BETWEEN is its negation. The connective is the Kleene AND,
# so a NULL bound does NOT simply propagate: `5 BETWEEN 10 AND NULL` is `FALSE AND UNKNOWN` =
# FALSE (a FALSE operand dominates), while `5 BETWEEN 1 AND NULL` is `TRUE AND UNKNOWN` = NULL.
# Both bounds parse at the additive level, so the structural AND is not the logical connective
# and `x BETWEEN a AND b AND c` is `(x BETWEEN a AND b) AND c`. Verified against PostgreSQL 18.
# Format + `requires`: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.where_eq, query.comparison_order, query.order_by, query.logical_connectives, expr.between, expr.comparison_value, types.int16, types.int32, types.text, null.three_valued, resource.cost_metering

statement ok
CREATE TABLE t (id int32 PRIMARY KEY, a int32)

statement ok
INSERT INTO t VALUES (1, 5), (2, 15), (3, 25), (4, NULL)

# Range test: only a=15 falls in [10,20]; a=NULL is UNKNOWN (dropped). Cost: 4 scanned, the
# desugared `And(Ge(a,10), Le(a,20))` is 3 interior nodes per scanned row = 12, plus 1 produced.
# cost: 17
query I nosort
SELECT id FROM t WHERE a BETWEEN 10 AND 20 ORDER BY id
----
2

# NOT BETWEEN keeps the present values outside [10,20] (a=5, a=25); a=NULL stays UNKNOWN.
query I nosort
SELECT id FROM t WHERE a NOT BETWEEN 10 AND 20 ORDER BY id
----
1
3

# Projected as a boolean — a NULL `a` makes both bounds UNKNOWN, so the result is NULL.
# names: ?column?
query B nosort
SELECT a BETWEEN 1 AND 100 FROM t ORDER BY id
----
true
true
true
NULL

# A one-row table to evaluate constant predicates: the headline Kleene-AND cases.
statement ok
CREATE TABLE one (id int32 PRIMARY KEY)

statement ok
INSERT INTO one VALUES (1)

# `5 BETWEEN 10 AND NULL` = `(5>=10) AND (5<=NULL)` = `FALSE AND UNKNOWN` = FALSE — a FALSE
# operand dominates the Kleene AND, so a NULL bound does NOT poison the result here.
query B nosort
SELECT 5 BETWEEN 10 AND NULL FROM one
----
false

# `5 BETWEEN 1 AND NULL` = `TRUE AND UNKNOWN` = NULL — no FALSE to dominate, so it is UNKNOWN.
query B nosort
SELECT 5 BETWEEN 1 AND NULL FROM one
----
NULL

query B nosort
SELECT 5 BETWEEN 1 AND 10 FROM one
----
true

# Precedence: the second AND is the logical connective, so this is
# `(a BETWEEN 1 AND 20) AND (id = 2)` — only id=2 (a=15 is in range and id=2) survives.
query I nosort
SELECT id FROM t WHERE a BETWEEN 1 AND 20 AND id = 2 ORDER BY id
----
2

# A cross-family bound is a type error (an integer column vs a text bound).
statement error 42804
SELECT id FROM t WHERE a BETWEEN 1 AND 'x'

# An untyped integer-literal bound too wide for the column's type traps at resolve.
statement ok
CREATE TABLE s16 (id int32 PRIMARY KEY, v int16)

statement error 22003
SELECT id FROM s16 WHERE v BETWEEN 1 AND 100000
