# Unary minus as an expression operator, and the int64-minimum / 2^63 literal
# asymmetry. The sign is the unary-minus operator, not part of the literal: a bare
# magnitude up to 2^63 lexes, but only `-(2^63)` is representable (int64's minimum);
# a bare 2^63 fits no type and traps 22003 at resolve, and a magnitude beyond 2^63
# is a lex-time syntax error 42601 (spec/design/grammar.md §4, types.md §6).
# Format + `requires`: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.where_eq, types.int32, types.int64, expr.unary_minus, expr.arithmetic, error.overflow_trap

statement ok
CREATE TABLE t (id int32 PRIMARY KEY, a int32)

statement ok
INSERT INTO t VALUES (1, 5)

statement ok
INSERT INTO t VALUES (2, -2147483648)

# unary minus negates a column value
query I nosort
SELECT -a FROM t WHERE id = 1
----
-5

# double negation (with a space, so it is two operators, not a comment)
query I nosort
SELECT - -a FROM t WHERE id = 1
----
5

# G19 — unary minus binds TIGHTER than multiplicative `* /` (the tightest tower level), so
# `-2 * 3` is `(-2) * 3` = -6 and `-6 / 2` is `(-6) / 2` = -3.
query I nosort
SELECT -2 * 3 FROM t WHERE id = 1
----
-6

query I nosort
SELECT -6 / 2 FROM t WHERE id = 1
----
-3

# Unary minus also binds tighter than additive `+`, and THIS is value-observable: `-2 + 3` is
# `(-2) + 3` = 1, not `-(2 + 3)` = -5.
query I nosort
SELECT -2 + 3 FROM t WHERE id = 1
----
1

# `-a * b` parses as `(-a) * b`: with a=5, `-a * 2` is `(-5) * 2` = -10.
query I nosort
SELECT -a * 2 FROM t WHERE id = 1
----
-10

# unary minus reaches int64's minimum, which has no positive counterpart
query I nosort
SELECT -9223372036854775808 FROM t WHERE id = 1
----
-9223372036854775808

# a bare 2^63 (one past int64's maximum) fits no signed integer type -> 22003
statement error 22003
SELECT 9223372036854775808 FROM t WHERE id = 1

# a magnitude beyond 2^63 cannot be represented at all -> lex-time syntax error
statement error 42601
SELECT 9223372036854775809 FROM t WHERE id = 1

# negating int32's minimum overflows int32 (its positive counterpart does not fit)
statement error 22003
SELECT -a FROM t WHERE id = 2
