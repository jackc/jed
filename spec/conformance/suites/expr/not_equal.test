# Not-equal `<>` and its `!=` alias (spec/design/functions.md §1, grammar.md §4).
# `<>` is the 3VL negation of `=`: it propagates NULL exactly as `=` does, so a NULL
# operand makes the result UNKNOWN (rendered NULL) — `NULL <> NULL` is NULL, and `<>` is
# not "true across NULL". `!=` is PostgreSQL's alternate spelling and lexes to the SAME
# operator, so the two are interchangeable. Same operand contract as `=`: overloaded across
# the comparable families (integer with promotion, text, boolean, …), an untyped literal
# adapts to its sibling (a too-wide one traps 22003), and a cross-family pair is 42804.
# Format + `requires`: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, query.select, query.where_eq, query.comparison_order, query.order_by, expr.not_equal, expr.comparison_value, expr.parens, types.i16, types.i32, types.text, types.boolean, compare.promotion, null.three_valued

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, a i32, b i32)

statement ok
INSERT INTO t VALUES (1, 5, 5)

statement ok
INSERT INTO t VALUES (2, 5, 9)

statement ok
INSERT INTO t VALUES (3, 5, NULL)

statement ok
INSERT INTO t VALUES (4, NULL, 5)

statement ok
INSERT INTO t VALUES (5, NULL, NULL)

# Projected as a boolean: equal values are FALSE, differing values TRUE, and any NULL
# operand propagates to UNKNOWN (NULL) — `<>` is not reflexive across NULL.
query B nosort
SELECT a <> b FROM t ORDER BY id
----
false
true
NULL
NULL
NULL

# `!=` is the same operator (a lexer alias) — byte-identical results to `<>`.
query B nosort
SELECT a != b FROM t ORDER BY id
----
false
true
NULL
NULL
NULL

# `<>` is the exact negation of `=` on the present-value rows; both leave the NULL rows
# UNKNOWN (contrast against the `=` column below).
query B nosort
SELECT a = b FROM t ORDER BY id
----
true
false
NULL
NULL
NULL

# In WHERE only TRUE selects: `a <> b` keeps the one strictly-differing row; the equal row
# is FALSE and the three NULL rows are UNKNOWN, so all four are dropped.
query I nosort
SELECT id FROM t WHERE a <> b ORDER BY id
----
2

# The `!=` spelling selects the identical row set.
query I nosort
SELECT id FROM t WHERE a != b ORDER BY id
----
2

# An untyped integer literal adapts to the column type and compares by value: b <> 5 is
# TRUE only for row 2 (b = 9); the NULL b rows stay UNKNOWN and drop.
query I nosort
SELECT id FROM t WHERE b <> 5 ORDER BY id
----
2

# The classic NULL gotcha: `x <> NULL` is UNKNOWN for every row (NULL is not a value to
# differ from), so the filter selects nothing — exactly as PostgreSQL.
query I nosort
SELECT id FROM t WHERE a <> NULL ORDER BY id
----

# Cross-width operands promote exactly like `=` (i16 vs i32 widen to i32).
statement ok
CREATE TABLE w (id i32 PRIMARY KEY, s i16, n i32)

statement ok
INSERT INTO w VALUES (1, 7, 7)

statement ok
INSERT INTO w VALUES (2, 7, 8)

query I nosort
SELECT id FROM w WHERE s <> n ORDER BY id
----
2

# text `<>` compares by the `C` collation (code-point order); a NULL operand still
# propagates. y <> 'cat' is TRUE for 'dog', FALSE for 'cat', UNKNOWN for NULL.
statement ok
CREATE TABLE tt (id i32 PRIMARY KEY, x text, y text)

statement ok
INSERT INTO tt VALUES (1, 'cat', 'cat')

statement ok
INSERT INTO tt VALUES (2, 'cat', 'dog')

statement ok
INSERT INTO tt VALUES (3, 'cat', NULL)

query I nosort
SELECT id FROM tt WHERE y <> 'cat' ORDER BY id
----
2

# boolean `<>` (behaves as XOR) with three-valued propagation: `(a = 5) <> (b = 5)` is
# TRUE only where exactly one side is TRUE and neither is NULL.
query I nosort
SELECT id FROM t WHERE (a = 5) <> (b = 5) ORDER BY id
----
2

# Same operand contract as `=`: a cross-family pair (i32 vs text) has no comparison — 42804.
statement error 42804
SELECT id FROM t WHERE a <> 'x'

# And an untyped literal that overflows the column's type traps 22003 at resolve, before any
# row is scanned — the same literal range check `=` performs.
statement error 22003
SELECT id FROM w WHERE s <> 100000

# Non-associative, like the other comparisons: chaining is a syntax error.
statement error 42601
SELECT id FROM t WHERE a <> b <> b

# A lone `!` (not followed by `=`) is not part of the surface — a lex error.
statement error 42601
SELECT id FROM t WHERE a ! b
