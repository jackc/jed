# IN (list) / NOT IN — membership over a non-empty value list (spec/design/grammar.md §20).
# `x IN (a,b,c)` is the OR-chain PostgreSQL defines it as: `x = a OR x = b OR x = c`; `NOT IN`
# is its negation. So three-valued NULL falls out of the Kleene OR — `1 IN (2,NULL)` is NULL,
# `1 IN (1,NULL)` is TRUE (a match dominates), `1 NOT IN (2,NULL)` is NULL — and per-element
# typing reuses the `=` operand contract (a too-wide literal traps 22003, a cross-family
# element is 42804). The empty list `IN ()` is a 42601 syntax error. Verified against the
# live PostgreSQL 18 oracle.
# Format + `requires`: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.where_eq, query.order_by, expr.in_list, expr.comparison_value, types.i16, types.i32, types.i64, types.text, types.decimal, null.three_valued, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, a i32)

statement ok
INSERT INTO t VALUES (1, 10), (2, 20), (3, NULL)

# Projected as a boolean: a present value that matches is TRUE; a present value that matches
# nothing but the list has a NULL is UNKNOWN (the NOT-IN-with-NULL gotcha); a NULL `a` is
# UNKNOWN. `1 IN (1,NULL)` = TRUE because a match dominates the Kleene OR.
# names: ?column?
query B nosort
SELECT a IN (10, NULL) FROM t ORDER BY id
----
true
NULL
NULL

# With no NULL in the list, a non-matching present value is a definite FALSE; only the NULL
# `a` row is UNKNOWN.
query B nosort
SELECT a IN (10, 20) FROM t ORDER BY id
----
true
true
NULL

# NOT IN is the exact negation: NOT(true)=false, NOT(unknown)=unknown.
query B nosort
SELECT a NOT IN (10, NULL) FROM t ORDER BY id
----
false
NULL
NULL

# G19 — a single-NULL list `a IN (NULL)` desugars to the lone `a = NULL`, which is UNKNOWN for
# EVERY row (a present value compared to NULL, or a NULL `a`) — so the projection is all NULL.
# names: ?column?
query B nosort
SELECT a IN (NULL) FROM t ORDER BY id
----
NULL
NULL
NULL

# ...and in WHERE that UNKNOWN keeps no rows.
query I nosort
SELECT id FROM t WHERE a IN (NULL) ORDER BY id
----

# In WHERE, only rows whose predicate is TRUE survive: a=10 and a=20 match; a=NULL is dropped
# (UNKNOWN). Cost: 3 scanned, the desugared `Or(Eq(a,10),Eq(a,20))` is 3 interior nodes per
# scanned row (1 or + 2 eq, leaf column/constant operands free) = 9, plus 2 produced = 14.
# cost: 15
query I nosort
SELECT id FROM t WHERE a IN (10, 20) ORDER BY id
----
1
2

# NOT IN with a NULL in the list keeps NO rows: every present `a` is either a match (NOT IN
# false) or UNKNOWN (a non-match against the NULL element), and the NULL `a` is UNKNOWN too.
query I nosort
SELECT id FROM t WHERE a NOT IN (20, NULL) ORDER BY id
----

# A single-element list desugars to a lone equality.
query I nosort
SELECT id FROM t WHERE a IN (10) ORDER BY id
----
1

# Text IN list compares by the C collation; an exact element match wins.
statement ok
CREATE TABLE w (id i32 PRIMARY KEY, s text)

statement ok
INSERT INTO w VALUES (1, 'alice'), (2, 'bob'), (3, 'carol')

query T nosort
SELECT s FROM w WHERE s IN ('alice', 'carol') ORDER BY id
----
alice
carol

# Decimal IN compares by exact numeric value: 1.5 and 1.50 are equal, so the row matches.
statement ok
CREATE TABLE d (id i32 PRIMARY KEY, n numeric(5,2))

statement ok
INSERT INTO d VALUES (1, 1.50), (2, 2.00)

query I nosort
SELECT id FROM d WHERE n IN (1.5, 9.9) ORDER BY id
----
1

# G19 — cross-width IN: an i64 column against a list of untyped integer literals. Each element
# adapts to the column's i64 type through the `=` operand contract (the promotion tower), so a
# small-magnitude literal and one outside i32's range coexist in the same list. `v IN (10, 20)`
# matches the two small rows; `v IN (5000000000, 99)` matches the row whose value exceeds i32.
statement ok
CREATE TABLE big (id i32 PRIMARY KEY, v i64)

statement ok
INSERT INTO big VALUES (1, 10), (2, 20), (3, 5000000000)

# cost: 15
query I nosort
SELECT id FROM big WHERE v IN (10, 20) ORDER BY id
----
1
2

# cost: 14
query I nosort
SELECT id FROM big WHERE v IN (5000000000, 99) ORDER BY id
----
3

# Empty list is a syntax error (the parser requires at least one element).
statement error 42601
SELECT id FROM t WHERE a IN ()

# A cross-family element is a type error (an integer column vs a text element).
statement error 42804
SELECT id FROM t WHERE a IN (10, 'x')

# An untyped integer-literal element too wide for the column's type traps at resolve, before
# any row is scanned — the same literal range check `=` performs (types.md §6).
statement ok
CREATE TABLE s16 (id i32 PRIMARY KEY, v i16)

statement error 22003
SELECT id FROM s16 WHERE v IN (1, 100000)
