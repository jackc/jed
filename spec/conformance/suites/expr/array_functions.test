# Array function/operator surface AF1 (spec/design/array-functions.md): the polymorphic
# anyarray/anyelement resolution (§2) + the scalar-function-shaped surface (§3) — introspection
# (array_ndims/array_length/array_lower/array_upper/cardinality/array_dims) and the non-strict
# builders (array_append/array_prepend/array_cat). Introspection propagates NULL and returns NULL
# (or 0 for cardinality) for an out-of-shape request; the builders treat a NULL/empty array as the
# identity, reject a multidimensional array_append/prepend (22000), and 2202E on an incompatible
# array_cat. PostgreSQL-oracle-verified (postgres:18). A bare untyped NULL in a typed slot is out of
# scope (jed's existing 42883 strictness); NULL is exercised through typed NULL columns / casts.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.order_by, query.where_eq, types.array, types.array_multidim, types.i32, types.text, func.array, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, xs i32[], ys i32[])

# Row 1: a 3-element xs + a 2-element ys. Row 2: an EMPTY xs + a NULL ys. Row 3: a NULL xs.
statement ok
INSERT INTO t VALUES
  (1, ARRAY[10,20,30], ARRAY[40,50]),
  (2, '{}', NULL),
  (3, NULL, ARRAY[7,8,9])

# --- introspection: ndims / cardinality / dims --------------------------------------------
# A populated array reports its shape; the empty array {} is ndims/dims NULL but cardinality 0; a
# NULL array is NULL throughout (propagation).
query IIIT nosort
SELECT id, array_ndims(xs), cardinality(xs), array_dims(xs) FROM t ORDER BY id
----
1
1
3
[1:3]
2
NULL
0
NULL
3
NULL
NULL
NULL

# --- introspection: length / lower / upper (per dimension) ---------------------------------
# Dimension 1's length/bounds; NULL for the empty array and the NULL array.
query IIII nosort
SELECT id, array_length(xs,1), array_lower(xs,1), array_upper(xs,1) FROM t ORDER BY id
----
1
3
1
3
2
NULL
NULL
NULL
3
NULL
NULL
NULL

# array_length of dimension 2 of a 1-D value is NULL (out of range).
query II nosort
SELECT id, array_length(xs,2) FROM t WHERE id = 1
----
1
NULL

# G20 — a non-positive dimension index is out of range, so array_length returns NULL for dim 0 and
# for a negative dim (like the too-high dim above).
query II nosort
SELECT array_length(xs,0), array_length(xs,-1) FROM t WHERE id = 1
----
NULL
NULL

# --- builders: array_append / array_prepend (non-strict) ----------------------------------
# Append/prepend grow the array; a NULL or empty array yields the 1-D singleton.
query IT nosort
SELECT id, array_append(xs,99) FROM t ORDER BY id
----
1
{10,20,30,99}
2
{99}
3
{99}

query IT nosort
SELECT id, array_prepend(0,xs) FROM t ORDER BY id
----
1
{0,10,20,30}
2
{0}
3
{0}

# --- builders: array_cat (identity-aware) -------------------------------------------------
# Concatenate xs ‖ ys: a NULL/empty operand is the identity.
query IT nosort
SELECT id, array_cat(xs,ys) FROM t ORDER BY id
----
1
{10,20,30,40,50}
2
{}
3
{7,8,9}

# --- literal-expression forms (constant, evaluated over one row) ---------------------------
# Introspection over ARRAY[…] constructors.
query TII nosort
SELECT array_dims(ARRAY[10,20,30]), array_length(ARRAY[10,20,30],1), cardinality(ARRAY[10,20,30]) FROM t WHERE id = 1
----
[1:3]
3
3

# A multidimensional value: ndims 2, dimension-2 length 3, the [l:u][l:u] dims, total cardinality.
query IITI nosort
SELECT array_ndims(ARRAY[ARRAY[1,2,3],ARRAY[4,5,6]]), array_length(ARRAY[ARRAY[1,2,3],ARRAY[4,5,6]],2), array_dims(ARRAY[ARRAY[1,2,3],ARRAY[4,5,6]]), cardinality(ARRAY[ARRAY[1,2,3],ARRAY[4,5,6]]) FROM t WHERE id = 1
----
2
3
[1:2][1:3]
6

# A custom lower bound is preserved by append/prepend (the opposite bound grows).
query TT nosort
SELECT array_dims(array_append('[2:4]={7,8,9}'::i32[], 10)), array_dims(array_prepend(6, '[2:4]={7,8,9}'::i32[])) FROM t WHERE id = 1
----
[2:5]
[2:5]

# A NULL element is appended as a real NULL element; array_cat along the outer dimension stacks a row.
query TT nosort
SELECT array_append(ARRAY[1,2], NULL), array_cat(ARRAY[ARRAY[1,2],ARRAY[3,4]], ARRAY[5,6]) FROM t WHERE id = 1
----
{1,2,NULL}
{{1,2},{3,4},{5,6}}

# G20 — array_cat of two NULL arrays is NULL (each NULL operand is the identity, so the result is
# the other operand — here also NULL).
query T nosort
SELECT array_cat(NULL::i32[], NULL::i32[]) FROM t WHERE id = 1
----
NULL

# The N == M+1 dimension branch: a 1-D array concatenated with a 2-D array prepends as a leading
# row (the mirror of the 2-D ‖ 1-D case above, which appends a trailing row).
query T nosort
SELECT array_cat(ARRAY[5,6], ARRAY[ARRAY[1,2],ARRAY[3,4]]) FROM t WHERE id = 1
----
{{5,6},{1,2},{3,4}}

# text[] flows through the polymorphic builders unchanged.
query TT nosort
SELECT array_append(ARRAY['a','b'], 'c'), array_prepend('z', ARRAY['a','b']) FROM t WHERE id = 1
----
{a,b,c}
{z,a,b}

# --- errors -------------------------------------------------------------------------------
# array_append / array_prepend reject a multidimensional array (22000).
statement error 22000
SELECT array_append(ARRAY[ARRAY[1,2],ARRAY[3,4]], 9) FROM t WHERE id = 1

statement error 22000
SELECT array_prepend(9, ARRAY[ARRAY[1,2],ARRAY[3,4]]) FROM t WHERE id = 1

# array_cat of incompatible dimensionalities is 2202E.
statement error 2202E
SELECT array_cat(ARRAY[ARRAY[1,2]], ARRAY[ARRAY[3,4,5]]) FROM t WHERE id = 1

# An element-type conflict matches no overload (42883).
statement error 42883
SELECT array_cat(ARRAY[1,2], ARRAY['a','b']) FROM t WHERE id = 1
