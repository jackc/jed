# String / text scalar functions (spec/design/string-functions.md). Pure per-row text built-ins
# (PostgreSQL's "String Functions and Operators", manual §9.4), STRICT (a NULL argument → NULL).
# They reuse the generic scalar-function mold (functions.md §9): resolved by argument family, kernel
# by name, NULL short-circuited at eval, one operator_eval per call. The character-counting /
# character-indexing functions count UNICODE CODE POINTS (matching PG's UTF8 character semantics —
# NOT UTF-8 bytes nor UTF-16 units, the cross-core trap exercised by the astral 😀 below);
# octet_length / bit_length count UTF-8 bytes / bits. PostgreSQL-oracle-verified (postgres:18).
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.select_no_from, query.where_eq, query.order_by, types.i32, types.text, resource.cost_metering

# === length(text) → int: the number of characters (code points) ========================

query I
SELECT length('hello')
----
5

# 'héllo' is 5 code points but 6 UTF-8 bytes (é = 2 bytes) — length counts characters, not bytes.
query I
SELECT length('héllo')
----
5

# the empty string is 0 characters
query I
SELECT length('')
----
0

# an astral character (😀 = U+1F600) is ONE code point — but TWO UTF-16 units, so a naïve TS
# `.length` would over-count it as 2. The code-point count of 'a😀b' is 3.
query I
SELECT length('a😀b')
----
3

# NULL propagates
query I
SELECT length(NULL::text)
----
NULL

# length is valid anywhere an expression is (here in WHERE), like any scalar function.
statement ok
CREATE TABLE words (id i32 PRIMARY KEY, w text)

statement ok
INSERT INTO words VALUES (1, 'a'), (2, 'bb'), (3, 'ccc'), (4, NULL)

query IT rowsort
SELECT length(w), w FROM words WHERE length(w) >= 2
----
2
bb
3
ccc

# the cost of a single length() over a constant is the uniform scalar-function shape — node
# operator_eval + the literal argument's own eval + the one produced row — identical cross-core.
# cost: 2
query I
SELECT length('abc')
----
3

# === char_length / character_length: SQL-standard aliases of length ====================

query I
SELECT char_length('héllo')
----
5

query I
SELECT character_length('a😀b')
----
3

query I
SELECT char_length(''), character_length(NULL::text)
----
0
NULL

# === octet_length(text) → int: the number of UTF-8 BYTES (not characters) ==============

# 'héllo' is 6 bytes (é = 2 bytes) but 5 characters — octet_length counts bytes.
query I
SELECT octet_length('héllo')
----
6

# an astral character (😀) is 4 UTF-8 bytes; 'a😀b' is 6 bytes (1 + 4 + 1).
query I
SELECT octet_length('a😀b')
----
6

# empty string is 0 bytes; ASCII is one byte per character; NULL propagates.
query I
SELECT octet_length(''), octet_length('abc'), octet_length(NULL::text)
----
0
3
NULL

# === bit_length(text) → int: UTF-8 bits = octet_length × 8 =============================

query I
SELECT bit_length('héllo')
----
48

query I
SELECT bit_length('abc'), bit_length(''), bit_length(NULL::text)
----
24
0
NULL

# === substr(text, start[, count]) → text: the function form of SUBSTRING ================

# 2-arg form: characters from `start` to the end (1-based)
query T
SELECT substr('alphabet', 3)
----
phabet

# 3-arg form: `count` characters starting at `start`
query T
SELECT substr('alphabet', 3, 2)
----
ph

# start ≤ 0 clips: the window [0,3) keeps positions 1..2
query T
SELECT substr('alphabet', 0, 3)
----
al

# a negative start also clips (window [-2,3) → positions 1..2)
query T
SELECT substr('alphabet', -2, 5)
----
al

# count past the end clips to the end
query T
SELECT substr('alphabet', 5, 100)
----
abet

# start past the end, or count 0, yields the empty string (asserted via = '' since the harness
# cannot carry an empty / edge-whitespace value in an expected block)
query B
SELECT substr('alphabet', 100, 2) = '', substr('alphabet', 5, 0) = ''
----
true
true

# code-point indexed (not bytes): position 2 of 'héllo' is é
query T
SELECT substr('héllo', 2, 3)
----
éll

# a NEGATIVE count is 22011 (substring_error, "negative substring length not allowed")
statement error 22011
SELECT substr('abc', 1, -1)

# any NULL argument propagates (typed NULLs — a bare untyped NULL argument matches no overload
# family, 42883, jed's documented scalar-function behavior; here the NULLs carry a type)
query T
SELECT substr('abc', NULL::int, 2), substr(NULL::text, 1, 2), substr('abc', 2, NULL::int)
----
NULL
NULL
NULL

# === left(text, n) → text: the first n characters (negative drops from the right) =====

query T
SELECT left('abcde', 2)
----
ab

# code-point indexed
query T
SELECT left('héllo', 2)
----
hé

# a negative n returns all but the last |n| characters
query T
SELECT left('abcde', -2)
----
abc

# n past the length returns the whole string; n=0 or a too-large negative is empty
query B
SELECT left('abcde', 10) = 'abcde', left('abcde', 0) = '', left('abcde', -10) = ''
----
true
true
true

query T
SELECT left(NULL::text, 2), left('abc', NULL::int)
----
NULL
NULL

# === right(text, n) → text: the last n characters (negative drops from the left) ======

query T
SELECT right('abcde', 2)
----
de

query T
SELECT right('héllo', 2)
----
lo

# a negative n returns all but the first |n| characters
query T
SELECT right('abcde', -2)
----
cde

# n=0 or a too-large negative is empty
query B
SELECT right('abcde', 0) = '', right('abcde', -10) = ''
----
true
true

query T
SELECT right(NULL::text, 2), right('abc', NULL::int)
----
NULL
NULL

# === lpad(text, length[, fill]) → text: left-pad / truncate ============================

# explicit fill, cyclically applied (no edge whitespace to confuse the harness)
query T
SELECT lpad('hi', 5, 'xy')
----
xyxhi

# default fill is a space; assert via equality so the spaces ride inside the SQL literal, not the
# (whitespace-trimmed) expected block
query B
SELECT lpad('hi', 5) = '   hi', lpad('héllo', 7, '-') = '--héllo'
----
true
true

# a string longer than length truncates to its first `length` characters
query T
SELECT lpad('hello', 3)
----
hel

# length ≤ 0 is empty; an empty fill cannot pad (returns the unchanged short string)
query B
SELECT lpad('hi', 0) = '', lpad('hi', -1) = '', lpad('hi', 5, '') = 'hi'
----
true
true
true

# a pathologically large length traps 54000 (program_limit_exceeded)
statement error 54000
SELECT lpad('x', 2000000000)

query T
SELECT lpad(NULL::text, 5), lpad('hi', NULL::int), lpad('hi', 5, NULL::text)
----
NULL
NULL
NULL

# === rpad(text, length[, fill]) → text: right-pad / truncate ==========================

query T
SELECT rpad('hi', 5, 'xy')
----
hixyx

# default fill is a space (assert via equality); a longer string truncates
query B
SELECT rpad('hi', 5) = 'hi   ', rpad('hello', 3) = 'hel'
----
true
true

statement error 54000
SELECT rpad('x', 2000000000)

query T
SELECT rpad(NULL::text, 5), rpad('hi', NULL::int)
----
NULL
NULL

# === btrim(text[, characters]) → text: trim a character SET from both ends =============

# the `characters` argument is a SET of code points, trimmed from both ends
query T
SELECT btrim('xxhixx', 'x')
----
hi

# default trims spaces from both ends
query T
SELECT btrim('  hi  ')
----
hi

# the set is matched per-character (not as a substring); code-point based
query T
SELECT btrim('héllo', 'ho')
----
éll

# all characters in the set → empty; an empty set trims nothing
query B
SELECT btrim('xyzzyx', 'xyz') = '', btrim('abc', '') = 'abc'
----
true
true

query T
SELECT btrim(NULL::text), btrim('abc', NULL::text)
----
NULL
NULL

# === ltrim(text[, characters]) → text: trim from the LEADING end only =================

query T
SELECT ltrim('xxhixx', 'x')
----
hixx

# default trims leading spaces only (trailing remain — asserted via equality)
query B
SELECT ltrim('  hi  ') = 'hi  '
----
true

query T
SELECT ltrim(NULL::text), ltrim('abc', NULL::text)
----
NULL
NULL

# === rtrim(text[, characters]) → text: trim from the TRAILING end only ================

query T
SELECT rtrim('xxhixx', 'x')
----
xxhi

# default trims trailing spaces only (leading remain — asserted via equality)
query B
SELECT rtrim('  hi  ') = '  hi'
----
true

query T
SELECT rtrim(NULL::text), rtrim('abc', NULL::text)
----
NULL
NULL

# === replace(text, from, to) → text: substring replace-all ============================

query T
SELECT replace('abcabc', 'bc', 'X')
----
aXaX

# a single-character substring, multiple occurrences; code-point safe
query T
SELECT replace('héllo', 'l', 'L')
----
héLLo

# an EMPTY `from` replaces nothing (returns the string unchanged); a non-matching `from` is a no-op
query B
SELECT replace('abc', '', 'X') = 'abc', replace('abc', 'x', 'y') = 'abc'
----
true
true

query T
SELECT replace(NULL::text, 'a', 'b'), replace('abc', NULL::text, 'b'), replace('abc', 'a', NULL::text)
----
NULL
NULL
NULL

# === translate(text, from, to) → text: per-character map / delete =====================

# each `from` character maps to the `to` character at the same position
query T
SELECT translate('12345', '14', 'ax')
----
a23x5

# a `from` character past the end of `to` is DELETED (here '3')
query T
SELECT translate('12345', '143', 'ax')
----
a2x5

# a character's first occurrence in `from` wins; code-point based
query T
SELECT translate('abc', 'aa', 'xy'), translate('héllo', 'lo', 'LO')
----
xbc
héLLO

# empty `from` maps nothing; an all-mapped-to-empty `to` deletes everything
query B
SELECT translate('abc', '', 'x') = 'abc', translate('abc', 'abc', '') = ''
----
true
true

query T
SELECT translate(NULL::text, 'a', 'b'), translate('abc', NULL::text, 'b'), translate('abc', 'a', NULL::text)
----
NULL
NULL
NULL

# === repeat(text, n) → text: the string concatenated n times ==========================

query T
SELECT repeat('ab', 3)
----
ababab

# code-point safe; n ≤ 0 is empty
query T
SELECT repeat('héllo', 2)
----
héllohéllo

query B
SELECT repeat('x', 0) = '', repeat('x', -1) = ''
----
true
true

# a pathologically large result traps 54000 (program_limit_exceeded)
statement error 54000
SELECT repeat('x', 2000000000)

query T
SELECT repeat(NULL::text, 3), repeat('x', NULL::int)
----
NULL
NULL

# === reverse(text) → text: the code points in reverse order ===========================

query T
SELECT reverse('abc')
----
cba

# code-point reversal: a multibyte char stays whole
query T
SELECT reverse('héllo')
----
olléh

# an astral character (😀) reverses as ONE code point, not two UTF-16 units
query T
SELECT reverse('a😀b')
----
b😀a

query B
SELECT reverse('') = ''
----
true

query T
SELECT reverse(NULL::text)
----
NULL

# === strpos(text, substring) → int: 1-based code-point position (POSITION) =============

query I
SELECT strpos('high', 'ig')
----
2

# code-point position, not byte: 'llo' starts at character 3 of 'héllo'
query I
SELECT strpos('héllo', 'llo')
----
3

# not found → 0; an empty substring → 1; multiple occurrences → the first
query I
SELECT strpos('abc', 'x'), strpos('abc', ''), strpos('aXbXc', 'X')
----
0
1
2

query I
SELECT strpos(NULL::text, 'a'), strpos('abc', NULL::text)
----
NULL
NULL

# === split_part(text, delimiter, n) → text: the n-th field ============================

query T
SELECT split_part('a,b,c', ',', 2)
----
b

# a negative n counts from the end (PG 14+)
query T
SELECT split_part('a,b,c', ',', -1)
----
c

# an empty delimiter treats the whole string as field 1; out-of-range fields are empty
query B
SELECT split_part('a,b,c', '', 1) = 'a,b,c', split_part('a,b,c', ',', 4) = '', split_part('a,b,c', ',', -4) = ''
----
true
true
true

# n = 0 traps 22023 (field position must not be zero)
statement error 22023
SELECT split_part('a,b,c', ',', 0)

query T
SELECT split_part(NULL::text, ',', 1), split_part('a,b', NULL::text, 1), split_part('a,b', ',', NULL::int)
----
NULL
NULL
NULL
