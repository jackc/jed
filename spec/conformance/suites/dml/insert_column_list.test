# INSERT with an explicit column list — values map to the named columns (in list order, not
# declaration order); an unlisted column takes its default else NULL; the DEFAULT keyword fills
# a slot. Bad lists are rejected: unknown column 42703, duplicate 42701, value/list arity
# mismatch 42601. The positional form (no list) still requires full arity. Two-phase /
# all-or-nothing per statement. spec/design/constraints.md §2, spec/design/grammar.md §12.
# requires: ddl.create_table, ddl.primary_key, ddl.not_null, ddl.column_default, dml.insert, dml.insert_multi_row, dml.insert_column_list, query.select, query.is_null, query.order_by, types.i16, types.i32, types.text

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, a i32 DEFAULT 10, b text)

# the list need not be in declaration order; values map to the named columns. a defaults to
# 10 (omitted), b -> 'x'
statement ok
INSERT INTO t (b, id) VALUES ('x', 1)

# a column omitted from the list with no default is NULL (b here)
statement ok
INSERT INTO t (id, a) VALUES (2, 20)

# the column list applies per-row in a multi-row INSERT (a defaults each row)
statement ok
INSERT INTO t (id, b) VALUES (3, 'p'), (4, 'q')

query IIT nosort
SELECT id, a, b FROM t ORDER BY id
----
1
10
x
2
20
NULL
3
10
p
4
10
q

# b was left NULL only for the row that omitted it with no default
query I nosort
SELECT id FROM t WHERE b IS NULL
----
2

# unknown column in the list is 42703
statement error 42703
INSERT INTO t (id, nope) VALUES (5, 1)

# a column named twice in the list is 42701
statement error 42701
INSERT INTO t (id, a, a) VALUES (5, 1, 2)

# too few values for the list is 42601
statement error 42601
INSERT INTO t (id, a) VALUES (5)

# too many values for the list is 42601
statement error 42601
INSERT INTO t (id, a) VALUES (5, 1, 2)

# the positional form (no list) still requires a value for every column — 42601
statement error 42601
INSERT INTO t VALUES (5, 1)

# none of the failed inserts landed
query I nosort
SELECT id FROM t ORDER BY id
----
1
2
3
4

# a NOT NULL column omitted from the list, with no default, is 23502
statement ok
CREATE TABLE r (id i32 PRIMARY KEY, must i32 NOT NULL)

statement error 23502
INSERT INTO r (id) VALUES (1)

# omitting the PRIMARY KEY column (implicitly NOT NULL, no default) is 23502
statement error 23502
INSERT INTO r (must) VALUES (99)

# providing the NOT NULL column is fine
statement ok
INSERT INTO r (id, must) VALUES (1, 7)

# two-phase / all-or-nothing: a 23502 in the second row stores neither
statement error 23502
INSERT INTO r (id, must) VALUES (2, 8), (3, NULL)

query II nosort
SELECT id, must FROM r ORDER BY id
----
1
7
