# EXPLAIN of a DML statement (spec/design/explain.md §2) renders the plan WITHOUT executing it — an
# EXPLAIN of a DELETE deletes nothing, an EXPLAIN of an INSERT inserts nothing. The DML root is
# Insert / Update / Delete; INSERT … VALUES has a Values child, INSERT … SELECT renders its source
# subplan, and UPDATE/DELETE render the residual Filter + the target Scan. The scan access path is
# chosen by the same policy-driven inventory the executor uses (PK, ordered B-tree, GIN/GiST,
# interval set), so the reported path matches what the statement would run.
# requires: ddl.create_table, ddl.primary_key, ddl.composite_primary_key, ddl.secondary_index, ddl.index_partial, ddl.gin_index, ddl.gist_index, dml.insert, dml.insert_select, dml.insert_multi_row, dml.insert_on_conflict, dml.update, dml.delete, query.select, query.where_eq, query.comparison_order, query.logical_connectives, query.point_lookup, query.composite_pk_pushdown, query.index_range, query.index_partial, query.or_in_point_lookup, query.interval_set, query.index_mutation, query.gin_scan, query.gist_scan, query.subquery_scalar, query.explain, dml.explain, expr.arithmetic, expr.in_list, types.i32, types.text, types.array, types.range, func.array_containment, func.range_constructors, func.range_operators

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, v i32, s text)

statement ok
CREATE TABLE u (id i32 PRIMARY KEY, tid i32)

statement ok
INSERT INTO t VALUES (1, 10, 'a')

statement ok
INSERT INTO t VALUES (2, 20, 'b')

# INSERT … VALUES: an Insert root over a Values leaf carrying the row count.
query ITTII nosort
EXPLAIN INSERT INTO t VALUES (3, 30, 'c'), (4, 40, 'd')
----
0
Insert t
-
2
0
1
Values
rows=2
2
0

# INSERT … SELECT renders its source query plan (here a PK-bounded scan) under the Insert root.
query ITTII nosort
EXPLAIN INSERT INTO u SELECT id, v FROM t WHERE id = 1
----
0
Insert u
-
1
4
1
Filter
conjuncts=1
1
4
2
Scan t
PK bound: id = 1; touched=2
1
2

# ON CONFLICT is noted on the Insert root.
query ITTII nosort
EXPLAIN INSERT INTO t VALUES (5, 50, 'e') ON CONFLICT (id) DO NOTHING
----
0
Insert t
on conflict do nothing
1
0
1
Values
rows=1
1
0

# UPDATE with a PK predicate: the target scan bounds to a PK point lookup; sets=N on the root.
query ITTII nosort
EXPLAIN UPDATE t SET v = 99 WHERE id = 1
----
0
Update t
sets=1
1
3
1
Filter
conjuncts=1
1
3
2
Scan t
PK bound: id = 1
1
2

# A bare UPDATE (no WHERE) is a full scan with no Filter node.
query ITTII nosort
EXPLAIN UPDATE t SET v = v + 1
----
0
Update t
sets=1
2
3
1
Scan t
Full scan
2
3

