# Multi-row INSERT — `INSERT INTO t VALUES (..),(..)`. One statement inserts one or
# more parenthesized rows. It is two-phase / all-or-nothing (grammar.md §12), like
# UPDATE: every row is validated — arity, type/range (22003), NOT NULL (23502), and a
# duplicate primary key (23505, against both stored rows AND earlier rows in the same
# batch) — before any row is inserted, so a failing batch stores NOTHING.
# Format + the `requires` directive: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, query.select, query.where_eq, query.order_by, types.int16, types.int32, types.int64, error.overflow_trap

statement ok
CREATE TABLE t (id int32 PRIMARY KEY, a int16, b int64)

# one statement, three rows
statement ok
INSERT INTO t VALUES (1, 10, 100), (2, 20, 200), (3, 30, 300)

query III nosort
SELECT id, a, b FROM t ORDER BY id
----
1
10
100
2
20
200
3
30
300

# a second multi-row INSERT appends to the existing rows
statement ok
INSERT INTO t VALUES (4, 40, 400), (5, 50, 500)

query I nosort
SELECT id FROM t ORDER BY id
----
1
2
3
4
5

# a single parenthesized row is still the multi-row form with one row
statement ok
INSERT INTO t VALUES (6, 60, 600)

query I nosort
SELECT a FROM t WHERE id = 6
----
60

# all-or-nothing: the second row overflows int16 (max 32767), so NEITHER row is stored
statement error 22003
INSERT INTO t VALUES (7, 70, 700), (8, 99999, 800)

query I nosort
SELECT id FROM t WHERE id = 7
----

# all-or-nothing: a key duplicated WITHIN the batch traps 23505 and stores nothing
statement error 23505
INSERT INTO t VALUES (9, 90, 900), (9, 91, 901)

query I nosort
SELECT id FROM t WHERE id = 9
----

# a key colliding with an already-stored row traps 23505; the batch stores nothing
statement error 23505
INSERT INTO t VALUES (10, 1, 1), (1, 2, 2)

query I nosort
SELECT id FROM t WHERE id = 10
----

# a row whose arity differs from the column count is a syntax error (42601)
statement error 42601
INSERT INTO t VALUES (11, 11, 11), (12, 12)

query I nosort
SELECT id FROM t WHERE id = 11
----

# the whole table is exactly the six rows that the successful inserts added
query I nosort
SELECT id FROM t ORDER BY id
----
1
2
3
4
5
6

# a table with no primary key: multi-row INSERT keeps the rows in insertion order
# (the synthetic rowid is monotonic, allocated left-to-right at insert)
statement ok
CREATE TABLE log (a int32, b int16)

statement ok
INSERT INTO log VALUES (30, 3), (10, 1), (20, 2)

query II nosort
SELECT a, b FROM log
----
30
3
10
1
20
2

# NULL into a nullable column is fine inside a multi-row batch
statement ok
INSERT INTO log VALUES (40, NULL), (50, 5)

query II nosort
SELECT a, b FROM log
----
30
3
10
1
20
2
40
NULL
50
5
