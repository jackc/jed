# Database-qualified table names — the `main.` qualifier + resolution errors (Slice 1a of attached
# databases, spec/design/attached-databases.md §3). A `db.table` name in table position (FROM/JOIN
# and the DML targets) names the ATTACHED DATABASE the table lives in; this slice recognizes only the
# reserved implicit qualifiers `main` (the file/persistent database) and `temp` (the session-local
# domain — covered in ddl/qualified_temp.test, which skips disk). Any other qualifier is 42P01
# "database … is not attached"; a qualified name whose table is absent is 42P01. jed-specific
# (PostgreSQL has no `main` database/schema qualifier), so CROSS-CORE-checked, NOT PostgreSQL-oracle-
# checked. These cases use only PERSISTENT tables, so they run in BOTH storage modes (a qualified name
# resolves the same after a file reopen — resolution is catalog-level, storage-agnostic).
# requires: query.qualified_table, ddl.create_table, ddl.primary_key, dml.insert, dml.insert_multi_row, dml.update, dml.delete, query.select, query.where_eq, query.order_by, query.join_inner, types.i32

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, v i32)

statement ok
INSERT INTO t VALUES (1, 10), (2, 20), (3, 30)

# --- a `main.` qualifier reads the persistent table -------------------------------------------

query I rowsort
SELECT v FROM main.t
----
10
20
30

# a point lookup through the qualified name uses the primary key
query I nosort
SELECT v FROM main.t WHERE id = 2
----
20

# the qualifier does NOT appear in column position — the label is still the table name
query I nosort
SELECT t.v FROM main.t WHERE t.id = 1
----
10

# an explicit alias labels the qualified relation; the database qualifier never labels a column
query I nosort
SELECT x.v FROM main.t AS x WHERE x.id = 3
----
30

# --- qualified DML targets --------------------------------------------------------------------

statement ok
INSERT INTO main.t VALUES (4, 40)

query I nosort
SELECT v FROM t WHERE id = 4
----
40

statement ok
UPDATE main.t SET v = 99 WHERE id = 4

query I nosort
SELECT v FROM main.t WHERE id = 4
----
99

statement ok
DELETE FROM main.t WHERE id = 4

query I nosort
SELECT id FROM t ORDER BY id
----
1
2
3

# --- a qualified name inside a subquery / INSERT ... SELECT ------------------------------------

statement ok
CREATE TABLE u (id i32 PRIMARY KEY, w i32)

statement ok
INSERT INTO u SELECT id, v FROM main.t

query II nosort
SELECT id, w FROM u ORDER BY id
----
1
10
2
20
3
30

# a derived table over a qualified base name
query I nosort
SELECT d.v FROM (SELECT v FROM main.t WHERE id = 2) AS d
----
20

# --- a cross-qualifier join over two persistent tables (both `main`) --------------------------

query II nosort
SELECT a.id, b.w FROM main.t AS a JOIN main.u AS b ON a.id = b.id ORDER BY a.id
----
1
10
2
20
3
30

# --- resolution errors ------------------------------------------------------------------------

# an unknown database qualifier is 42P01 ("database is not attached")
statement error 42P01
SELECT * FROM reports.t

# ... in a DML target too
statement error 42P01
INSERT INTO reports.t VALUES (1, 1)

statement error 42P01
UPDATE reports.t SET v = 1

statement error 42P01
DELETE FROM reports.t

# a known database but an absent table is 42P01
statement error 42P01
SELECT * FROM main.nope

# a database-qualified name cannot be a set-returning function call (42601, no cross-database SRF)
statement error 42601
SELECT * FROM main.generate_series(1, 3)
