# Composite-type nesting-depth limit — a composite type may nest at most MAX_COMPOSITE_DEPTH = 32
# composites deep; a CREATE TYPE whose result would be deeper aborts with 54001 statement_too_complex
# (CLAUDE.md §13; spec/design/cost.md §7b, composite.md §3). The THIRD native-stack untrusted-query
# gate, completing the coverage of the nesting-depth (depth_limit.test) and input-size
# (input_size_limit.test) gates.
#
# Why it needs its own gate: a chain of cheap CREATE TYPEs each nesting the previous (`c1 AS (x
# i32)`, `c2 AS (x c1)`, …) builds unbounded composite-nesting depth across MANY statements. The
# per-statement input-size cap never sees it (each statement is tiny), and the parser nesting counter
# never sees it either (the depth is a property of the catalog GRAPH, resolved at use/codec time, not
# any one statement's AST). But every derived recursive walk — the value codec, the comparator,
# record_out/record_in, resolve_col_type — recurses to this depth and would overflow the native call
# stack. The gate bounds the depth at the PRODUCER (CREATE TYPE), so no over-deep type ever enters the
# catalog and every downstream walk is transitively stack-safe (the "bound at the producer" rule the
# parser depth limit also follows).
#
# A composite type's depth is the length of its deepest chain of nested composites, counting itself:
# a row of scalars is depth 1, so `cN AS (x c{N-1})` is depth N. The limit is a fixed, cross-core
# identical constant (CLAUDE.md §8): c32 (depth 32) is the deepest ACCEPTED type, c33 (depth 33) is
# rejected, in Rust / Go / TS alike. An array field counts as its element type (array levels are not
# composite levels — see the array cases below).
#
# jed-SPECIFIC (PG bounds composite nesting only by a runtime stack probe, not a fixed deterministic
# limit), so the 54001 records are NOT oracle-checked.
# requires: types.composite, types.array, types.composite_array_field, types.i32, resource.composite_depth_limit

# === Boundary: depth 32 is the deepest ACCEPTED composite type. ===
# Build the chain c1 (depth 1) … c32 (depth 32), one nesting level per CREATE TYPE.

statement ok
CREATE TYPE c1 AS (x i32)

statement ok
CREATE TYPE c2 AS (x c1)

statement ok
CREATE TYPE c3 AS (x c2)

statement ok
CREATE TYPE c4 AS (x c3)

statement ok
CREATE TYPE c5 AS (x c4)

statement ok
CREATE TYPE c6 AS (x c5)

statement ok
CREATE TYPE c7 AS (x c6)

statement ok
CREATE TYPE c8 AS (x c7)

statement ok
CREATE TYPE c9 AS (x c8)

statement ok
CREATE TYPE c10 AS (x c9)

statement ok
CREATE TYPE c11 AS (x c10)

statement ok
CREATE TYPE c12 AS (x c11)

statement ok
CREATE TYPE c13 AS (x c12)

statement ok
CREATE TYPE c14 AS (x c13)

statement ok
CREATE TYPE c15 AS (x c14)

statement ok
CREATE TYPE c16 AS (x c15)

statement ok
CREATE TYPE c17 AS (x c16)

statement ok
CREATE TYPE c18 AS (x c17)

statement ok
CREATE TYPE c19 AS (x c18)

statement ok
CREATE TYPE c20 AS (x c19)

statement ok
CREATE TYPE c21 AS (x c20)

statement ok
CREATE TYPE c22 AS (x c21)

statement ok
CREATE TYPE c23 AS (x c22)

statement ok
CREATE TYPE c24 AS (x c23)

statement ok
CREATE TYPE c25 AS (x c24)

statement ok
CREATE TYPE c26 AS (x c25)

statement ok
CREATE TYPE c27 AS (x c26)

statement ok
CREATE TYPE c28 AS (x c27)

statement ok
CREATE TYPE c29 AS (x c28)

statement ok
CREATE TYPE c30 AS (x c29)

statement ok
CREATE TYPE c31 AS (x c30)

# c32 is depth 32 — exactly the limit, accepted.
statement ok
CREATE TYPE c32 AS (x c31)

# A depth-32 type is fully usable: declaring a column of it walks resolve_col_type 32 levels deep
# without overflow — proof the limit leaves the derived walks safe at the boundary.
statement ok
CREATE TABLE deep32 (id i32 PRIMARY KEY, v c32)

# === One level over (depth 33) aborts with 54001 at CREATE TYPE — the producer gate. ===

# c33 would be depth 33, one past the limit.
statement error 54001
CREATE TYPE c33 AS (x c32)

# === Depth is MAX over fields, not SUM: two depth-31 fields still make depth 32, accepted. ===

statement ok
CREATE TYPE wide AS (a c31, b c31)

# But two paths to depth 32 still cap the type at 33 when nested under one more level.
statement error 54001
CREATE TYPE wide_over AS (a c32, b c1)

# === An array field counts as its ELEMENT type — array levels are not composite levels. ===

# c31[] contributes depth 31 (the array passes through to c31), so this composite is depth 32 — OK.
statement ok
CREATE TYPE arrok AS (x c31[])

# c32[] contributes depth 32, so wrapping it in one more composite is depth 33 — rejected, exactly as
# a bare c32 field would be. The array wrapper does not shrink the chain.
statement error 54001
CREATE TYPE arrbad AS (x c32[])
