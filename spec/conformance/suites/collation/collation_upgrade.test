# Collation upgrade / REINDEX migration — clearing a version-skew end to end (spec/design/collation.md
# §12). The deferred 2d follow-on: a host op (`db.upgrade_collations()`, driven here by the new
# `# upgrade-collations:` harness directive) rebuilds a version-SKEWED table's collated keys against
# the LOADED Unicode version and re-pins the stamp — so the table is read-write again AND its collated
# index regains pushdown (a Full index, §8 / encoding.md §2.12).
#
# This runs against the SAME pre-built skewed image the read-safety tripwire uses
# (collation_skew_corrupt.jed — `unicode` pinned to a bogus 9999.0.0, `t_name_idx` keyed in C/byte
# order = wrong for the loaded collation). SQL cannot construct this state, hence the `# fixture:`.
# The arc: a write is refused (still skewed) → migrate → the same write succeeds AND a query is served
# correctly by the REBUILT index. The migration is a privileged host op, NOT SQL-reachable (untrusted
# queries can never trigger it — CLAUDE.md §13); the harness acts as the host.
#
# requires: harness.fixture_open, harness.upgrade_collations, expr.collate, ddl.collate_column, ddl.secondary_index, query.select, query.where_eq, query.comparison_order, query.order_by, query.point_lookup, dml.insert, types.i32, types.text, resource.cost_metering

# fixture: fileformat/fixtures/collation_skew_corrupt.jed
# load-collation: unicode = collation/17.0.0/root.allkeys

# Rows in the fixture: (1,'a') (2,'Z') (3,'ä') (4,'b'); loaded unicode order is a < ä < b < … < z < Z.

# BEFORE the upgrade — the table is version-skewed (read-only). A read is still correct (it heap-scans
# and recomputes against the loaded table; the skewed index is refused for pushdown — §12). The cost
# is a full 4-row scan (10), the proof that the skewed index is NOT seeked.
# cost: 10
query I rowsort
SELECT id FROM t WHERE name = 'Z'
----
2

# A write to the skewed table is refused (XX002, collation.md §12).
statement error XX002
INSERT INTO t VALUES (5, 'c')

# Run the migration: rebuild the skewed collated keys under the loaded version + re-pin the stamp.
# upgrade-collations:

# AFTER the upgrade — the SAME equality query now PUSHES DOWN to the rebuilt (correct) unicode index:
# index leaf + the fetched row's leaf (2 pages) + 1 row + 1 filter + 1 produced = 5, strictly less than
# the pre-upgrade full scan (10). That drop IS the proof the migration re-enabled pushdown.
# cost: 5
query I rowsort
SELECT id FROM t WHERE name = 'Z'
----
2

# The same write that was XX002 now SUCCEEDS — the skew is cleared, the table is read-write again.
statement ok
INSERT INTO t VALUES (5, 'c')

# The new row participates in the loaded-collation order: a < ä < b < c < z-family < Z → 1,3,4,5,2.
query I nosort
SELECT id FROM t ORDER BY name COLLATE "unicode"
----
1
3
4
5
2

# Idempotent: a second upgrade with nothing skewed is a no-op (the write below still succeeds).
# upgrade-collations:

statement ok
INSERT INTO t VALUES (6, 'd')
