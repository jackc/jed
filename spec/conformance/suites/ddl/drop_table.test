# DROP TABLE — remove a table (its definition and all its rows) from the catalog. The
# inverse of CREATE TABLE: a missing table is 42P01 (there is no IF EXISTS this slice),
# single table, no CASCADE/RESTRICT (grammar.md §13). After a drop the name is free to
# re-create from empty. Format + the `requires` directive: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, ddl.drop_table, dml.insert, dml.update, dml.delete, query.select, query.order_by, types.i16, types.i32, types.i64

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, v i16)

statement ok
INSERT INTO t VALUES (1, 10), (2, 20)

# the table is queryable before the drop
query I nosort
SELECT id FROM t ORDER BY id
----
1
2

# DROP removes the table; its rows go with it
statement ok
DROP TABLE t

# every access path against the dropped table now traps 42P01 (undefined_table) — the
# same lookup INSERT/SELECT/UPDATE/DELETE already use for an unknown table
statement error 42P01
SELECT id FROM t

statement error 42P01
INSERT INTO t VALUES (3, 30)

statement error 42P01
UPDATE t SET v = 0

statement error 42P01
DELETE FROM t

# dropping a table that does not exist is 42P01 — there is no IF EXISTS this slice, so a
# repeat drop and a never-created name both error
statement error 42P01
DROP TABLE t

statement error 42P01
DROP TABLE never_existed

# the name is free again after a drop: re-create it (with a different shape) from empty
statement ok
CREATE TABLE t (id i32 PRIMARY KEY, w i64)

query I nosort
SELECT id FROM t ORDER BY id
----

statement ok
INSERT INTO t VALUES (7, 700)

query I nosort
SELECT id FROM t
----
7

# DROP is case-insensitive on the table name (DROP TABLE T drops t)
statement ok
DROP TABLE T

statement error 42P01
SELECT id FROM t

# dropping one table leaves the others intact
statement ok
CREATE TABLE a (id i32 PRIMARY KEY)

statement ok
CREATE TABLE b (id i32 PRIMARY KEY)

statement ok
INSERT INTO a VALUES (1)

statement ok
INSERT INTO b VALUES (2)

statement ok
DROP TABLE a

statement error 42P01
SELECT id FROM a

query I nosort
SELECT id FROM b
----
2

# syntax: a bare DROP TABLE with no table name is a syntax error (42601)
statement error 42601
DROP TABLE

# syntax: trailing input after the table name is a syntax error (42601)
statement error 42601
DROP TABLE b extra
