# GENERATED { ALWAYS | BY DEFAULT } AS IDENTITY columns + the INSERT OVERRIDING { SYSTEM | USER }
# VALUE clause (spec/design/sequences.md §13) — the SQL-standard identity surface. An identity column
# desugars like `serial`: an OWNED bigint sequence (named <table>_<column>_seq) + a DEFAULT
# nextval(...) + NOT NULL, plus the persisted ALWAYS/BY DEFAULT distinction (format_version 15). The
# column type must be smallint/integer/bigint. GENERATED ALWAYS rejects an explicit INSERT value
# (428C9) unless OVERRIDING SYSTEM VALUE; GENERATED BY DEFAULT accepts one (not advancing the
# sequence) unless OVERRIDING USER VALUE; OVERRIDING USER VALUE discards a supplied value and uses
# the sequence. UPDATE of an ALWAYS column is 428C9. DEFAULT-and-identity / serial-and-identity / two
# identity specs are 42601.
#
# The on-disk persistence of the ALWAYS/BY DEFAULT bit (the 428C9 gate surviving a reopen), the
# auto-named owned-sequence auto-drop, and the bigint-flavored-owned-sequence divergence live in the
# per-core unit tests (reopen / introspection / divergence the PG-clean corpus cannot express).
# requires: ddl.identity, ddl.sequence, func.sequence, ddl.create_table, ddl.drop_table, dml.insert, dml.insert_column_list, dml.insert_select, dml.update, query.select, types.i32, types.i64, types.text

# --- GENERATED ALWAYS: auto-numbers, DEFAULT keyword allowed, explicit value 428C9 ----------------

statement ok
CREATE TABLE a (id int GENERATED ALWAYS AS IDENTITY PRIMARY KEY, v text)

statement ok
INSERT INTO a (v) VALUES ('x'), ('y')

# the DEFAULT keyword always uses the identity sequence, even for GENERATED ALWAYS
statement ok
INSERT INTO a (id, v) VALUES (DEFAULT, 'z')

query IT rowsort
SELECT id, v FROM a
----
1
x
2
y
3
z

# an explicit (non-DEFAULT) value into a GENERATED ALWAYS column without OVERRIDING is 428C9
statement error 428C9
INSERT INTO a (id, v) VALUES (100, 'boom')

# OVERRIDING SYSTEM VALUE lets the explicit value land
statement ok
INSERT INTO a (id, v) OVERRIDING SYSTEM VALUE VALUES (100, 'sys')

# OVERRIDING USER VALUE discards the supplied value and uses the sequence (next is 4)
statement ok
INSERT INTO a (id, v) OVERRIDING USER VALUE VALUES (999, 'usr')

query IT rowsort
SELECT id, v FROM a
----
1
x
100
sys
2
y
3
z
4
usr

# --- GENERATED BY DEFAULT: explicit value used (sequence not advanced); OVERRIDING USER VALUE -------
# `id` is intentionally NOT a PRIMARY KEY: jed's standing PK-reassignment narrowing (0A000) would
# otherwise pre-empt the UPDATE below, where PG re-keys — a documented divergence (sequences.md §13.4).

statement ok
CREATE TABLE b (id int GENERATED BY DEFAULT AS IDENTITY, v text)

statement ok
INSERT INTO b (v) VALUES ('a')

# an explicit value is accepted and does NOT advance the sequence
statement ok
INSERT INTO b (id, v) VALUES (50, 'explicit')

statement ok
INSERT INTO b (v) VALUES ('c')

# OVERRIDING USER VALUE discards 777 and uses the sequence (next is 3)
statement ok
INSERT INTO b (id, v) OVERRIDING USER VALUE VALUES (777, 'over')

# OVERRIDING SYSTEM VALUE on BY DEFAULT keeps the explicit value (a no-op restriction)
statement ok
INSERT INTO b (id, v) OVERRIDING SYSTEM VALUE VALUES (60, 'sys')

query IT rowsort
SELECT id, v FROM b
----
1
a
2
c
3
over
50
explicit
60
sys

# --- the GENERATED ALWAYS gate fires before any row (even an empty SELECT source) ------------------

statement error 428C9
INSERT INTO a (id, v) SELECT 1, 'q' WHERE false

# --- INSERT ... SELECT advances the identity sequence per row --------------------------------------

statement ok
CREATE TABLE s (id int GENERATED ALWAYS AS IDENTITY, v int)

statement ok
INSERT INTO s (v) SELECT g FROM (VALUES (10), (11), (12)) AS t(g)

query II rowsort
SELECT id, v FROM s
----
1
10
2
11
3
12

# --- sequence options on the identity sequence -----------------------------------------------------

statement ok
CREATE TABLE o (id int GENERATED ALWAYS AS IDENTITY (START WITH 100 INCREMENT BY 5), v text)

statement ok
INSERT INTO o (v) VALUES ('a'), ('b')

query IT rowsort
SELECT id, v FROM o
----
100
a
105
b

# --- UPDATE of a GENERATED ALWAYS identity column is 428C9; BY DEFAULT is allowed ------------------

statement error 428C9
UPDATE a SET id = 7 WHERE v = 'x'

statement ok
UPDATE b SET id = 500 WHERE v = 'a'

query I nosort
SELECT id FROM b WHERE v = 'a'
----
500

# --- OVERRIDING on a table with no identity column is accepted (a no-op) ---------------------------

statement ok
CREATE TABLE n (id int, v text)

statement ok
INSERT INTO n OVERRIDING SYSTEM VALUE VALUES (1, 'a')

query IT nosort
SELECT id, v FROM n
----
1
a

# --- CREATE TABLE conflicts (all 42601) and the type gate (22023) ---------------------------------

# an explicit DEFAULT together with IDENTITY
statement error 42601
CREATE TABLE bad1 (id int DEFAULT 5 GENERATED ALWAYS AS IDENTITY)

# a serial type is itself a synthesized default, so serial + IDENTITY is the same conflict
statement error 42601
CREATE TABLE bad2 (id serial GENERATED ALWAYS AS IDENTITY)

# two identity specifications on one column
statement error 42601
CREATE TABLE bad3 (id int GENERATED ALWAYS AS IDENTITY GENERATED BY DEFAULT AS IDENTITY)

# the identity column type must be smallint / integer / bigint
statement error 22023
CREATE TABLE bad4 (id text GENERATED ALWAYS AS IDENTITY)

# --- cleanup --------------------------------------------------------------------------------------

statement ok
DROP TABLE a

statement ok
DROP TABLE b

statement ok
DROP TABLE s

statement ok
DROP TABLE o

statement ok
DROP TABLE n
