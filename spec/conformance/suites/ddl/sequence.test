# CREATE SEQUENCE / DROP SEQUENCE — a named, persisted, monotonic int64 generator as the third
# catalog-object kind (after tables + composite types), format_version 12. Order-free options
# (INCREMENT/MINVALUE/MAXVALUE/START/CACHE/CYCLE), bigint-only, the shared relation namespace
# (42P07 duplicate / 42P01 missing), option validation 22023, RESTRICT-only. The value functions
# nextval/currval are exercised in ../expr/sequence_value.test. The transactional-rollback
# divergence (nextval rolls back — a documented PG divergence, sequences.md §5) and read-only 25006
# live in the per-core unit tests (it cannot live in the PG-clean oracle corpus).
# requires: ddl.sequence, func.sequence, ddl.create_table, ddl.drop_table, dml.insert, query.select, types.int64

# a bare CREATE SEQUENCE defaults to INCREMENT 1, MINVALUE 1, START 1
statement ok
CREATE SEQUENCE s

# the sequence is usable immediately (first value is START = 1). NOTE on the corpus structure: an
# advancing nextval is written `statement ok` (a side-effecting statement the oracle harness replays
# in each row's prefix) and the value is asserted with a trailing `query`; a `query nextval` is not
# replayed, so it never double-advances — this keeps the cumulative progression oracle-reproducible.
statement ok
SELECT nextval('s')

# CREATE SEQUENCE of a name already in the relation namespace is 42P07 (no IF NOT EXISTS)
statement error 42P07
CREATE SEQUENCE s

# IF NOT EXISTS makes a re-create a no-op success (the existing sequence is unchanged — the next
# value is 2, proving the counter was not reset)
statement ok
CREATE SEQUENCE IF NOT EXISTS s

query I nosort
SELECT nextval('s')
----
2

# the name collides with a table in the same namespace, both directions
statement ok
CREATE TABLE tbl (id int32 PRIMARY KEY)

statement error 42P07
CREATE SEQUENCE tbl

statement error 42P07
CREATE TABLE s (id int32 PRIMARY KEY)

# --- option validation (22023) ----------------------------------------------

statement error 22023
CREATE SEQUENCE bad INCREMENT 0

statement error 22023
CREATE SEQUENCE bad CACHE 0

statement error 22023
CREATE SEQUENCE bad MINVALUE 10 MAXVALUE 5

statement error 22023
CREATE SEQUENCE bad MINVALUE 1 MAXVALUE 10 START 100

# the full ascending option set is accepted
statement ok
CREATE SEQUENCE upward INCREMENT BY 5 MINVALUE 1 MAXVALUE 100 START WITH 10 CACHE 1

query I nosort
SELECT nextval('upward')
----
10

# a descending sequence: negative INCREMENT, START defaults to MAXVALUE
statement ok
CREATE SEQUENCE downward INCREMENT BY -1 MINVALUE -5 MAXVALUE -1

query I nosort
SELECT nextval('downward')
----
-1

# NO MINVALUE / NO MAXVALUE / NO CYCLE select the defaults (well-formed)
statement ok
CREATE SEQUENCE defs INCREMENT 2 NO MINVALUE NO MAXVALUE NO CYCLE

# --- DROP SEQUENCE -----------------------------------------------------------

# DROP removes the sequence; the name is then unresolvable (42P01)
statement ok
DROP SEQUENCE s

statement error 42P01
SELECT nextval('s')

# dropping a missing sequence is 42P01 (no IF EXISTS), a repeat drop included
statement error 42P01
DROP SEQUENCE s

statement error 42P01
DROP SEQUENCE never_existed

# IF EXISTS makes a missing drop a no-op success, and drops several at once
statement ok
DROP SEQUENCE IF EXISTS s, upward, downward

# the name is free again after a drop
statement ok
CREATE SEQUENCE s

query I nosort
SELECT nextval('s')
----
1

# clean up the live oracle (autocommit DDL persists across corpus:check files)
statement ok
DROP SEQUENCE s, defs

statement ok
DROP TABLE tbl
