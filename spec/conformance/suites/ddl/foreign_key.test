# FOREIGN KEY constraints (spec/design/constraints.md §6, grammar.md §43).
# A FOREIGN KEY ties a child's columns to a key of a parent table: the referenced columns must
# be the parent's PRIMARY KEY or a UNIQUE set (else 42830), and corresponding columns must be the
# SAME type (jed is stricter than PG — see the per-core unit tests). Enforced at four write sites
# inside the two-phase / all-or-nothing pass: a child INSERT/UPDATE whose key is absent in the
# parent, or a parent DELETE/UPDATE of a row still referenced by a child, traps 23503. MATCH SIMPLE:
# a NULL in any local column exempts the row. Existence is validated against the statement's batch
# END STATE, so a self-reference and a forward multi-row reference both resolve. A referenced table
# cannot be dropped (2BP01). Every record below agrees with PostgreSQL 18 (oracle-checked); the
# jed-specific divergences — stricter type pairing, the end-state parent UPDATE, and the 0A000
# CASCADE/SET NULL/SET DEFAULT actions — live in the per-core unit tests, not this corpus.
# Format: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, ddl.composite_primary_key, ddl.unique, ddl.check, ddl.foreign_key, ddl.drop_table, dml.insert, dml.insert_multi_row, dml.delete, dml.update, query.select, query.order_by, types.i32, types.text, null.three_valued

# --- a single-column FK to the parent's primary key (column-level REFERENCES) -----

statement ok
CREATE TABLE dept (id i32 PRIMARY KEY, name text)

statement ok
INSERT INTO dept VALUES (1, 'eng'), (2, 'sales'), (3, 'hr')

# the referenced column list defaults to the parent's primary key
statement ok
CREATE TABLE emp (id i32 PRIMARY KEY, dept_id i32 REFERENCES dept)

# referencing an existing parent key is fine
statement ok
INSERT INTO emp VALUES (10, 1), (11, 2)

# a missing parent key traps 23503
statement error 23503
INSERT INTO emp VALUES (12, 99)

# MATCH SIMPLE: a NULL foreign-key column is exempt (references nothing)
statement ok
INSERT INTO emp VALUES (13, NULL)

query II nosort
SELECT id, dept_id FROM emp ORDER BY id
----
10
1
11
2
13
NULL

# --- parent DELETE may not strand a child ----------------------------------------

# deleting a referenced parent row traps 23503
statement error 23503
DELETE FROM dept WHERE id = 1

# deleting an unreferenced parent row is fine
statement ok
DELETE FROM dept WHERE id = 3

# --- child UPDATE re-validates an assigned FK column ------------------------------

# reassigning to an existing parent key is fine
statement ok
UPDATE emp SET dept_id = 2 WHERE id = 10

# reassigning to a missing parent key traps 23503
statement error 23503
UPDATE emp SET dept_id = 88 WHERE id = 11

# reassigning to NULL is exempt (MATCH SIMPLE)
statement ok
UPDATE emp SET dept_id = NULL WHERE id = 11

query II nosort
SELECT id, dept_id FROM emp ORDER BY id
----
10
2
11
NULL
13
NULL

# --- a FK to a UNIQUE (non-PK) column, and parent UPDATE that orphans -------------

statement ok
CREATE TABLE pu (id i32 PRIMARY KEY, code i32 UNIQUE)

statement ok
INSERT INTO pu VALUES (1, 100), (2, 200)

statement ok
CREATE TABLE cu (id i32 PRIMARY KEY, pcode i32 REFERENCES pu (code))

statement ok
INSERT INTO cu VALUES (10, 100)

# updating the referenced UNIQUE value out from under a child traps 23503
statement error 23503
UPDATE pu SET code = 999 WHERE id = 1

# updating an unreferenced parent row is fine
statement ok
UPDATE pu SET code = 999 WHERE id = 2

# --- a composite FK to a composite primary key -----------------------------------

statement ok
CREATE TABLE comp_p (a i32, b i32, label text, PRIMARY KEY (a, b))

statement ok
INSERT INTO comp_p VALUES (1, 1, 'x'), (1, 2, 'y')

statement ok
CREATE TABLE comp_c (id i32 PRIMARY KEY, pa i32, pb i32, CONSTRAINT comp_fk FOREIGN KEY (pa, pb) REFERENCES comp_p (a, b))

statement ok
INSERT INTO comp_c VALUES (10, 1, 1)

# a missing composite key traps 23503
statement error 23503
INSERT INTO comp_c VALUES (11, 9, 9)

# composite MATCH SIMPLE: a partly-NULL tuple is exempt
statement ok
INSERT INTO comp_c VALUES (12, 1, NULL)

# --- a self-referencing FK (the batch end state resolves forward references) ------

statement ok
CREATE TABLE node (id i32 PRIMARY KEY, parent i32 REFERENCES node (id))

# a forward reference within one multi-row INSERT (row 2 references id 1, inserted after it)
statement ok
INSERT INTO node VALUES (2, 1), (1, NULL)

# a row may reference itself
statement ok
INSERT INTO node VALUES (3, 3)

# a missing parent traps 23503
statement error 23503
INSERT INTO node VALUES (4, 99)

# a referenced node cannot be deleted ...
statement error 23503
DELETE FROM node WHERE id = 1

# ... but deleting every row at once is fine (nothing is left referencing anything)
statement ok
DELETE FROM node

query I nosort
SELECT id FROM node ORDER BY id
----

# --- DDL resolution errors (PG codes) --------------------------------------------

# a missing referenced table is 42P01
statement error 42P01
CREATE TABLE m1 (z i32 REFERENCES nosuchtable)

# referencing a column that is neither a PK nor a UNIQUE set is 42830
statement ok
CREATE TABLE np (x i32, y i32)

statement error 42830
CREATE TABLE m2 (z i32 REFERENCES np (x))

# a referencing/referenced column-count disagreement is 42830
statement error 42830
CREATE TABLE m3 (z i32, FOREIGN KEY (z) REFERENCES comp_p (a, b))

# omitting the referenced list when the parent has no primary key is 42704 (PG's code here:
# the default is specifically the PK, distinct from the explicit-no-unique-match 42830 above)
statement error 42704
CREATE TABLE m4 (z i32 REFERENCES np)

# a same-position type mismatch is 42804
statement error 42804
CREATE TABLE m5 (z text REFERENCES dept (id))

# an FK shares the per-table constraint namespace with CHECK — a name collision is 42710
statement error 42710
CREATE TABLE m6 (id i32 PRIMARY KEY, a i32, CONSTRAINT dup CHECK (a > 0), CONSTRAINT dup FOREIGN KEY (a) REFERENCES dept (id))

# ON DELETE / ON UPDATE NO ACTION and RESTRICT are accepted (identical in jed)
statement ok
CREATE TABLE m7 (id i32 PRIMARY KEY, d i32 REFERENCES dept (id) ON DELETE NO ACTION ON UPDATE RESTRICT)

# --- DROP TABLE and dependencies -------------------------------------------------

statement ok
CREATE TABLE dp (id i32 PRIMARY KEY)

statement ok
CREATE TABLE dc (id i32 PRIMARY KEY, r i32 REFERENCES dp)

# a table referenced by another table's FK cannot be dropped (2BP01)
statement error 2BP01
DROP TABLE dp

# dropping the referencing table first, then the parent, is fine
statement ok
DROP TABLE dc

statement ok
DROP TABLE dp

# a self-reference does not block dropping its own table
statement ok
CREATE TABLE sd (id i32 PRIMARY KEY, p i32 REFERENCES sd (id))

statement ok
DROP TABLE sd
