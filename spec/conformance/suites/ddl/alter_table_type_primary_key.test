# ALTER TABLE slice 5: ALTER COLUMN TYPE and standalone ADD/DROP PRIMARY KEY rewrites. The custom
# DROP PRIMARY KEY spelling and ignored explicit PK handle are jed-specific; do not oracle-check.
# requires: ddl.alter_table, ddl.create_table, ddl.primary_key, ddl.unique, ddl.check, ddl.foreign_key, ddl.secondary_index, ddl.identity, ddl.sequence, func.sequence, dml.insert, dml.insert_column_list, dml.delete, query.select, query.order_by, query.where_eq, types.i16, types.i32, types.i64, types.text, types.json, expr.arithmetic, resource.cost_metering

statement ok
CREATE TABLE alter_type (id i32 PRIMARY KEY, v i32 DEFAULT 7, CONSTRAINT alter_type_v_key UNIQUE (v), CHECK (v > 0))

statement ok
INSERT INTO alter_type VALUES (1, 2), (2, 3)

statement ok
CREATE INDEX alter_type_v_idx ON alter_type (v)

# cost: 10
statement ok
ALTER TABLE alter_type ALTER COLUMN v SET DATA TYPE i64 USING v + 10

query II rowsort
SELECT id, v FROM alter_type
----
1
12
2
13

# The old default is converted and preserved for future inserts.
statement ok
INSERT INTO alter_type (id) VALUES (3)

query II rowsort
SELECT id, v FROM alter_type
----
1
12
2
13
3
7

# A PK member's type conversion re-keys the table and every secondary-index suffix.
statement ok
ALTER TABLE alter_type ALTER id TYPE i64 USING id + 100

query II rowsort
SELECT id, v FROM alter_type
----
101
12
102
13
103
7

# Re-keying is observable through a point lookup and duplicate enforcement, not merely a full scan.
query II
SELECT id, v FROM alter_type WHERE id = 101
----
101
12

statement error 23505
INSERT INTO alter_type VALUES (101, 99)

# The converted final PK values are uniqueness-checked before the rewrite is published.
statement ok
CREATE TABLE alter_type_pk_collision (id i32 PRIMARY KEY)

statement ok
INSERT INTO alter_type_pk_collision VALUES (1), (2)

statement error 23505
ALTER TABLE alter_type_pk_collision ALTER id TYPE i64 USING id - id + 1

query I rowsort
SELECT id FROM alter_type_pk_collision
----
1
2

# Retaining PK metadata cannot bypass the ordinary keyability gate.
statement ok
CREATE TABLE alter_type_unkeyable (id text PRIMARY KEY)

statement error 0A000
ALTER TABLE alter_type_unkeyable ALTER id TYPE json

# Failed per-row conversion is atomic.
statement error 22003
ALTER TABLE alter_type ALTER v TYPE i16 USING v + 40000

query II rowsort
SELECT id, v FROM alter_type
----
101
12
102
13
103
7

# ADD PRIMARY KEY validates and re-keys a synthetic-rowid table.
statement ok
CREATE TABLE alter_pk (a i32, b i32, note text)

statement ok
INSERT INTO alter_pk VALUES (2, 1, 'second'), (1, 2, 'first')

statement ok
CREATE INDEX alter_pk_note_idx ON alter_pk (note)

# cost: 6
statement ok
ALTER TABLE alter_pk ADD CONSTRAINT ignored_handle PRIMARY KEY (a, b)

query IIT rowsort
SELECT a, b, note FROM alter_pk
----
1
2
first
2
1
second

statement error 42P16
ALTER TABLE alter_pk ADD PRIMARY KEY (b)

# DROP PRIMARY KEY re-keys back to fresh dense synthetic rowids and retains NOT NULL.
# cost: 3
statement ok
ALTER TABLE alter_pk DROP PRIMARY KEY

statement ok
INSERT INTO alter_pk VALUES (1, 2, 'duplicate key now allowed')

statement error 23502
INSERT INTO alter_pk VALUES (NULL, 4, 'still not null')

query IIT rowsort
SELECT a, b, note FROM alter_pk
----
1
2
duplicate key now allowed
1
2
first
2
1
second

# Duplicate and NULL end states reject ADD atomically.
statement ok
CREATE TABLE alter_pk_bad (a i32, b i32)

statement ok
INSERT INTO alter_pk_bad VALUES (1, 1), (1, 2), (NULL, 3)

statement error 23502
ALTER TABLE alter_pk_bad ADD PRIMARY KEY (a, b)

statement ok
DELETE FROM alter_pk_bad WHERE b = 3

statement error 23505
ALTER TABLE alter_pk_bad ADD PRIMARY KEY (a)

# An IDENTITY column retypes its owned sequence, including one pending from an earlier action in the
# same statement. Default bounds widen while explicitly configured bounds remain explicit.
statement ok
CREATE TABLE alter_identity_type (id i16 GENERATED BY DEFAULT AS IDENTITY)

statement ok
SELECT setval('alter_identity_type_id_seq', 32767)

statement ok
ALTER TABLE alter_identity_type ALTER id TYPE i64

query I
SELECT nextval('alter_identity_type_id_seq')
----
32768

statement ok
CREATE TABLE alter_identity_pending (seed i32)

statement ok
ALTER TABLE alter_identity_pending ADD id i16 GENERATED BY DEFAULT AS IDENTITY, ALTER id TYPE i64

statement ok
SELECT setval('alter_identity_pending_id_seq', 32767)

query I
SELECT nextval('alter_identity_pending_id_seq')
----
32768

statement ok
CREATE TABLE alter_identity_explicit (id i16 GENERATED BY DEFAULT AS IDENTITY (MAXVALUE 100))

statement ok
ALTER TABLE alter_identity_explicit ALTER id TYPE i64

statement error 22003
SELECT setval('alter_identity_explicit_id_seq', 101)

# Sequence metadata and the column rewrite roll back together when later final-state validation
# fails after the type action staged wider sequence bounds.
statement ok
CREATE TABLE alter_identity_atomic (id i16 GENERATED BY DEFAULT AS IDENTITY)

statement ok
INSERT INTO alter_identity_atomic (id) VALUES (DEFAULT)

statement error 23514
ALTER TABLE alter_identity_atomic ALTER id TYPE i64, ADD CHECK (id > 100)

statement error 22003
SELECT setval('alter_identity_atomic_id_seq', 32768)

# Referenced PK drops use ordinary RESTRICT/CASCADE dependency handling.
statement ok
CREATE TABLE alter_pk_parent (id i32 PRIMARY KEY)

statement ok
CREATE TABLE alter_pk_child (id i32 PRIMARY KEY, parent_id i32 REFERENCES alter_pk_parent(id))

# A type change cannot leave either side of an FK with incompatible static types.
statement error 42804
ALTER TABLE alter_pk_child ALTER parent_id TYPE i64

statement error 42804
ALTER TABLE alter_pk_parent ALTER id TYPE i64

statement error 2BP01
ALTER TABLE alter_pk_parent DROP PRIMARY KEY

statement ok
ALTER TABLE alter_pk_parent DROP PRIMARY KEY CASCADE, ALTER id TYPE i64

# The earlier CASCADE removed the incoming FK from the final statement state.
statement ok
INSERT INTO alter_pk_child VALUES (1, 999)
