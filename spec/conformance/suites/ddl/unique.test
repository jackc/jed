# UNIQUE constraints + unique indexes (spec/design/constraints.md §5, indexes.md §8).
# A UNIQUE constraint IS a unique secondary index — auto-named <table>_<cols>_key (PG's
# convention, proven below via namespace collisions) or named by the CONSTRAINT prefix;
# CREATE UNIQUE INDEX is the direct form (auto-name keeps _idx). Enforcement is NULLS
# DISTINCT (PG's default): a tuple with any NULL component never conflicts. Violations
# trap 23505 at INSERT (both sources, in-batch included) inside the two-phase pass, after
# the PK duplicate check (PG's precedence). The PG-divergent block sits LAST with ledger
# overrides (conformance.md §5): UPDATE validates uniqueness against the statement's END
# STATE (PG checks per-row in heap order), and DROP INDEX of a constraint-backed index is
# allowed (jed has no ALTER TABLE ... DROP CONSTRAINT).
# Format: ../../../design/conformance.md.
# requires: ddl.create_table, ddl.primary_key, ddl.unique, ddl.secondary_index, ddl.check, ddl.drop_table, dml.insert, dml.insert_multi_row, dml.insert_select, dml.update, query.select, query.order_by, types.i32, types.text, null.three_valued, resource.cost_metering

statement ok
CREATE TABLE t (id i32 PRIMARY KEY, v i32 UNIQUE, w i32, CONSTRAINT wv UNIQUE (w, v))

statement ok
INSERT INTO t VALUES (1, 10, 100), (2, NULL, 100)

# a stored duplicate traps 23505
statement error 23505
INSERT INTO t VALUES (3, 10, 200)

# an in-batch duplicate too (two-phase / all-or-nothing: nothing stored)
statement error 23505
INSERT INTO t VALUES (3, 30, 1), (4, 30, 2)

query I nosort
SELECT id FROM t ORDER BY id
----
1
2

# NULLS DISTINCT (PG's default): any number of NULLs coexist, and a NULL component
# exempts the whole multi-column tuple — (100, NULL) repeats though w matches
statement ok
INSERT INTO t VALUES (5, NULL, 100)

statement ok
INSERT INTO t VALUES (6, NULL, 300), (7, NULL, 300)

# INSERT ... SELECT takes the same enforcement path
statement ok
INSERT INTO t VALUES (8, 40, 400)

statement error 23505
INSERT INTO t SELECT id + 20, v, w FROM t WHERE id = 8

# the PK duplicate is reported before UNIQUE when one row violates both
statement error 23505
INSERT INTO t VALUES (1, 10, 999)

# a genuine UPDATE conflict with an untouched row
statement error 23505
UPDATE t SET v = 40 WHERE id = 1

# --- the constraint IS its index: names occupy the relation namespace ------------

# the auto-name t_v_key exists ...
statement error 42P07
CREATE INDEX t_v_key ON t (w)

statement error 42P07
CREATE TABLE t_v_key (x i32)

# ... and the CONSTRAINT name became the index wv
statement error 42P07
CREATE INDEX wv ON t (w)

# --- member resolution (PG codes, in PG's order) ----------------------------------

statement error 42703
CREATE TABLE e2 (a i32, UNIQUE (nosuch))

statement error 42701
CREATE TABLE e1 (a i32, UNIQUE (a, a))

# a non-key-encodable member is the documented 0A000 narrowing (as for PK / CREATE INDEX)
statement error 0A000
CREATE TABLE e6 (a i32, s text UNIQUE)

# --- dedup and the PK fold ---------------------------------------------------------

# the PK absorbs an identical-list UNIQUE; identical UNIQUE lists fold into one
statement ok
CREATE TABLE f (a i32 PRIMARY KEY UNIQUE, b i32 UNIQUE, UNIQUE (b))

# no index f_a_key was created (the PK absorbed it) — the name is free ...
statement ok
CREATE TABLE f_a_key (x i32)

# ... while the folded pair left exactly one f_b_key
statement error 42P07
CREATE TABLE f_b_key (x i32)

statement ok
DROP TABLE f_a_key

# --- naming collisions --------------------------------------------------------------

# an explicit constraint name vs an existing relation, vs its own table, and vs a
# same-statement sibling — all 42P07 (the relation namespace)
statement error 42P07
CREATE TABLE c2 (a i32, CONSTRAINT t UNIQUE (a))

statement error 42P07
CREATE TABLE p4 (a i32, CONSTRAINT p4 UNIQUE (a))

statement error 42P07
CREATE TABLE e8 (a i32, CONSTRAINT x UNIQUE (a), b i32, CONSTRAINT x UNIQUE (b))

# ... vs a CHECK constraint's name it is 42710 (the per-table constraint namespace),
# in either declaration order
statement error 42710
CREATE TABLE z4 (a i32, CONSTRAINT zc CHECK (a > 0), CONSTRAINT zc UNIQUE (a))

statement error 42710
CREATE TABLE z5 (a i32, CONSTRAINT zc UNIQUE (a), CONSTRAINT zc CHECK (a > 0))

# --- CREATE UNIQUE INDEX: build verification ---------------------------------------

statement ok
CREATE TABLE d (id i32 PRIMARY KEY, a i32, n i32)

statement ok
INSERT INTO d VALUES (1, 7, NULL), (2, 7, NULL), (3, 8, 5)

# building over existing duplicates fails and registers nothing
statement error 23505
CREATE UNIQUE INDEX dup ON d (a)

# nothing was created — the name is free
statement ok
CREATE TABLE dup (x i32)

statement ok
DROP TABLE dup

# NULLs are exempt at build (two NULLs in n); the build charges exactly the plain
# scan — page_read(1 node) + 3 storage_row_read — the verification is unmetered
# cost: 4
statement ok
CREATE UNIQUE INDEX ON d (n)

# d_n_idx (the _idx auto-name) enforces thereafter
statement error 23505
INSERT INTO d VALUES (4, 9, 5)

statement ok
INSERT INTO d VALUES (4, 9, NULL)

# an INSERT into a uniquely-indexed table still costs zero (the probe is unmetered)
# cost: 0
statement ok
INSERT INTO d VALUES (5, 1, 1)

# --- documented PG divergences (oracle-overridden; the PG-failing oks sit LAST so they
# cannot poison the oracle replay prefix — conformance.md §5) ------------------------

statement ok
CREATE TABLE m (id i32 PRIMARY KEY, vv i32 UNIQUE)

statement ok
INSERT INTO m VALUES (1, 1), (2, 2), (3, 30)

# UPDATE validates uniqueness against the statement's END STATE (indexes.md §8): the
# transient per-row collision (1,2 -> 2,3) succeeds in jed; PG fails it in heap order
statement ok
UPDATE m SET vv = vv + 1 WHERE id < 3

query I nosort
SELECT vv FROM m ORDER BY id
----
2
3
30

# a value swap is the same divergence
statement ok
UPDATE m SET vv = 5 - vv WHERE id < 3

query I nosort
SELECT vv FROM m ORDER BY id
----
3
2
30

# DROP INDEX of a constraint-backed unique index drops the constraint with it (jed has
# no ALTER TABLE ... DROP CONSTRAINT — the index name is the constraint's only handle;
# PG refuses with 2BP01)
statement ok
DROP INDEX m_vv_key

statement ok
INSERT INTO m VALUES (4, 30)
