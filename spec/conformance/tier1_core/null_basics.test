# tier1_core — NULL storage and three-valued logic (CLAUDE.md §4).
# Format: ../../design/conformance.md.

statement ok
CREATE TABLE t (id int32 PRIMARY KEY, v int16)

statement ok
INSERT INTO t VALUES (1, 10)

statement ok
INSERT INTO t VALUES (2, NULL)

# IS NULL selects the null row
query I nosort
SELECT id FROM t WHERE v IS NULL
----
2

# IS NOT NULL selects the rest
query I nosort
SELECT id FROM t WHERE v IS NOT NULL
----
1

# three-valued logic: `= NULL` is UNKNOWN, never TRUE -> no rows
query I nosort
SELECT id FROM t WHERE v = NULL
----

# a NULL value also never satisfies equality with a non-null
query I nosort
SELECT id FROM t WHERE v = 10 ORDER BY id
----
1

# NULL renders as the literal NULL in output
query II nosort
SELECT id, v FROM t ORDER BY id
----
1
10
2
NULL
